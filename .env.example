# ============================================================================
# VARIABLES DE ENTORNO - LEMES Medical System Backend
# ============================================================================
# Copia este archivo a .env y rellena tus valores reales

# ============================================================================
# SUPABASE / BASE DE DATOS
# ============================================================================

# URL de conexión a la base de datos PostgreSQL (Supabase)
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXXX.supabase.co:5432/postgres

# ============================================================================
# EXPRESS SERVER
# ============================================================================

# Puerto donde corre el servidor
PORT=3000

# Entorno (development, production, test)
NODE_ENV=development

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================

# Clave secreta para firmar JWT (generar una fuerte en producción)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production-12345

# Tiempo de expiración del JWT (ej: "24h", "7d")
JWT_EXPIRES_IN=24h

# ============================================================================
# BCRYPT
# ============================================================================

# Costo de bcrypt (10-12 es estándar, mayor = más seguro pero lento)
BCRYPT_ROUNDS=10

# ============================================================================
# APLICACIÓN
# ============================================================================

# Nombre de la aplicación
APP_NAME=LEMES Medical System

# Descripción
APP_DESCRIPTION=Backend API para Sistema Médico LEMES

# ============================================================================
# CORS
# ============================================================================

# URLs permitidas para CORS (separadas por comas si hay varias)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============================================================================
# LOGGING
# ============================================================================

# Nivel de log (debug, info, warn, error)
LOG_LEVEL=debug

# Ruta del archivo de logs
LOG_FILE=./logs/app.log

# ============================================================================
# EMAIL (para notificaciones futuras)
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@lemes.com

# ============================================================================
# STORAGE (para archivos)
# ============================================================================

# Bucket para almacenar documentos
STORAGE_BUCKET=documentos

# URL pública de storage
STORAGE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/
