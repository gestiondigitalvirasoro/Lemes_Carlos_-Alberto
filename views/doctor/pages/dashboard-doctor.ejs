    // ============================================================
    // MOSTRAR TABLA DE TURNOS CON ACCIONES
    // ============================================================
    function mostrarTablaTurnos() {
      const tbody = document.getElementById('turnos-tabla-body');

      // Contador de turnos
      const counter = document.getElementById('turnos-counter');
      if (counter) {
        const total = turnosHoy.length;
        const finalizados = turnosHoy.filter(t => t.estado === 'FINALIZADA').length;
        const enConsulta = turnosHoy.filter(t => t.estado === 'EN_CONSULTA').length;
        const pendientes = turnosHoy.filter(t => t.estado === 'PENDIENTE').length;
        counter.innerHTML = `
          <span class="turnos-counter-item"><span>${total}</span> turno${total !== 1 ? 's' : ''} hoy</span>
          ${enConsulta > 0 ? `<span class="turnos-counter-item" style="color:#007BFF;"><span>${enConsulta}</span> en consulta</span>` : ''}
          ${pendientes > 0 ? `<span class="turnos-counter-item" style="color:#FFC107;"><span>${pendientes}</span> pendiente${pendientes !== 1 ? 's' : ''}</span>` : ''}
          ${finalizados > 0 ? `<span class="turnos-counter-item" style="color:#28A745;"><span>${finalizados}</span> finalizado${finalizados !== 1 ? 's' : ''}</span>` : ''}
        `;
      }

      if (turnosHoy.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">No hay turnos hoy</td></tr>';
        return;
      }

      tbody.innerHTML = turnosHoy.map(turno => {
        const paciente = turno.paciente;
        let botonesAccion = '';

        // Generar botones según el estado
        if (turno.estado === 'PENDIENTE') {
          botonesAccion = `<span class="text-muted" style="font-size: 0.8rem;"><i class="bi bi-mouse2"></i> Doble clic para iniciar</span>`;
        } else if (turno.estado === 'EN_CONSULTA') {
          botonesAccion = `
            <button class="btn btn-sm btn-info" onclick="abrirHistoriaClinica(${turno.id}, ${turno.paciente.id})" title="Ver historia clínica">
              <i class="bi bi-file-earmark-text"></i> Historia
            </button>
            <button class="btn btn-sm btn-success" onclick="finalizarConsultaTurno(${turno.id})" title="Finalizar consulta">
              <i class="bi bi-check-circle"></i> Finalizar
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="cancelarConsultaTurno(${turno.id})" title="Cancelar turno">
              <i class="bi bi-x-circle"></i>
            </button>
          `;
        } else if (turno.estado === 'FINALIZADA' || turno.estado === 'CANCELADA') {
          botonesAccion = `
            <span class="text-muted" style="font-size: 0.85rem;">—</span>
          `;
        }
        
        const esPendiente = turno.estado === 'PENDIENTE';
        const hayEnConsulta = turnosHoy.some(t => t.estado === 'EN_CONSULTA');
        const dblclick = esPendiente && !hayEnConsulta
          ? `ondblclick="iniciarConsultaTurno(${turno.id})" style="cursor:pointer;" title="Doble clic para iniciar consulta"`
          : '';

        return `<tr ${dblclick} class="${esPendiente && !hayEnConsulta ? 'fila-pendiente-seleccionable' : ''}">
          <td><small class="text-muted">${turno.fecha}</small></td>
          <td><strong>${turno.hora}</strong></td>
          <td>${paciente.nombre} ${paciente.apellido}</td>
          <td>${formatEdad(paciente.edad)}</td>
          <td>${paciente.obraSocial || '-'}</td>
          <td><span class="estado-badge estado-${turno.estado}">${formatEstado(turno.estado)}</span></td>
          <td style="min-width: 280px;">
            <div style="display: flex; gap: 4px; flex-wrap: wrap;">
              ${botonesAccion}
            </div>
          </td>
        </tr>`;
      }).join('');
    }

    // ============================================================
    // CARGAR ALERTAS CLÍNICAS
    // ============================================================
    function cargarAlertas() {
      fetch('/api/alertas-clinicas', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => res.json())
        .then(data => {
          console.log('🚨 Alertas:', data);
          if (data.success && data.alertas) {
            mostrarAlertas(data.alertas);
          }
        })
        .catch(error => console.error('Error alertas:', error));
    }

    function mostrarAlertas(alertas) {
      const bloque = document.querySelector('.alertas-clinicas');
      const contenedor = document.getElementById('contenedor-alertas');

      if (alertas.length === 0) {
        // Ocultar bloque completo cuando no hay alertas
        if (bloque) bloque.style.display = 'none';
        return;
      }

      if (bloque) bloque.style.display = '';

      const renderItem = (a, cls) => {
        let btnNotif = '';
        if (a.prioridad === 'solicitud_turno') {
          btnNotif = `<div style="display:flex;gap:5px;margin-top:8px;flex-wrap:wrap;">
            ${a.whatsapp_url ? `<button onclick="notificarSolicitudWA('${a.solicitud_id}','${a.whatsapp_url}',this)"
              style="padding:3px 9px;background:#25D366;color:white;border:none;border-radius:4px;font-size:11px;cursor:pointer;font-weight:600;">💬 WhatsApp</button>` : ''}
            ${a.email ? `<button onclick="notificarSolicitudEmail('${a.solicitud_id}','${a.email}',this)"
              style="padding:3px 9px;background:#3b82f6;color:white;border:none;border-radius:4px;font-size:11px;cursor:pointer;font-weight:600;">📧 Email</button>` : ''}
            <button onclick="accionSolicitud('${a.solicitud_id}','Turno asignado',this)"
              style="padding:3px 9px;background:#28a745;color:white;border:none;border-radius:4px;font-size:11px;cursor:pointer;font-weight:600;">✅ Ya tiene turno</button>
            <button onclick="accionSolicitud('${a.solicitud_id}','Vencida',this)"
              style="padding:3px 9px;background:#fd7e14;color:white;border:none;border-radius:4px;font-size:11px;cursor:pointer;font-weight:600;">⌛ Venció</button>
            <button onclick="cerrarNotifSolicitud('${a.solicitud_id}',this)"
              style="padding:3px 9px;background:#e2e8f0;color:#555;border:none;border-radius:4px;font-size:11px;cursor:pointer;">✕ Cerrar</button>
            <button onclick="accionSolicitud('${a.solicitud_id}','Cancelada',this)"
              style="padding:3px 9px;background:#dc3545;color:white;border:none;border-radius:4px;font-size:11px;cursor:pointer;font-weight:600;">❌ Cancelar</button>
          </div>`;
        }
        return `
          <div class="alerta-item ${cls}" id="alerta-sol-${a.solicitud_id || ''}">
            <div class="alerta-icono"><i class="bi ${a.icono || 'bi-exclamation-circle'}"></i></div>
            <div class="alerta-contenido">
              <p class="alerta-titulo">${a.titulo}</p>
              <p class="alerta-valor">${a.descripcion}</p>
              <p class="alerta-paciente">→ ${a.paciente}${a.turno_hora ? ' · turno ' + a.turno_hora : ''}</p>
              ${btnNotif}
            </div>
          </div>`;
      };

      // Agrupar por prioridad
      const grupos = {
        critica:         alertas.filter(a => a.prioridad === 'critica'),
        importante:      alertas.filter(a => a.prioridad === 'importante'),
        informativa:     alertas.filter(a => a.prioridad === 'informativa'),
        solicitud_turno: alertas.filter(a => a.prioridad === 'solicitud_turno')
      };

      const renderCategoria = (titulo, icono, items, catClass, itemClass) => {
        if (items.length === 0) return '';
        return `
          <div class="alertas-categoria ${catClass}">
            <h6>${icono} ${titulo} <small style="font-weight:400; margin-left:8px; opacity:0.7;">${items.length}</small></h6>
            ${items.map(a => renderItem(a, itemClass)).join('')}
          </div>`;
      };

      contenedor.innerHTML = `<div class="alertas-grid">
        ${renderCategoria('Críticas', '⚠️', grupos.critica, 'cat-critica', 'alerta-critica')}
        ${renderCategoria('Importantes', '⏱', grupos.importante, 'cat-importante', 'alerta-importante')}
        ${renderCategoria('Informativas', 'ℹ️', grupos.informativa, 'cat-informativa', 'alerta-informativa')}
        ${renderCategoria('Solicitudes de turno', '📅', grupos.solicitud_turno, 'cat-informativa', 'alerta-informativa')}
      </div>`;
    }

    function switchTab(tabName) {
      // Ocultar todos los tabs
      document.querySelectorAll('.tab-content').forEach(tab => {
        tab.style.display = 'none';
      });
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.classList.remove('active');
      });

      // Mostrar tab seleccionado
      document.getElementById(`tab-${tabName}`).style.display = 'block';
      event.target.classList.add('active');

      // Cargar contenido según tab
      if (tabName === 'anamnesis' && historiasData.anamnesis !== undefined) {
        document.getElementById('anamnesis-text').textContent = historiasData.anamnesis || 'Sin anamnesis registrada';
      }
      // Aquí agregarías más lógica para otros tabs...
    }

    // ============================================================
    // FUNCIONES PARA BUSCAR PACIENTES (AUTOCOMPLETE)
    // ============================================================
    function filtrarPacientes(input, containerId) {
      const valor = input.value.toLowerCase();
      const container = document.getElementById(containerId);

      if (valor.length < 2) {
        container.innerHTML = '';
        return;
      }

      const filtrados = pacientesList.filter(p =>
        p.nombre.toLowerCase().includes(valor) ||
        p.apellido.toLowerCase().includes(valor) ||
        p.dni.toString().includes(valor)
      ).slice(0, 10);

      container.innerHTML = filtrados.map(p =>
        `<div class="autocomplete-item" onclick="seleccionarPaciente(${p.id}, '${p.nombre}', '${p.apellido}', '${input.id}', '${containerId}')" style="padding:8px; cursor:pointer; border-bottom:1px solid #eee; hover:background:#f0f0f0;">
          ${p.nombre} ${p.apellido} (DNI: ${p.dni}) - ${p.obra_social || 'Sin obra social'}
        </div>`
      ).join('');
    }

    function seleccionarPaciente(id, nombre, apellido, inputId, containerId) {
      document.getElementById(inputId).value = `${nombre} ${apellido}`;
      document.getElementById(inputId.replace('-input', '-id')).value = id;
      document.getElementById(containerId).innerHTML = '';
    }

    // ============================================================
    // FUNCIONES PARA GUARDAR
    // ============================================================
    // ==== MANEJO DE OPCIONES: Buscar vs Crear Paciente ====
    function initOpcionesTurno() {
      const opcionBuscar = document.getElementById('opcion-buscar');
      const opcionCrear = document.getElementById('opcion-crear');
      const seccionBuscar = document.getElementById('seccion-buscar');
      const seccionCrear = document.getElementById('seccion-crear');

      if (!opcionBuscar || !opcionCrear) {
        console.log('⚠️ Elementos no encontrados, reintentando...');
        setTimeout(initOpcionesTurno, 100);
        return;
      }

      opcionBuscar.addEventListener('change', () => {
        if (seccionBuscar) seccionBuscar.style.display = 'block';
        if (seccionCrear) seccionCrear.style.display = 'none';
      });

      opcionCrear.addEventListener('change', () => {
        if (seccionBuscar) seccionBuscar.style.display = 'none';
        if (seccionCrear) seccionCrear.style.display = 'block';
      });
    }

    // Ejecutar cuando el modal se abre
    const modalNuevoTurno = document.getElementById('modalNuevoTurno');
    if (modalNuevoTurno) {
      modalNuevoTurno.addEventListener('show.bs.modal', () => {
        initOpcionesTurno();
      });
    }

    function guardarNuevoTurno() {
      const opcionElement = document.querySelector('input[name="opcion-paciente"]:checked');
      if (!opcionElement) {
        alert('⚠️ Selecciona una opción');
        return;
      }

      const opcion = opcionElement.value;
      const fecha = document.getElementById('turno-fecha').value;
      const hora = document.getElementById('turno-hora').value;

      if (!fecha || !hora) {
        alert('⚠️ Falta Fecha y/o Hora');
        return;
      }

      if (opcion === 'buscar') {
        // Opción: Buscar PERSONA existente CON TURNO
        const personaId = document.getElementById('turno-paciente-id').value;
        if (!personaId) {
          alert('⚠️ Selecciona una persona con turno');
          return;
        }
        const obs = document.getElementById('turno-obs').value;

        showLoading('Creando turno...');
        fetch('/api/turnos/crear', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            persona_id: personaId,
            fecha: fecha,
            hora: hora,
            observaciones: obs
          })
        })
          .then(res => res.json())
          .then(data => {
            hideLoading();
            if (data.success) {
              alert('✅ Turno creado exitosamente');
              const modal = bootstrap.Modal.getInstance(document.getElementById('modalNuevoTurno'));
              if (modal) modal.hide();
              document.getElementById('formNuevoTurno').reset();
              cargarTurnos();
            } else {
              alert('❌ Error: ' + (data.message || data.error));
            }
          })
          .catch(err => {
            hideLoading();
            console.error('Error:', err);
            alert('❌ Error al crear turno');
          });
      } else {
        // Opción: Crear nuevo paciente
        const nombre = document.getElementById('turno-nombre').value.trim();
        const apellido = document.getElementById('turno-apellido').value.trim();
        const dni = document.getElementById('turno-dni').value.trim();

        if (!nombre || !apellido || !dni) {
          alert('⚠️ Completa Nombre, Apellido y DNI');
          return;
        }

        const telefono = document.getElementById('turno-telefono').value?.trim() || null;
        const fecha_nacimiento = document.getElementById('turno-fecha-nac').value || null;
        const obra_social = document.getElementById('turno-obra-social').value?.trim() || null;
        const numero_afiliado = document.getElementById('turno-numero-afiliado').value?.trim() || null;
        const obs = document.getElementById('turno-obs').value;

        showLoading('Creando paciente y turno...');
        fetch('/api/turnos/crear-con-paciente', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre,
            apellido,
            dni,
            telefono,
            fecha_nacimiento,
            obra_social,
            numero_afiliado,
            fecha,
            hora,
            observaciones: obs
          })
        })
          .then(res => res.json())
          .then(data => {
            hideLoading();
            if (data.success) {
              alert('✅ Paciente y Turno creados');
              const modal = bootstrap.Modal.getInstance(document.getElementById('modalNuevoTurno'));
              if (modal) modal.hide();
              document.getElementById('formNuevoTurno').reset();
              document.getElementById('opcion-buscar').checked = true;
              cargarTurnos();
            } else {
              alert('❌ Error: ' + (data.message || data.error));
            }
          })
          .catch(err => {
            hideLoading();
            console.error('Error:', err);
            alert('❌ Error al crear paciente y turno');
          });
      }
    }

    function guardarNuevaConsulta() {
      const pacienteId = document.getElementById('consulta-paciente-id').value;
      const motivo = document.getElementById('consulta-motivo').value;

      if (!pacienteId || !motivo) {
        alert('Completa todos los campos');
        return;
      }

      fetch('/api/consultas/crear', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paciente_id: pacienteId, motivo_consulta: motivo })
      })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✅ Consulta iniciada');
            document.getElementById('formNuevaConsulta').reset();
            bootstrap.Modal.getInstance(document.getElementById('modalNuevaConsulta')).hide();
          } else {
            alert('❌ Error: ' + data.error);
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Error: ' + error.message);
        });
    }

