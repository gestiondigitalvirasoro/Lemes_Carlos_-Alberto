    async function guardarAltaDashboard(turnoId) {
      const nombre = document.getElementById('dAltaNombre').value.trim();
      const apellido = document.getElementById('dAltaApellido').value.trim();
      if (!nombre || !apellido) { alert('Nombre y Apellido son obligatorios'); return; }
      const btn = document.getElementById('btnGuardarAltaD');
      btn.disabled = true; btn.innerHTML = '⏳ Guardando...';
      showLoading('Dando de alta e iniciando consulta...');
      try {
        const response = await fetch(`/api/turnos/${turnoId}/confirmar-llegada`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            nombre,
            apellido,
            telefono: document.getElementById('dAltaTelefono').value.trim() || null,
            email: document.getElementById('dAltaEmail').value.trim() || null,
            obra_social: document.getElementById('dAltaObraSocial').value.trim() || null,
            numero_afiliado: document.getElementById('dAltaNumeroAfiliado').value.trim() || null
          })
        });
        const data = await response.json();
        hideLoading();
        if (response.ok && data.success) {
          document.getElementById('modalAltaContainer').innerHTML = '';
          const pacienteId = data.data?.paciente_id;
          if (pacienteId) {
            window.open(`/doctor/historia-nueva?paciente_id=${pacienteId}&turno_id=${turnoId}`, '_blank');
          } else {
            window.location.reload();
          }
        } else {
          throw new Error(data.message || 'Error al dar de alta');
        }
      } catch (error) {
        hideLoading();
        btn.disabled = false; btn.innerHTML = '✅ Guardar e Iniciar';
        alert('❌ ' + error.message);
      }
    }

