    // ============================================================
    // CANCELAR CONSULTA
    // ============================================================
    async function cancelarConsultaTurno(turnoId) {
      if (!confirm('¿Estás seguro de que deseas cancelar esta consulta?')) {
        return;
      }

      try {
        showLoading('Cancelando consulta...');
        console.log('🔄 Cancelando consulta para turno:', turnoId);
        const token = localStorage.getItem('token');
        
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',
          body: JSON.stringify({ estado: 'CANCELADA' })
        });

        console.log('📡 Response status:', response.status);
        const data = await response.json();
        console.log('📊 Response data:', data);

        if (!response.ok) {
          hideLoading();
          if (response.status === 401) {
            throw new Error('🔐 AUTENTICACIÓN: Token inválido o expirado');
          }
          if (response.status === 403) {
            throw new Error('❌ PERMISO: Solo doctor o secretaria pueden cancelar turnos');
          }
          throw new Error(data.message || 'Error al cancelar la consulta');
        }

        console.log('✅ Consulta cancelada:', data);
        hideLoading();
        alert('✅ Consulta cancelada correctamente');
        cargarTurnos(); // Recargar datos
      } catch (error) {
        hideLoading();
        console.error('❌ Error:', error);
        alert('Error: ' + error.message);
      }
    }

