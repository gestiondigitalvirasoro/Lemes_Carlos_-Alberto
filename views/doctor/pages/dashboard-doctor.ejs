        `;
      } else if (siguiente.estado === 'EN_CONSULTA') {
        botonesDiv.innerHTML = `
          <button class="btn btn-sm btn-info" style="padding: 6px 16px; font-weight: 600;" onclick="abrirHistoriaClinica(${siguiente.id}, ${siguiente.paciente.id})">
            <i class="bi bi-file-earmark-text"></i> Ver Historia
          </button>
          <button class="btn btn-sm btn-success" style="padding: 6px 16px; font-weight: 600;" onclick="finalizarConsultaTurno(${siguiente.id})">
            <i class="bi bi-check-circle"></i> Finalizar
          </button>
          <button class="btn btn-sm btn-outline-danger" style="padding: 6px 14px; font-weight: 600;" onclick="cancelarConsultaTurno(${siguiente.id})">
            <i class="bi bi-x-circle"></i> Cancelar
          </button>
        `;
      }

      console.log('✅ Próximo paciente mostrado:', siguiente.estado, paciente.nombre);
    }

    // ============================================================
    // CAMBIAR ESTADO DEL TURNO
    // ============================================================
    async function iniciarConsultaTurno(turnoId) {
      try {
        showLoading('Iniciando consulta y abriendo historia clínica...');
        console.log('🔄 Iniciando consulta para turno:', turnoId);
        const token = localStorage.getItem('token');
        console.log('🔑 Token en localStorage:', token ? '✅ Presente' : '❌ No presente');
        
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',  // 👈 ENVIAR COOKIES AUTOMÁTICAMENTE
          body: JSON.stringify({ estado: 'EN_CONSULTA' })
        });

        console.log('📡 Response status:', response.status);
        const data = await response.json();
        console.log('📊 Response data:', data);

        if (!response.ok) {
          if (response.status === 401) {
            console.error('❌ AUTHENTICATION ERROR');
            hideLoading();
            throw new Error('🔐 AUTENTICACIÓN: Token inválido o expirado. Contacta al administrador.');
          }
          
          if (response.status === 403) {
            console.error('❌ PERMISSION ERROR');
            hideLoading();
            throw new Error('❌ PERMISO: Solo doctor o secretaria pueden cambiar el estado del turno');
          }
          
          if (response.status === 409) {
            console.warn('⚠️ CONFLICT: Ya hay una consulta activa');
            hideLoading();
            consultaActivaData = data.consultaActiva || {};
            turnoEnIntento = turnoId;
            mostrarModalConsultaActiva(data);
            return;
          }

          if (response.status === 422 && data.pacienteIncompleto) {
            hideLoading();
            abrirModalAltaDashboard(turnoId, data.datosActuales || {});
            return;
          }

          hideLoading();
          throw new Error(data.message || 'Error al cambiar el estado');
        }

        console.log('✅ Consulta iniciada:', data);
        
        // 🎯 Obtener paciente_id del response
        const pacienteId = data.data?.paciente_id;
        console.log('👤 Paciente ID:', pacienteId);
        
        if (!pacienteId) {
          throw new Error('No se pudo obtener el ID del paciente');
        }

        // 📂 Abrir NUEVA consulta en blanco en pestaña nueva
        hideLoading();
        const historiaUrl = `/doctor/historia-nueva?paciente_id=${pacienteId}&turno_id=${turnoId}`;
        window.open(historiaUrl, '_blank');
        
      } catch (error) {
        hideLoading();
        console.error('❌ Error:', error);
        alert('Error: ' + error.message);
      }
    }

