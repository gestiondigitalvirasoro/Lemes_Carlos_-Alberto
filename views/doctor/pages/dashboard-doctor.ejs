  <!-- LOADER OVERLAY -->
  <div class="loader-overlay" id="loaderOverlay">
    <div class="loader-container">
      <div class="spinner"></div>
      <div class="loader-text" id="loaderText">Procesando...</div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 🔐 TOKEN PASADO POR EL SERVIDOR
    const TOKEN_FROM_SERVER = '<%= token %>';
    console.log('🔐 Token recibido del servidor:', TOKEN_FROM_SERVER.substring(0, 50) + '...');
    
    // Guardar en localStorage
    if (TOKEN_FROM_SERVER && TOKEN_FROM_SERVER.trim().length > 10) {
      localStorage.setItem('token', TOKEN_FROM_SERVER);
      console.log('✅ Token guardado en localStorage');
    }
    
    let turnosHoy = [];
    let historiasData = {};
    let pacientesList = [];
    let consultaActivaData = null;
    let turnoEnIntento = null;

    // Helpers de formato
    function formatEstado(estado) {
      const map = {
        'EN_CONSULTA': 'En Consulta',
        'PENDIENTE': 'Pendiente',
        'FINALIZADA': 'Finalizada',
        'CANCELADA': 'Cancelada',
        'AUSENTE': 'Ausente'
      };
      return map[estado] || estado;
    }

    function formatEdad(edad) {
      if (edad === '--' || edad === null || edad === undefined || edad === '') return '-';
      if (typeof edad === 'number' && edad === 0) return '-';
      return edad + ' años';
    }

    // Funciones para el loader
    function showLoading(mensaje = 'Procesando...') {
      document.getElementById('loaderText').textContent = mensaje;
      document.getElementById('loaderOverlay').classList.add('active');
    }

    function hideLoading() {
      document.getElementById('loaderOverlay').classList.remove('active');
    }

    document.addEventListener('DOMContentLoaded', function () {
      cargarTurnos();
      cargarAlertas();
      cargarPacientes();
      cargarIncidencias();
    });

    // ============================================================
    // PRÓXIMAS VISITAS / INCIDENCIAS
    // ============================================================
    async function cargarIncidencias() {
      const cont = document.getElementById('incidencias-dashboard');
      try {
        const resp = await fetch('/api/incidencias', { credentials: 'include' });
        const data = await resp.json();
        if (!data.success || !data.data.length) {
          cont.innerHTML = '<div style="text-align:center;color:#aaa;padding:16px;font-size:13px;">No hay próximas visitas pendientes.</div>';
          return;
        }
        const COLOR_ESTADO = { 'Pendiente':'#ffc107','Notificada':'#17a2b8','Turno asignado':'#28a745','Reprogramada':'#fd7e14' };
        const COLOR_PRIOR  = { 'Urgente':'#dc3545','Alta':'#fd7e14','Normal':'#6c757d' };
        cont.innerHTML = `
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:13px;">
              <thead>
                <tr style="background:#f8f9fa;color:#555;">
                  <th style="padding:10px;text-align:left;font-weight:600;border-bottom:2px solid #eee;">Paciente</th>
                  <th style="padding:10px;text-align:left;font-weight:600;border-bottom:2px solid #eee;">Fecha sugerida</th>
                  <th style="padding:10px;text-align:left;font-weight:600;border-bottom:2px solid #eee;">Motivo</th>
                  <th style="padding:10px;text-align:left;font-weight:600;border-bottom:2px solid #eee;">Estado</th>
                  <th style="padding:10px;text-align:left;font-weight:600;border-bottom:2px solid #eee;">Turno asignado</th>
                  <th style="padding:10px;text-align:left;font-weight:600;border-bottom:2px solid #eee;">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${data.data.map(i => {
                  const fecha = i.fecha_sugerida ? new Date(i.fecha_sugerida).toLocaleDateString('es-AR') : '-';
                  const turnoInfo = i.turno_fecha ? `${new Date(i.turno_fecha).toLocaleDateString('es-AR')} ${i.turno_hora || ''}` : '—';
                  const colorEst = COLOR_ESTADO[i.estado] || '#6c757d';
                  const colorPri = COLOR_PRIOR[i.prioridad] || '#6c757d';
                  const puedeNotificar = i.estado === 'Pendiente' || i.estado === 'Notificada';
                  return `<tr style="border-bottom:1px solid #f0f0f0;">
                    <td style="padding:10px;">
                      <strong>${i.paciente}</strong><br>
                      <small style="color:#888;">DNI: ${i.paciente_dni || '-'}</small><br>
                      <span style="background:${colorPri};color:white;border-radius:3px;padding:1px 6px;font-size:10px;">${i.prioridad}</span>
                    </td>
                    <td style="padding:10px;"><strong>${fecha}</strong><br><small style="color:#aaa;">±${i.dias_tolerancia} días</small></td>
                    <td style="padding:10px;">${i.motivo || '—'}<br>${i.observaciones ? `<small style="color:#888;">${i.observaciones}</small>` : ''}</td>
                    <td style="padding:10px;"><span style="background:${colorEst};color:white;border-radius:4px;padding:3px 8px;font-size:11px;font-weight:600;">${i.estado}</span>
                      ${i.fecha_notificacion ? `<br><small style="color:#aaa;">Notif: ${new Date(i.fecha_notificacion).toLocaleDateString('es-AR')}</small>` : ''}
                    </td>
                    <td style="padding:10px;">${turnoInfo}</td>
                    <td style="padding:10px;white-space:nowrap;">
                      ${puedeNotificar ? `
                        <button onclick="notificarIncidencia('${i.id}','${i.paciente_telefono}','${i.paciente_email}')"
                          style="padding:4px 10px;background:#25D366;color:white;border:none;border-radius:4px;font-size:11px;cursor:pointer;margin-bottom:3px;display:block;">
                          📲 Notificar
                        </button>` : ''}
                      <button onclick="cancelarIncidenciaDash('${i.id}')"
                        style="padding:4px 10px;background:#fee2e2;color:#dc2626;border:none;border-radius:4px;font-size:11px;cursor:pointer;display:block;">
                        ✕ Cancelar
                      </button>
                    </td>
                  </tr>`;
                }).join('')}
              </tbody>
            </table>
          </div>`;
      } catch(e) {
        cont.innerHTML = '<div style="color:#dc3545;padding:12px;font-size:13px;">Error al cargar próximas visitas.</div>';
      }
    }

    async function notificarIncidencia(id, telefono, email) {
      const opciones = [];
      if (telefono) opciones.push('WhatsApp');
      if (email) opciones.push('Email');
      if (!opciones.length) { alert('El paciente no tiene teléfono ni email registrado.'); return; }
      const canal = opciones.length === 2
        ? (confirm('¿Enviar por WhatsApp?\nCancelar = Email') ? 'whatsapp' : 'email')
        : (opciones[0] === 'WhatsApp' ? 'whatsapp' : 'email');
      try {
        const resp = await fetch(`/api/incidencias/${id}/notificar`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ canal, telefono, email })
        });
        const data = await resp.json();
        if (data.success) {
          if (data.whatsapp_url) window.open(data.whatsapp_url, '_blank');
          else alert('✅ Email enviado correctamente');
          cargarIncidencias();
        } else {
          alert('Error: ' + data.error);
        }
      } catch(e) {
        alert('Error de red');
      }
    }

    async function notificarIncDesdeAlerta(id) {
      await fetch(`/api/incidencias/${id}/notificar`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        credentials: 'include', body: JSON.stringify({ canal: 'whatsapp' })
      });
      cargarAlertas();
      cargarIncidencias();
    }

    async function notificarEmailIncAlerta(id, email) {
      const resp = await fetch(`/api/incidencias/${id}/notificar`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        credentials: 'include', body: JSON.stringify({ canal: 'email', email })
      });
      const data = await resp.json();
      if (data.success) alert('✅ Email enviado correctamente');
      else alert('Error: ' + data.error);
      cargarAlertas();
      cargarIncidencias();
    }

    // === Funciones para solicitudes de turno en alertas ===
    async function accionSolicitud(id, estado, btn) {
      const card = document.getElementById(`alerta-sol-${id}`);
      try {
        await fetch(`/api/solicitudes-turno/${id}/estado`, {
          method: 'PUT', headers: { 'Content-Type': 'application/json' },
          credentials: 'include', body: JSON.stringify({ estado })
        });
        if (card) card.style.transition = 'opacity 0.3s', card.style.opacity = '0', setTimeout(() => card.remove(), 300);
      } catch(e) { alert('Error al actualizar solicitud'); }
    }

    async function notificarSolicitudWA(id, url, btn) {
      window.open(url, '_blank');
      await fetch(`/api/solicitudes-turno/${id}/notificar`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        credentials: 'include', body: JSON.stringify({ canal: 'whatsapp' })
      });
    }

    async function notificarSolicitudEmail(id, email, btn) {
      const resp = await fetch(`/api/solicitudes-turno/${id}/notificar`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        credentials: 'include', body: JSON.stringify({ canal: 'email', email })
      });
      const data = await resp.json();
      if (data.success) alert('✅ Email enviado correctamente');
      else alert('Error: ' + (data.error || 'No se pudo enviar'));
    }

    function cerrarNotifSolicitud(id, btn) {
      const card = document.getElementById(`alerta-sol-${id}`);
      if (card) card.style.transition = 'opacity 0.3s', card.style.opacity = '0', setTimeout(() => card.remove(), 300);
    }

    // ============================================================
    // CARGAR LISTA DE PACIENTES (para autocomplete)
    // ============================================================
    function cargarPacientes() {
      fetch('/api/pacientes-lista', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            pacientesList = data.data;
            console.log('👥 Pacientes cargados:', pacientesList.length);
          }
        })
        .catch(error => console.error('Error:', error));
    }

    // ============================================================
    // CARGAR TURNOS DE HOY
    // ============================================================
    function cargarTurnos() {
      fetch('/api/dashboard-turnos', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => {
          console.log('📡 Response status:', res.status);
          return res.json();
        })
        .then(data => {
          console.log('📊 Turnos cargados:', data);
          if (data.success && data.data) {
            // 🔄 Ordenar por PRIORIDAD de estado + hora
            turnosHoy = data.data.sort((a, b) => {
              // Prioridad de estados: EN_CONSULTA > PENDIENTE > FINALIZADA/CANCELADA
              const prioridad = {
                'EN_CONSULTA': 1,
                'PENDIENTE': 2,
                'FINALIZADA': 3,
                'CANCELADA': 4
              };
              
              const prioA = prioridad[a.estado] || 99;
              const prioB = prioridad[b.estado] || 99;
              
              // Primero comparar por prioridad
              if (prioA !== prioB) {
                return prioA - prioB;
              }
              
              // Si tienen la misma prioridad, ordenar por hora
              return a.hora.localeCompare(b.hora);
            });
            
            console.log('✅ Turnos ordenados por prioridad:', turnosHoy.length);
            console.log('   Próximo:', turnosHoy[0]?.estado, turnosHoy[0]?.hora);
            mostrarSiguientePaciente();
            mostrarTablaTurnos();
          } else {
            console.error('❌ Error en respuesta:', data);
          }
        })
        .catch(error => {
          console.error('❌ Error en fetch:', error);
        });
    }

    // ============================================================
    // MOSTRAR SIGUIENTE PACIENTE (PRIORIZA EN_CONSULTA)
    // ============================================================
    function mostrarSiguientePaciente() {
      if (turnosHoy.length === 0) {
        document.getElementById('siguiente-nombre').textContent = 'Sin turnos próximos';
        document.getElementById('siguiente-hora').textContent = '--:--';
        document.getElementById('siguiente-fecha').textContent = '--/--/----';
        document.getElementById('siguiente-botones').innerHTML = '<p class="text-muted">No hay pacientes pendientes</p>';
        return;
      }

      // Solo mostrar EN_CONSULTA activo — el doctor elige el siguiente con doble clic
      let siguiente = turnosHoy.find(t => t.estado === 'EN_CONSULTA');

      if (!siguiente) {
        const hayPendientes = turnosHoy.some(t => t.estado === 'PENDIENTE');
        document.getElementById('siguiente-nombre').textContent = hayPendientes ? 'Seleccioná un paciente' : 'Sin turnos pendientes';
        document.getElementById('siguiente-hora').textContent = '--:--';
        document.getElementById('siguiente-fecha').textContent = '--/--/----';
        document.getElementById('siguiente-dni').textContent = '-';
        document.getElementById('siguiente-telefono').textContent = '-';
        document.getElementById('siguiente-edad').textContent = '-';
        document.getElementById('siguiente-obra').textContent = '-';
        document.getElementById('siguiente-motivo').textContent = '-';
        const estadoBadge = document.getElementById('siguiente-estado');
        estadoBadge.textContent = '';
        estadoBadge.className = 'estado-badge';
        document.getElementById('siguiente-botones').innerHTML = hayPendientes
          ? '<p style="opacity:0.7;font-size:0.85rem;margin:0;"><i class="bi bi-hand-index"></i> Doble clic en un turno de la lista para iniciar la consulta</p>'
          : '<p style="opacity:0.7;font-size:0.9rem;margin:0;">Todos los turnos han sido completados</p>';
        return;
      }

      const paciente = siguiente.paciente;

      // Formatear fecha
      const fechaObj = new Date(siguiente.hora.split(':')[0] === '0' ? new Date() : new Date());
      const [year, month, day] = [fechaObj.getFullYear(), String(fechaObj.getMonth() + 1).padStart(2, '0'), String(fechaObj.getDate()).padStart(2, '0')];
      const fechaFormato = `${day}/${month}/${year}`;

      document.getElementById('siguiente-nombre').textContent = `${paciente.nombre} ${paciente.apellido}`;
      document.getElementById('siguiente-hora').textContent = siguiente.hora;
      document.getElementById('siguiente-fecha').textContent = fechaFormato;
      document.getElementById('siguiente-dni').textContent = paciente.dni;
      document.getElementById('siguiente-telefono').textContent = paciente.telefono || '-';
      document.getElementById('siguiente-edad').textContent = formatEdad(paciente.edad);
      document.getElementById('siguiente-obra').textContent = paciente.obraSocial || '-';
      document.getElementById('siguiente-motivo').textContent = siguiente.consulta?.motivo || siguiente.observaciones || '-';

      const estadoBadge = document.getElementById('siguiente-estado');
      estadoBadge.textContent = formatEstado(siguiente.estado);
      estadoBadge.className = `estado-badge estado-${siguiente.estado}`;

      // 🔥 BOTONES SEGÚN ESTADO
      const botonesDiv = document.getElementById('siguiente-botones');
      botonesDiv.innerHTML = '';

      if (siguiente.estado === 'PENDIENTE') {
        botonesDiv.innerHTML = `
          <button class="btn btn-sm btn-primary" style="padding: 6px 16px; font-weight: 600;" onclick="iniciarConsultaTurno(${siguiente.id})">
            <i class="bi bi-play-circle"></i> Iniciar Consulta
          </button>
          <button class="btn btn-sm btn-outline-danger" style="padding: 6px 14px; font-weight: 600;" onclick="cancelarConsultaTurno(${siguiente.id})">
            <i class="bi bi-x-circle"></i> Cancelar
