      })
    });

    if (!response.ok) throw new Error('Error generating recipe');
    const result = await response.json();
    mostrarPreviewImprimible(result.data, 'receta');
  } catch (error) {
    console.error('Error:', error);
    alert('Error al generar receta');
  }
}

async function generarOrdenMedica() {
  try {
    const response = await fetch('/api/doctor/orden-medica/generar', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      },
      body: JSON.stringify({
        historia_clinica_id: 1,
        paciente_nombre: `${pacienteSeleccionado.nombre} ${pacienteSeleccionado.apellido}`,
        diagnositco_principal: document.getElementById('diagnostico_principal')?.value || '',
        estudios_solicitados: estudios
      })
    });

    if (!response.ok) throw new Error('Error generating medical order');
    const result = await response.json();
    mostrarPreviewImprimible(result.data, 'orden');
  } catch (error) {
    console.error('Error:', error);
    alert('Error al generar orden médica');
  }
}

async function generarCertificado() {
  try {
    const diasReposo = prompt('¿Días de reposo (0 si no aplica)?', '0') || '0';
    const response = await fetch('/api/doctor/certificado/generar', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      },
      body: JSON.stringify({
        historia_clinica_id: 1,
        paciente_nombre: `${pacienteSeleccionado.nombre} ${pacienteSeleccionado.apellido}`,
        diagnostico: document.getElementById('diagnostico_principal')?.value || '',
        dias_reposo: parseInt(diasReposo),
        observaciones: ''
      })
    });

    if (!response.ok) throw new Error('Error generating certificate');
    const result = await response.json();
    mostrarPreviewImprimible(result.data, 'certificado');
  } catch (error) {
    console.error('Error:', error);
    alert('Error al generar certificado');
  }
}

function mostrarPreviewImprimible(data, tipo) {
  let html = '';

  if (tipo === 'receta') {
    html = `
      <div class="text-center mb-4">
        <h3>RECETA MÉDICA</h3>
        <p class="text-muted">${data.fecha}</p>
      </div>
      <div class="mb-4">
        <p><strong>Paciente:</strong> ${data.paciente}</p>
        <p><strong>Médico:</strong> ${data.doctor}</p>
        <p><strong>Especialidad:</strong> ${data.especialidad}</p>
      </div>
      <div class="mb-4">
        <h5>Medicamentos Indicados:</h5>
        <ul>
          ${data.medicamentos.map(m => `<li>${m.medicamento} - ${m.dosis} - ${m.frecuencia}</li>`).join('')}
        </ul>
      </div>
      <div class="mb-4">
        <p><strong>Observaciones:</strong> ${data.observaciones}</p>
      </div>
      <div class="text-center mt-4">
        <p>_________________________</p>
        <p>${data.firma}</p>
      </div>
    `;
  } else if (tipo === 'orden') {
    html = `
      <div class="text-center mb-4">
        <h3>ORDEN MÉDICA</h3>
        <p class="text-muted">N° ${data.numero} - ${data.fecha}</p>
      </div>
      <div class="mb-4">
        <p><strong>Paciente:</strong> ${data.paciente}</p>
        <p><strong>Médico:</strong> ${data.doctor}</p>
        <p><strong>Diagnóstico:</strong> ${data.diagnostico}</p>
      </div>
      <div class="mb-4">
        <h5>Estudios Solicitados:</h5>
        <ul>
          ${data.estudios.map(e => `<li>${e.tipo} - ${e.descripcion || ''}</li>`).join('')}
        </ul>
      </div>
      <div class="mb-4">
        <p><strong>Prioridad:</strong> ${data.prioridad}</p>
        <p><strong>Observaciones:</strong> ${data.observaciones}</p>
      </div>
      <div class="text-center mt-4">
        <p>_________________________</p>
        <p>${data.firma}</p>
      </div>
    `;
  } else if (tipo === 'certificado') {
    html = `
      <div class="text-center mb-4">
        <h3>CERTIFICADO MÉDICO</h3>
        <p class="text-muted">N° ${data.numero} - ${data.fecha}</p>
      </div>
      <div class="my-5 text-center">
        <p class="lead">${data.mensaje}</p>
      </div>
      <div class="mb-4">
        <p><strong>Paciente:</strong> ${data.paciente}</p>
        <p><strong>Diagnóstico:</strong> ${data.diagnostico}</p>
        <p><strong>Médico:</strong> ${data.doctor}</p>
        <p><strong>Especialidad:</strong> ${data.especialidad}</p>
      </div>
      <div class="text-center mt-5">
        <p>_________________________</p>
        <p>${data.firma}</p>
      </div>
    `;
  }

  document.getElementById('contenidoImprimible').innerHTML = html;
  document.getElementById('previewImprimible').style.display = 'block';
  document.getElementById('previewImprimible').scrollIntoView({ behavior: 'smooth' });
}

