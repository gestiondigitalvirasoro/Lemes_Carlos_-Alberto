// ============================================
// GRÁFICOS DE EVOLUCIÓN
// ============================================
async function cargarGraficos() {
  if (!pacienteSeleccionado?.id) {
    alert('Selecciona un paciente primero');
    return;
  }

  try {
    const response = await fetch(`/api/doctor/graficos/evolucion/${pacienteSeleccionado.id}`, {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      }
    });

    if (!response.ok) throw new Error('Error loading charts');
    const result = await response.json();
    const { labels, datasets } = result.data;

    // Destruir gráficos existentes
    Object.values(chartInstances || {}).forEach(chart => chart?.destroy?.());
    chartInstances = {};

    // GRÁFICO PESO
    const ctxPeso = document.getElementById('graficoPeso').getContext('2d');
    chartInstances.peso = new Chart(ctxPeso, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Peso (kg)',
          data: datasets.peso,
          borderColor: '#FF6B6B',
          backgroundColor: 'rgba(255,107,107,0.1)',
          borderWidth: 2,
          fill: true,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        plugins: { title: { display: true, text: 'Evolución de Peso' } }
      }
    });

    // GRÁFICO GLUCEMIA
    const ctxGlucemia = document.getElementById('graficoGlucemia').getContext('2d');
    chartInstances.glucemia = new Chart(ctxGlucemia, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Glucemia (mg/dL)',
          data: datasets.glucemia,
          borderColor: '#FFA500',
          backgroundColor: 'rgba(255,165,0,0.1)',
          borderWidth: 2,
          fill: true,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        plugins: { title: { display: true, text: 'Evolución de Glucemia' } }
      }
    });

    // GRÁFICO PRESIÓN ARTERIAL
    const ctxTA = document.getElementById('graficoTA').getContext('2d');
    chartInstances.ta = new Chart(ctxTA, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'Sistólica (mmHg)',
            data: datasets.presionSistolica,
            borderColor: '#E74C3C',
            backgroundColor: 'rgba(231,76,60,0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.4
          },
          {
            label: 'Diastólica (mmHg)',
            data: datasets.presionDiastolica,
            borderColor: '#3498DB',
            backgroundColor: 'rgba(52,152,219,0.1)',
            borderWidth: 2,
            fill: true,
            tension: 0.4
          }
        ]
      },
      options: {
        responsive: true,
        plugins: { title: { display: true, text: 'Evolución de Presión Arterial' } }
      }
    });

    // GRÁFICO IMC
    const ctxIMC = document.getElementById('graficoIMC').getContext('2d');
    chartInstances.imc = new Chart(ctxIMC, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'IMC',
          data: datasets.imc,
          backgroundColor: (ctx) => {
            const value = ctx.parsed.y;
            if (value < 18.5) return '#3498DB'; // Bajo peso
            if (value < 25) return '#2ECC71'; // Normal
            if (value < 30) return '#F39C12'; // Sobrepeso
            return '#E74C3C'; // Obeso
          },
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: { title: { display: true, text: 'Evolución de IMC' } }
      }
    });

    alert('Gráficos cargados exitosamente');
  } catch (error) {
    console.error('Error:', error);
    alert('Error al cargar gráficos');
  }
}

