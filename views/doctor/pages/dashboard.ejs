async function cambiarEstadoTurno(turnoId, nuevoEstado) {
  if (!nuevoEstado) return;
  
  // Confirmar si es cancelación
  if (nuevoEstado === 'CANCELADA') {
    if (!confirm('¿Está seguro de que desea cancelar este turno?')) return;
  }
  
  try {
    const response = await fetch(`/api/turno/${turnoId}/estado`, {
      method: 'PATCH',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      },
      body: JSON.stringify({ estado: nuevoEstado })
    });

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.message || 'Error al cambiar el estado');
    }
    
    // Recargar dashboard
    cargarDashboard();
  } catch (error) {
    console.error('Error:', error);
    alert('Error al cambiar el estado: ' + error.message);
  }
}

async function iniciarConsultaTurno(turnoId, pacienteId, nombrePaciente) {
  try {
    console.log('Iniciando consulta para turno:', turnoId, 'paciente:', pacienteId);
    
    // Crear la consulta médica (esto también debería cambiar el estado del turno a EN_CONSULTA)
    const response = await fetch('/api/consultas-medicas', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      },
      body: JSON.stringify({
        turno_id: turnoId,
        paciente_id: pacienteId,
        motivo_consulta: ''  // Se completará en la historia clínica
      })
    });

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.message || 'Error al iniciar consulta');
    }

    const result = await response.json();
    
    // Abrir la historia clínica del paciente
    abrirHistoria(pacienteId, nombrePaciente);
    
  } catch (error) {
    console.error('Error:', error);
    alert('Error al iniciar consulta: ' + error.message);
  }
}

async function abrirHistoria(pacienteId, nombre) {
  try {
    const response = await fetch(`/api/doctor/paciente/${pacienteId}/historia`, {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      }
    });
    
    if (!response.ok) throw new Error('Error al cargar historia');
    const result = await response.json();
    const paciente = result.data.paciente;
    const historiaActual = result.data.historia_actual;

    pacienteSeleccionado = paciente;

    // Llenar datos generales
    document.getElementById('pacienteNombreHistoria').textContent = nombre;
    document.getElementById('pacienteNombre').textContent = `${paciente.nombre || '-'} ${paciente.apellido || '-'}`;
    document.getElementById('pacienteDni').textContent = paciente.dni || '-';
    document.getElementById('pacienteEdad').textContent = (paciente.edad || '-') + ' años';
    document.getElementById('pacienteSexo').textContent = paciente.genero || '-';
    document.getElementById('pacienteContacto').textContent = paciente.telefono || '-';
    document.getElementById('pacienteObra').textContent = paciente.patologias_cronicas || '-';

    // Si existen historias clínicas, cargarlas en los tabs
    if (historiaActual) {
      // SIGNOS VITALES
      if (historiaActual.signos_vitales && historiaActual.signos_vitales.length > 0) {
        const signo = historiaActual.signos_vitales[0]; // Más reciente
        document.getElementById('peso').value = signo.peso_kg || '';
        document.getElementById('talla').value = signo.talla_cm || '';
        document.getElementById('imc').value = signo.imc || '';
        document.getElementById('presion_sistolica').value = signo.presion_sistolica || '';
        document.getElementById('presion_diastolica').value = signo.presion_diastolica || '';
        document.getElementById('frecuencia_cardiaca').value = signo.frecuencia_cardiaca || '';
        document.getElementById('temperatura').value = signo.temperatura_c || '';
        document.getElementById('glucemia').value = signo.glucemia_mg_dl || '';
        document.getElementById('circunferencia_abdominal').value = signo.circunferencia_abd || '';
      }

      // ANAMNESIS
      document.getElementById('motivo_consulta').value = historiaActual.motivo_consulta || '';
      document.getElementById('sintomas').value = historiaActual.anamnesis || '';
      document.getElementById('antecedentes_personales').value = historiaActual.antecedentes_patologicos_personales || '';
      document.getElementById('antecedentes_familiares').value = historiaActual.antecedentes_patologicos_familiares || '';
      document.getElementById('evolucion').value = historiaActual.habitos || '';

      // DIAGNÓSTICOS
      document.getElementById('examen_fisico').value = historiaActual.examen_fisico || '';
      document.getElementById('diagnostico_principal').value = historiaActual.diagnostico_principal || '';
      if (historiaActual.diagnosticos_secundarios && Array.isArray(historiaActual.diagnosticos_secundarios)) {
        document.getElementById('diagnosticos_secundarios').value = historiaActual.diagnosticos_secundarios.join(', ');
      }
      document.getElementById('impresion_clinica').value = historiaActual.impresion_clinica || '';

      // MEDICAMENTOS - Cargar desde historia
      if (historiaActual.tratamiento && Array.isArray(historiaActual.tratamiento)) {
        medicamentos = historiaActual.tratamiento;
        actualizarListaMedicamentos();
      }

      // ESTUDIOS - Cargar desde historia
      if (historiaActual.estudios_adjuntos && Array.isArray(historiaActual.estudios_adjuntos)) {
        estudios = historiaActual.estudios_adjuntos.map(e => ({
          tipo: e.tipo_estudio,
          descripcion: e.descripcion || '',
          resultado: e.resultado || '',
          observaciones: e.observaciones || ''
        }));
        actualizarListasEstudios();
      }
    }

    // Mostrar historia clínica
    document.getElementById('historiaClinicaDiv').style.display = 'block';
    
    // Scroll hasta la historia
    document.getElementById('historiaClinicaDiv').scrollIntoView({ behavior: 'smooth' });
  } catch (error) {
    console.error('Error:', error);
    alert('Error al cargar la historia clínica');
  }
}

function cerrarHistoria() {
  document.getElementById('historiaClinicaDiv').style.display = 'none';
  pacienteSeleccionado = null;
  limpiarFormularios();
}

function limpiarFormularios() {
  document.getElementById('formSignosVitales').reset();
  document.getElementById('formAnamnesis').reset();
  document.getElementById('formDiagnosticos').reset();
  document.getElementById('formMedicamentos').reset();
  document.getElementById('formEstudios').reset();
  medicamentos = [];
  estudios = [];
}

function calcularIMC() {
  const peso = parseFloat(document.getElementById('peso').value);
  const talla = parseFloat(document.getElementById('talla').value);
  if (peso && talla) {
    const imc = (peso / (talla * talla)).toFixed(2);
    document.getElementById('imc').value = imc;
  }
}

document.getElementById('peso')?.addEventListener('change', calcularIMC);
document.getElementById('talla')?.addEventListener('change', calcularIMC);

async function iniciarConsulta() {
  if (!turnoSeleccionado) {
    alert('No hay turno seleccionado');
    return;
  }
  
  try {
    const response = await fetch('/api/doctor/consulta/iniciar', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      },
      body: JSON.stringify({ turnoId: turnoSeleccionado.id })
    });
    
    if (!response.ok) throw new Error('Error al iniciar consulta');
    alert('Consulta iniciada');
    document.getElementById('btnIniciar').disabled = true;
  } catch (error) {
    console.error('Error:', error);
    alert('Error al iniciar consulta');
  }
}

async function finalizarConsulta() {
  if (!pacienteSeleccionado || !turnoSeleccionado) {
    alert('Selecciona un paciente primero');
    return;
  }

  try {
    // 1. Crear historia clínica
    const historiResponse = await fetch('/api/doctor/consulta/finalizar', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
      },
      body: JSON.stringify({
        turnoId: turnoSeleccionado.id,
        pacienteId: pacienteSeleccionado.id,
        motivo: document.getElementById('motivo_consulta')?.value || '',
        anamnesis: document.getElementById('sintomas')?.value || '',
        examen_fisico: document.getElementById('examen_fisico')?.value || '',
        diagnostico: document.getElementById('diagnostico_principal')?.value || '',
        medicamentos: JSON.stringify(medicamentos),
        observaciones: document.getElementById('evolucion')?.value || '',
        signos_vitales: {
          peso: document.getElementById('peso')?.value,
          talla: document.getElementById('talla')?.value,
          imc: document.getElementById('imc')?.value,
          presion: `${document.getElementById('presion_sistolica')?.value}/${document.getElementById('presion_diastolica')?.value}`,
          frecuencia_cardiaca: document.getElementById('frecuencia_cardiaca')?.value,
          temperatura: document.getElementById('temperatura')?.value,
          glucemia: document.getElementById('glucemia')?.value
        }
      })
    });
    
    if (!historiResponse.ok) throw new Error('Error al crear historia clínica');
    const historiaResult = await historiResponse.json();
    const historiaId = historiaResult.data.id;

    // 2. Guardar signos vitales en tabla separada
    if (document.getElementById('peso')?.value) {
      const signosResponse = await fetch('/api/doctor/signos-vitales', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${localStorage.getItem('auth_token')}`
        },
        body: JSON.stringify({
          historia_clinica_id: historiaId,
          peso: document.getElementById('peso')?.value,
          talla: document.getElementById('talla')?.value,
          presion_sistolica: document.getElementById('presion_sistolica')?.value,
          presion_diastolica: document.getElementById('presion_diastolica')?.value,
          frecuencia_cardiaca: document.getElementById('frecuencia_cardiaca')?.value,
          temperatura: document.getElementById('temperatura')?.value,
          glucemia: document.getElementById('glucemia')?.value,
          circunferencia_abdominal: document.getElementById('circunferencia_abdominal')?.value || null,
          observaciones: ''
        })
      });
      
      if (!signosResponse.ok) throw new Error('Error al guardar signos vitales');
    }

    alert('Consulta finalizada y historia clínica guardada correctamente');
    cerrarHistoria();
    cargarDashboard();
  } catch (error) {
    console.error('Error:', error);
    alert('Error al finalizar consulta: ' + error.message);
  }
}

