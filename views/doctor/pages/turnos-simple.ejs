    // ============================================================================
    // MODAL DE CONFIRMACIÓN DE TURNO CON DATOS DE SALUD
    // ============================================================================
    async function abrirModalConfirmarTurno(turnoId) {
      mostrarLoading('Cargando datos del paciente...');
      console.log('🏥 Abriendo modal de confirmación para turno:', turnoId);
      
      try {
        // Obtener datos del paciente
        const response = await fetch(`/api/turnos/${turnoId}/paciente-datos`, {
          credentials: 'include'
        });

        if (!response.ok) {
          throw new Error(`Error ${response.status} al obtener datos del paciente`);
        }

        const pacienteData = await response.json();
        console.log('📥 Datos del paciente recibidos:', pacienteData);

        if (!pacienteData.success || !pacienteData.paciente) {
          throw new Error(pacienteData.message || 'No se pudieron cargar los datos del paciente');
        }

        ocultarLoading();

        const pacienteInfo = pacienteData.paciente;
        const persona = pacienteInfo.persona;
        const datosSalud = pacienteInfo.datos_salud;

        // Crear HTML del modal de confirmación
        const modalHTML = `
          <div id="modalConfirmarBackdrop" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); display: flex; justify-content: center; align-items: center; z-index: 9999;" onclick="cerrarModalConfirmar()">
            <div id="modalConfirmarContent" style="background: white; border-radius: 12px; padding: 30px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; box-shadow: 0 10px 40px rgba(0,0,0,0.3);" onclick="event.stopPropagation()">
              <button onclick="cerrarModalConfirmar()" style="position: absolute; top: 15px; right: 15px; background: none; border: none; font-size: 28px; cursor: pointer; color: #999;">✕</button>
              
              <h2 style="color: #1a3a3a; margin-bottom: 10px; border-bottom: 3px solid #10b981; padding-bottom: 12px;">
                <i class="bi bi-check-circle" style="color: #10b981;"></i> Confirmar Turno
              </h2>
              <p style="color: #666; margin-bottom: 25px; font-size: 14px;">Completa los datos de salud del paciente para confirmar el turno</p>

              <!-- DATOS DEL PACIENTE -->
              <div style="background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
                <h4 style="color: #059669; margin-bottom: 10px; font-size: 14px;">👤 PACIENTE</h4>
                <div style="font-size: 14px; color: #333;">
                  <p style="margin: 5px 0;"><strong>${persona.nombre} ${persona.apellido}</strong></p>
                  <p style="margin: 5px 0; color: #666;">DNI: ${persona.dni}</p>
                </div>
              </div>

              <!-- FORMULARIO DE DATOS DE SALUD -->
              <form id="formConfirmarTurno" onsubmit="return false;">
                <div style="margin-bottom: 20px;">
                  <label style="display: block; font-weight: 600; color: #333; margin-bottom: 8px;">
                    <i class="bi bi-hospital"></i> Obra Social
                  </label>
                  <input type="text" id="confirmObraSocial" placeholder="Ej: OSDE, PAMI" 
                    value="${datosSalud.obra_social || ''}" 
                    style="width: 100%; padding: 10px 12px; border: 2px solid #e2e8f0; border-radius: 6px; font-size: 14px; transition: border 0.3s;">
                </div>

                <div style="margin-bottom: 20px;">
                  <label style="display: block; font-weight: 600; color: #333; margin-bottom: 8px;">
                    <i class="bi bi-card-text"></i> Número de Afiliado
                  </label>
                  <input type="text" id="confirmNumeroAfiliado" placeholder="123456789" 
                    value="${datosSalud.numero_afiliado || ''}" 
                    style="width: 100%; padding: 10px 12px; border: 2px solid #e2e8f0; border-radius: 6px; font-size: 14px; transition: border 0.3s;">
                </div>

                <div style="margin-bottom: 25px;">
                  <label style="display: block; font-weight: 600; color: #333; margin-bottom: 8px;">
                    <i class="bi bi-chat-dots"></i> Observaciones Generales
                  </label>
                  <textarea id="confirmObservaciones" rows="3" placeholder="Notas generales sobre el paciente..." 
                    style="width: 100%; padding: 10px 12px; border: 2px solid #e2e8f0; border-radius: 6px; font-size: 14px; resize: vertical; transition: border 0.3s;">${datosSalud.observaciones_generales || ''}</textarea>
