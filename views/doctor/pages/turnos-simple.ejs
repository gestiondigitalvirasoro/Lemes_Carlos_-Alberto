                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                  <button type="button" onclick="cerrarModalConfirmar()" 
                    style="padding: 12px 24px; background: #e2e8f0; color: #1a3a3a; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; transition: background 0.3s;">
                    ❌ Cancelar
                  </button>
