                    d.innerHTML = '<strong>' + nombre + '</strong> ' + dosis + '<br><small style="color:#555;">' + freq + '</small>';
                    tratContainer.appendChild(d);
                });
            }

            document.getElementById('modalReceta').style.display = 'flex';
        }

        function actualizarLineaPaciente() {
            const nombre = '<%- paciente.nombre %> <%- paciente.apellido %>';
            const dni    = 'DNI: <%- paciente.dni %>';
            const edad   = '<%- paciente.edad %> años';
            const os     = '<%- (paciente.obra_social && paciente.obra_social !== "N/A") ? paciente.obra_social : "" %>';
            const naf    = '<%- (paciente.numero_afiliado && paciente.numero_afiliado !== "N/A") ? paciente.numero_afiliado : "" %>';

            let partes = [nombre, dni, edad];
            if (document.getElementById('chk-os')?.checked && os)  partes.push('O.S: ' + os);
            if (document.getElementById('chk-naf')?.checked && naf) partes.push('N° Afil: ' + naf);

            const el = document.getElementById('rp-paciente');
            if (el) el.textContent = partes.join('  ·  ');
        }

