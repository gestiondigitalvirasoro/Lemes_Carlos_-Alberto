              <div style="position:relative;z-index:1;">
                <div style="text-align:center;border-bottom:2px solid #222;padding-bottom:12px;margin-bottom:14px;">
                  <div style="font-size:18px;font-weight:bold;font-family:'Brush Script MT',cursive;margin-bottom:4px;">Dr. Carlos Alberto Lemes</div>
