                                    placeholder="Busca por código (I10) o nombre (Hipertensión)" 
                                    autocomplete="off" readonly>
                                <div class="cie10-dropdown" id="cie10Dropdown"
                                    style="position: absolute; width: 100%; max-width: 400px; max-height: 300px; 
                                    overflow-y: auto; background: white; border: 1px solid #ddd; 
                                    border-radius: 4px; display: none; z-index: 1000; 
