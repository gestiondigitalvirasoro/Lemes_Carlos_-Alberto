                                        <button onclick="eliminarTratamiento('<%= trat.id %>')" style="position:absolute;top:8px;right:8px;background:none;border:none;color:#aaa;cursor:pointer;font-size:16px;line-height:1;" title="Eliminar">×</button>
                                        <div style="font-size:15px;font-weight:600;color:#1a1a1a;margin-bottom:3px;padding-right:20px;"><%= trat.medicamento %></div>
                                        <div style="font-size:13px;font-weight:500;color:#1D9E75;margin-bottom:2px;"><%= trat.dosis %></div>
                                        <div style="font-size:12px;color:#666;margin-bottom:8px;"><%= trat.frecuencia %><% if(trat.duracion_dias) { %> · <%= trat.duracion_dias %> días<% } %></div>
                                        <% if(trat.indicaciones) { %><div style="font-size:11px;color:#888;margin-bottom:8px;font-style:italic;"><%= trat.indicaciones %></div><% } %>
                                        <span style="background:#E1F5EE;color:#085041;border-radius:20px;padding:2px 10px;font-size:11px;font-weight:500;">✓ Activo</span>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>

                        <div id="tratamientosVacio" style="text-align:center;padding:20px;color:#999;display:<%= (historia?.consultas?.[0]?.tratamientos?.length > 0) ? 'none' : 'block' %>;">
                            <p style="margin:0;">Sin medicamentos registrados en esta consulta</p>
                        </div>

                        <!-- Formulario agregar medicamento -->
                        <div id="formTratamiento" style="background:#f8f9fa;border:0.5px solid #e9ecef;border-radius:10px;padding:1rem;display:none;">
                            <div style="font-size:13px;font-weight:600;color:#333;margin-bottom:12px;">+ Agregar medicamento</div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
                                <div style="position:relative;">
                                    <label style="font-size:12px;color:#666;display:block;margin-bottom:3px;">Medicamento</label>
                                    <input type="text" id="med-search-input" placeholder="Buscar medicamento..." autocomplete="off"
                                        style="width:100%;padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;"
                                        oninput="filtrarMedicamentos(this.value)" onfocus="mostrarDropMed()" onblur="setTimeout(()=>ocultarDropMed(),200)">
                                    <div id="med-dropdown" style="display:none;position:absolute;background:white;border:1px solid #ddd;border-top:none;max-height:220px;overflow-y:auto;width:100%;z-index:2000;box-shadow:0 4px 8px rgba(0,0,0,0.1);border-radius:0 0 6px 6px;">
                                    </div>
                                    <input type="hidden" id="trat-med-select" value="">
                                </div>
                            </div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
                                <div>
                                    <label style="font-size:12px;color:#666;display:block;margin-bottom:3px;">Dosis</label>
                                    <input type="text" id="trat-dosis" placeholder="ej: 850 mg" style="width:100%;padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
                                </div>
                                <div>
                                    <label style="font-size:12px;color:#666;display:block;margin-bottom:3px;">Frecuencia</label>
                                    <input type="text" id="trat-frecuencia" placeholder="ej: Cada 12 horas" style="width:100%;padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
                                </div>
                            </div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
                                <div>
                                    <label style="font-size:12px;color:#666;display:block;margin-bottom:3px;">Fecha inicio</label>
                                    <input type="date" id="trat-fecha-inicio" style="width:100%;padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
                                </div>
                                <div>
                                    <label style="font-size:12px;color:#666;display:block;margin-bottom:3px;">Duración (días)</label>
                                    <input type="number" id="trat-duracion" placeholder="ej: 30" style="width:100%;padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;">
                                </div>
                            </div>
                            <div style="margin-bottom:12px;">
                                <label style="font-size:12px;color:#666;display:block;margin-bottom:3px;">Indicaciones</label>
                                <textarea id="trat-indicaciones" placeholder="ej: Tomar con las comidas, evitar alcohol, no discontinuar..." rows="3" style="width:100%;padding:7px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;resize:vertical;font-family:inherit;"></textarea>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <button onclick="guardarTratamiento()" style="background:#1D9E75;color:white;border:none;border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;font-weight:500;">Guardar medicamento</button>
                                <button onclick="document.getElementById('formTratamiento').style.display='none'" style="background:none;border:1px solid #ddd;border-radius:6px;padding:8px 16px;font-size:13px;cursor:pointer;color:#666;">Cancelar</button>
                            </div>
                        </div>

                        <!-- Botón abrir formulario (solo en modo edición) -->
                        <button id="btnNuevoTratamiento" onclick="abrirFormTratamiento()" style="display:inline-block;margin-top:8px;background:none;border:1px solid #1D9E75;color:#1D9E75;border-radius:6px;padding:7px 16px;font-size:13px;cursor:pointer;">
                            <i class="bi bi-plus"></i> Agregar medicamento
                        </button>

                    </div>
                </section>

                <!-- IMPRESIÓN DIAGNÓSTICA -->
                <section class="section">
                    <div class="section-header">
                        <i class="bi bi-stethoscope"></i>
                        <h3>Impresión Diagnóstica</h3>
                    </div>
                    <div class="section-body">
                        <div class="form-group">
                            <label for="impresion">Valoración Médica y Conclusiones</label>
                            <textarea id="impresion" rows="8"><%= historia?.consultas?.[0]?.resumen || '' %></textarea>
                        </div>
                    </div>
