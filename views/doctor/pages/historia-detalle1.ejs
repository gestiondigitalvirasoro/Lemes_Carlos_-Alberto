            // Tratamientos
            const tratCards = document.querySelectorAll('.med-card-item');
            const tratContainer = document.getElementById('rp-trat-contenido');
            tratContainer.innerHTML = '';
            if (tratCards.length === 0) {
                tratContainer.innerHTML = '<span style="font-size:11px;color:#999;font-style:italic;">Sin tratamiento registrado</span>';
            } else {
                tratCards.forEach(card => {
