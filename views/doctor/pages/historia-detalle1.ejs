            </div>

            <!-- FOOTER -->
            <footer>
                <p>
                    <strong>Médico tratante:</strong> Dr. Carlos · Med. General · 
                    <strong>Última actualización:</strong> <%= new Date().toLocaleDateString('es-AR') %>
                </p>
            </footer>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Datos de la historia
        const historiaData = <%- JSON.stringify(historia || {}) %>;
        const historiaId = '<%= historia?.id || "" %>';
        const pacienteId = '<%= paciente?.id || "" %>';
        let modoEdicion = false;
        let consultaActualIdx = 0;
        
        console.log('📖 Historia cargada:', {
          id: historiaId,
          consultasCount: historiaData.consultas?.length || 0,
          consultas: historiaData.consultas?.map(c => ({ id: c.id, estado: c.estado_id, fecha: c.fecha }))
        });

        // Si hay consultas, usar la primera; si no, crear un mock para nueva consulta
        let currentConsultaId = null;
        if (historiaData.consultas && historiaData.consultas.length > 0) {
          currentConsultaId = historiaData.consultas[0].id;
          console.log('✅ Usando consulta existente:', currentConsultaId);
        } else {
          console.log('📝 Sin consultas - será una nueva');
        }

        // Confirmar cambio de consulta si hay cambios pendientes
        function confirmarCambioConsulta(idx) {
            if (modoEdicion) {
                const confirmar = confirm('Tenés cambios sin guardar. ¿Querés guardar antes de cambiar de consulta?');
                if (confirmar) {
                    guardarCambios().then(() => {
                        modoEdicion = false;
                        cambiarConsulta(idx);
                        // Actualizar select por si acaso
                        const sel = document.getElementById('consultaSelector');
                        if (sel) sel.value = idx;
                    }).catch(() => {
                        alert('Error al guardar. Revisá los datos e intentá de nuevo.');
                    });
                    return;
                }
                // Descartar cambios y cambiar
                modoEdicion = false;
                document.getElementById('btnEditar').style.display = 'flex';
                document.getElementById('btnGuardar').style.display = 'none';
                document.getElementById('btnCancelar').style.display = 'none';
            }
            cambiarConsulta(idx);
        }

                function cambiarConsulta(idx) {
            consultaActualIdx = parseInt(idx);
            const consulta = historiaData.consultas?.[consultaActualIdx];
            
            if (!consulta) {
              console.log('⚠️ No hay consulta en índice:', consultaActualIdx);
              // Limpiar formulario si no hay consultas
              const fecha = document.getElementById('consultaFecha');
              if (fecha) fecha.textContent = 'Nueva consulta';
              
              const motivo = document.getElementById('consultaMotivo');
              if (motivo) motivo.textContent = '-';
              
              const medico = document.getElementById('consultaMedico');
              if (medico) medico.textContent = '-';
              
              // Limpiar signos vitales
              ['presionSistolica', 'presionDiastolica', 'frecuenciaCardiaca', 'temperatura', 'peso', 'talla'].forEach(id => {
                const elem = document.getElementById(id);
                if (elem) elem.value = '';
              });
              
              // Limpiar anamnesis
              const motConsulta = document.getElementById('motivoConsulta');
              if (motConsulta) motConsulta.value = '';
              
              const anamnesis = document.getElementById('anamnesis');
              if (anamnesis) anamnesis.value = '';
              
              return;
            }
            
            // Actualizar información mostrada
            const fechaElem = document.getElementById('consultaFecha');
            if (fechaElem) fechaElem.textContent = consulta.fecha || '-';
            
            const motivoElem = document.getElementById('consultaMotivo');
            if (motivoElem) motivoElem.textContent = consulta.motivo_consulta || 'Sin especificar';
            
            const medicoElem = document.getElementById('consultaMedico');
            if (medicoElem) medicoElem.textContent = consulta.medico || 'Sin médico asignado';
            
            // Actualizar Signos Vitales (signos_vitales es un ARRAY)
            const signosVitales = consulta.signos_vitales?.[0];
            const presionSist = document.getElementById('presionSistolica');
            if (presionSist) presionSist.value = signosVitales?.presion_sistolica || '';
            
            const presionDias = document.getElementById('presionDiastolica');
            if (presionDias) presionDias.value = signosVitales?.presion_diastolica || '';
            
            const frecCard = document.getElementById('frecuenciaCardiaca');
            if (frecCard) frecCard.value = signosVitales?.frecuencia_cardiaca || '';
            
            const temp = document.getElementById('temperatura');
            if (temp) temp.value = signosVitales?.temperatura_c || '';
            
            const peso = document.getElementById('peso');
            if (peso) peso.value = signosVitales?.peso_kg || '';
            
            const talla = document.getElementById('talla');
            if (talla) talla.value = signosVitales?.talla_cm || '';
            
            // Actualizar Anamnesis (Enfermedad Actual)
            const motConsulta = document.getElementById('motivoConsulta');
            if (motConsulta) motConsulta.value = consulta.motivo_consulta || '';
            
            const anamnesisElem = document.getElementById('anamnesis');
            if (anamnesisElem) anamnesisElem.value = consulta.anamnesis || '';
            
            // Actualizar Tratamientos
            const tratGrid = document.getElementById('tratamientosGrid');
            const tratVacio = document.getElementById('tratamientosVacio');
            if (tratGrid) {
                tratGrid.innerHTML = '';
                const tratamientos = consulta.tratamientos || [];
                if (tratVacio) tratVacio.style.display = tratamientos.length === 0 ? 'block' : 'none';
                tratamientos.forEach(trat => {
                    const card = document.createElement('div');
                    card.className = 'med-card-item';
                    card.dataset.tratId = trat.id;
                    card.style.cssText = 'background:#fff;border:0.5px solid #e9ecef;border-radius:10px;padding:1rem 1rem 1rem 1.25rem;position:relative;border-left:4px solid #1D9E75;';
                    card.innerHTML = `
                        <button onclick="eliminarTratamiento('${trat.id}')" style="position:absolute;top:8px;right:8px;background:none;border:none;color:#aaa;cursor:pointer;font-size:16px;line-height:1;">×</button>
                        <div style="font-size:15px;font-weight:600;color:#1a1a1a;margin-bottom:3px;padding-right:20px;">${trat.medicamento}</div>
                        <div style="font-size:13px;font-weight:500;color:#1D9E75;margin-bottom:2px;">${trat.dosis}</div>
                        <div style="font-size:12px;color:#666;margin-bottom:8px;">${trat.frecuencia}${trat.duracion_dias ? ' · ' + trat.duracion_dias + ' días' : ''}</div>
                        ${trat.indicaciones ? `<div style="font-size:11px;color:#888;margin-bottom:8px;font-style:italic;">${trat.indicaciones}</div>` : ''}
                        <span style="background:#E1F5EE;color:#085041;border-radius:20px;padding:2px 10px;font-size:11px;font-weight:500;">✓ Activo</span>
                    `;
                    tratGrid.appendChild(card);
                });
            }

            // Actualizar Diagnósticos
            diagnosticosSeleccionados = consulta.diagnosticos || [];
            const diagContainer = document.getElementById('diagnosticosContainer');
            if (diagContainer) {
              diagContainer.innerHTML = '';
              diagnosticosSeleccionados.forEach(d => {
                const div = document.createElement('div');
                div.className = 'diagnostic-card';
                div.dataset.codigo = d.codigo;
                div.innerHTML = `
                    <div>
                        <strong>${d.codigo}</strong>
                        <p>${d.descripcion}</p>
                    </div>
                    <button class="btn-remove" onclick="removeDiagnostico('${d.codigo}')" style="display: inline-block;">
                        <i class="bi bi-trash"></i>
                    </button>
                `;
                diagContainer.appendChild(div);
              });
            }
            
            const diagCount = document.getElementById('diagnosticosCount');
            if (diagCount) diagCount.textContent = diagnosticosSeleccionados.length;
            
            // Actualizar Estudios
            const estudiosBody = document.getElementById('estudiosTableBody');
            if (estudiosBody) {
              estudiosBody.innerHTML = '';
              if (consulta.estudios?.length > 0) {
                consulta.estudios.forEach((est, idx) => {
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-estudio-idx', idx);
                    tr.setAttribute('data-tipo', est.tipo_estudio || '');
                    tr.setAttribute('data-resultado', est.resultado || '');
                    tr.setAttribute('data-observaciones', est.observaciones || '');
                    tr.setAttribute('data-fecha', est.fecha_estudio || '');
                    tr.style.borderBottom = '1px solid #f0f0f0';

                    const fechaMostrar = est.fecha_estudio
                        ? (() => {
                            const d = new Date(est.fecha_estudio + 'T00:00:00Z');
                            return !isNaN(d.getTime())
                              ? d.toLocaleDateString('es-AR', {day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'UTC'})
                              : '-';
                          })()
                        : '-';

                    tr.innerHTML = `
                        <td style="padding: 12px; color: #333; font-weight: 600;">${est.tipo_estudio || '-'}</td>
                        <td style="padding: 12px; color: #e74c3c; font-weight: 600; font-size: 14px;">${est.resultado || '-'}</td>
                        <td style="padding: 12px; color: #666;">${est.observaciones || '-'}</td>
                        <td style="padding: 12px; color: #999; font-size: 13px;">${fechaMostrar}</td>
                        <td style="padding: 12px; display: none;" class="estudio-accion-td"></td>
                    `;
                    estudiosBody.appendChild(tr);
                });
                const emptyDiv = document.getElementById('estudiosEmpty');
                if (emptyDiv) emptyDiv.style.display = 'none';
              } else {
                const emptyDiv = document.getElementById('estudiosEmpty');
                if (emptyDiv) emptyDiv.style.display = 'block';
              }
            }
            
            const estCount = document.getElementById('estudiosCount');
            if (estCount) estCount.textContent = consulta.estudios?.length || 0;
            
            // Antecedentes y Adjuntos son PERMANENTES de la historia - no se actualizan al cambiar consulta

            // Actualizar Impresión Diagnóstica (Valoración Médica)
            const impresionElem = document.getElementById('impresion');
            if (impresionElem && consulta?.resumen) {
              impresionElem.value = consulta.resumen || '';
              console.log('✅ Impresión Diagnóstica cargada:', consulta.resumen);
            } else if (impresionElem) {
              impresionElem.value = '';
            }
            
            // Actualizar Archivos Adjuntos (viene como array directo del backend)
            const adjContainer = document.getElementById('adjuntosContainer');
            console.log('🔍 DEBUG documentos:', {
              hasElement: !!adjContainer,
              documentosData: historiaData.documentos,
              documentosLength: historiaData.documentos?.length
            });
            if (adjContainer && historiaData.documentos && historiaData.documentos.length > 0) {
              console.log('📄 Documentos encontrados:', historiaData.documentos);
              adjContainer.innerHTML = '';
              adjContainer.style.cssText = 'display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 20px; padding: 20px 10px;';
              
