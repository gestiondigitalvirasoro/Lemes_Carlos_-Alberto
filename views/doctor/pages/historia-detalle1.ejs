                  <line x1="20" y1="312" x2="68" y2="312" stroke="white" stroke-width="4"/>
                  <text x="10" y="358" font-family="'Brush Script MT',cursive" font-size="18" fill="#000">L y L  Consultorio privado</text>
                </svg>
