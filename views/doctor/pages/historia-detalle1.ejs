                        <i class="bi bi-heart-pulse"></i>
                        <h3>Signos Vitales</h3>
                    </div>
                    <div class="section-body">
                        <div class="vitals-grid">
                            <div class="vital-card">
                                <label>Presión Sistólica</label>
                                <input type="number" class="vital-input" id="presionSistolica" 
                                    value="<%= historia?.signos_vitales?.presion_sistolica || '' %>" 
                                    readonly>
                                <div class="vital-status status-normal">Normal: 90-140</div>
                            </div>
                            <div class="vital-card">
                                <label>Presión Diastólica</label>
                                <input type="number" class="vital-input" id="presionDiastolica" 
                                    value="<%= historia?.signos_vitales?.presion_diastolica || '' %>" 
                                    readonly>
                                <div class="vital-status status-normal">Normal: 60-90</div>
                            </div>
                            <div class="vital-card">
                                <label>FC (lpm)</label>
                                <input type="number" class="vital-input" id="frecuenciaCardiaca" 
                                    value="<%= historia?.signos_vitales?.frecuencia_cardiaca || '' %>" 
                                    readonly>
                                <div class="vital-status status-normal">Normal: 60-100</div>
                            </div>
                            <div class="vital-card">
                                <label>Temperatura (°C)</label>
                                <input type="number" step="0.1" class="vital-input" id="temperatura" 
                                    value="<%= historia?.signos_vitales?.temperatura_c || '' %>" 
                                    readonly>
                                <div class="vital-status status-normal">Normal: 36.1-37.2</div>
                            </div>
                            <div class="vital-card">
                                <label>Peso (kg)</label>
                                <input type="number" step="0.1" class="vital-input" id="peso" 
                                    value="<%= historia?.signos_vitales?.peso_kg || '' %>" 
                                    readonly>
                                <div class="vital-status status-normal">Rango: 30-200</div>
                            </div>
                            <div class="vital-card">
                                <label>Talla (cm)</label>
                                <input type="number" class="vital-input" id="talla" 
                                    value="<%= historia?.signos_vitales?.talla_cm || '' %>" 
                                    readonly>
                                <div class="vital-status status-normal">Rango: 100-250</div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ANAMNESIS -->
                <section class="section" id="sectionAnamnesis">
                    <div class="section-header">
                        <i class="bi bi-chat-dots"></i>
                        <h3>Anamnesis</h3>
                    </div>
                    <div class="section-body">
                        <div class="form-group">
                            <label for="motivoConsulta">Motivo de Consulta</label>
                            <textarea id="motivoConsulta" rows="4"><%= historia?.motivo_consulta || '' %></textarea>
                        </div>
                        <div class="form-group">
                            <label for="anamnesis">Enfermedad Actual</label>
                            <textarea id="anamnesis" rows="6"><%= historia?.anamnesis || '' %></textarea>
                        </div>
                    </div>
                </section>

                <!-- ANTECEDENTES -->
                <!-- ANTECEDENTES -->
                <section class="section" id="sectionAntecedentes">
                    <div class="section-header">
                        <i class="bi bi-book"></i>
                        <h3>Antecedentes Patológicos</h3>
                    </div>
                    <div class="section-body">
                        <div class="form-group">
                            <label for="antecedentes">Antecedentes Personales y Familiares</label>
                            <textarea id="antecedentes" rows="6"><%= historia?.antecedentes || '' %></textarea>
                        </div>
                    </div>
                </section>

                <!-- DIAGNÓSTICOS -->
                <section class="section" id="diagnosticos">
                    <div class="section-header">
                        <i class="bi bi-search"></i>
                        <h3>Diagnósticos (<span id="diagnosticosCount">0</span>)</h3>
                    </div>
                    <div class="section-body">
                        <!-- Formulario para agregar diagnósticos -->
