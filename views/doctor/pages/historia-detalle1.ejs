                <!-- ESTUDIOS COMPLEMENTARIOS -->
                <section class="section" id="estudios">
                    <div class="section-header">
                        <i class="bi bi-flask"></i>
                        <h3>Estudios Complementarios <span style="background: #e7f3ff; color: #0066cc; border-radius: 50%; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; margin-left: 8px;" id="estudiosCount"><%= (historia?.consultas?.[0]?.estudios?.length || 0) %></span></h3>
                    </div>
                    <div class="section-body">
                        <div style="overflow-x: auto;">
                            <table class="table table-hover" style="margin-bottom: 15px;">
                                <thead style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                                    <tr>
                                        <th style="color: #666; font-weight: 700; padding: 12px;">TIPO ESTUDIO</th>
                                        <th style="color: #666; font-weight: 700; padding: 12px;">RESULTADO</th>
                                        <th style="color: #666; font-weight: 700; padding: 12px;">OBSERVACIONES</th>
                                        <th style="color: #666; font-weight: 700; padding: 12px;">FECHA</th>
                                        <th id="estudiosAccionesHeader" style="color: #666; font-weight: 700; padding: 12px; width: 80px; display: none;">ACCIÓN</th>
                                    </tr>
                                </thead>
                                <tbody id="estudiosTableBody">
                                    <% if (historia && historia.consultas && historia.consultas.length > 0 && historia.consultas[0].estudios?.length > 0) { %>
                                        <% historia.consultas[0].estudios?.forEach((est, idx) => { %>
                                            <tr data-estudio-idx="<%= idx %>" 
                                                data-tipo="<%= est.tipo_estudio || '' %>"
                                                data-resultado="<%= est.resultado || '' %>"
                                                data-observaciones="<%= est.observaciones || '' %>"
                                                data-fecha="<%= est.fecha_estudio || '' %>"
                                                style="border-bottom: 1px solid #f0f0f0;">
                                                <td style="padding: 12px; color: #333; font-weight: 600;"><%= est.tipo_estudio || '-' %></td>
                                                <td style="padding: 12px; color: #e74c3c; font-weight: 600; font-size: 14px;"><%= est.resultado || '-' %></td>
                                                <td style="padding: 12px; color: #666;"><%= est.observaciones || '-' %></td>
                                                <td style="padding: 12px; color: #999; font-size: 13px;">
                                                  <%= est.fecha_formateada || '-' %>
                                                </td>
                                                <td style="padding: 12px; display: none;" class="estudio-accion-td"></td>
                                            </tr>
                                        <% }); %>
