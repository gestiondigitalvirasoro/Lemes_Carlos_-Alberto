            } else {
                diagCards.forEach(card => {
                    const codigo = card.dataset.codigo || card.querySelector('strong')?.textContent?.trim() || '';
                    const desc   = card.querySelector('p')?.textContent?.trim() || '';
                    const d = document.createElement('div');
                    d.style.cssText = 'font-size:11px;line-height:1.9;';
                    d.innerHTML = '<strong style="color:#1D9E75;">' + codigo + '</strong> ' + desc;
