                        <% if (!historia?.consultas?.[0]?.estudios?.length) { %>
                            <div id="estudiosEmpty" style="text-align: center; padding: 40px 20px; color: #999;">
                                <i class="bi bi-flask" style="font-size: 2.5rem; display: block; margin-bottom: 12px; color: #bbb;"></i>
                                <p style="margin: 0;">Sin estudios complementarios registrados</p>
                            </div>
                        <% } %>

                        <!-- Botón Agregar Estudio (solo en modo edición) -->
                        <button id="btnAgregarEstudio" onclick="agregarFilaEstudio()" style="background: #007bff; color: white; border: none; padding: 10px 16px; border-radius: 6px; cursor: pointer; font-size: 14px; display: none; margin-top: 12px;">
                            <i class="bi bi-plus"></i> Agregar Estudio
                        </button>
                    </div>
                </section>

                <!-- ADJUNTOS E IMÁGENES -->
                <section class="section" id="adjuntos">
                    <div class="section-header">
                        <i class="bi bi-file-image"></i>
                        <h3>Adjuntos e Imágenes <span style="background: #e7f3ff; color: #0066cc; border-radius: 50%; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; margin-left: 8px;" id="adjuntosCount">0</span></h3>
                    </div>
                    <div class="section-body">
                        <!-- Drag-Drop Zone -->
                        <div id="dropZone" style="
                            border: 2px dashed #0066cc;
                            border-radius: 8px;
                            padding: 40px 20px;
                            text-align: center;
                            background: #f9f9ff;
                            cursor: pointer;
                            transition: all 0.3s;
                            margin-bottom: 20px;
                        ">
                            <i class="bi bi-folder" style="font-size: 2.5rem; color: #0066cc; display: block; margin-bottom: 12px;"></i>
                            <h5 style="color: #0066cc; margin: 10px 0;">Arrastrá archivos o hací clic para subir</h5>
                            <p style="color: #999; font-size: 13px;">Imágenes, PDF, informes de laboratorio</p>
                            <input type="file" id="fileInput" multiple hidden>
                        </div>

                        <!-- Lista de Adjuntos -->
                        <div id="adjuntosContainer" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px;">
                            <% if (historia?.adjuntos?.length > 0) { %>
                                <% historia.adjuntos.forEach(adj => { %>
                                    <div class="file-card" data-id="<%= adj.id %>" style="
                                        background: white;
                                        border: 1px solid #e0e0e0;
                                        border-radius: 6px;
                                        padding: 12px;
                                        text-align: center;
                                        transition: all 0.2s;
                                        position: relative;
                                    ">
                                        <i class="bi <%= adj.tipo?.includes('image') ? 'bi-image' : 'bi-file' %>" style="font-size: 2rem; color: #666; display: block; margin-bottom: 8px;"></i>
