                                            <%= adj.nombre_archivo?.substring(0, 20) || 'Archivo' %>
                                        </div>
                                        <small style="color: #999; display: block; margin-top: 5px;">
                                            <%= new Date(adj.fecha_carga).toLocaleDateString('es-AR') %>
