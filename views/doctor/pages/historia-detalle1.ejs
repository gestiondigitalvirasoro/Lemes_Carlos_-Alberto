                        <i class="bi bi-calendar3" style="color: #17a2b8;"></i>
                        <h3 style="color: #17a2b8;">Consulta activa</h3>
                    </div>
                    <div class="section-body">
                        <% if (historia && historia.consultas && historia.consultas.length > 0) { %>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <select id="consultaSelector" onchange="confirmarCambioConsulta(this.value)" style="flex:1; min-width:200px; padding:10px; border:1px solid #ddd; border-radius:6px; font-size:14px; cursor:pointer; background:white;">
                                    <% historia.consultas?.forEach((cons, idx) => { %>
                                        <option value="<%= idx %>" <%= idx === 0 ? 'selected' : '' %>>
                                            <%= cons.fecha %> — <%= cons.motivo_consulta || 'Consulta' %>
                                        </option>
                                    <% }); %>
                                </select>
                                <span style="font-size:13px; color:#666;">
                                    <i class="bi bi-person-circle me-1"></i><span id="consultaMedico"></span>
                                </span>
                            </div>
                        <% } else { %>
                            <p style="color:#999; margin:0;">Sin consultas registradas</p>
                        <% } %>
                    </div>
                </section>

                                <!-- SIGNOS VITALES -->
                <section class="section" id="signos-vitales">
