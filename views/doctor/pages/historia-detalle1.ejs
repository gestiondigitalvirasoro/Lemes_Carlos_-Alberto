            document.getElementById('rp-fecha').textContent =
                'Santo Tomé, ' + hoy.toLocaleDateString('es-AR', {day:'2-digit',month:'long',year:'numeric'});

            // Medicamentos desde diagnosticosSeleccionados y cards
            const medCards = document.querySelectorAll('.med-card-item');
