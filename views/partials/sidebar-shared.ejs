<!-- SIDEBAR COMPARTIDO - Mobile Responsive -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
  .sidebar {
    width: 280px; background: linear-gradient(180deg, #1a3a3a 0%, #0d1f1f 100%); color: white;
    padding: 30px 20px; box-shadow: 2px 0 10px rgba(0,0,0,0.1); position: fixed; height: 100vh;
    overflow-y: auto; z-index: 1000; transition: left 0.3s ease;
  }
  .sidebar-brand {
    margin: -30px -20px 30px -20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(92,174,163,0.4);
    padding-bottom: 6px;
  }
  .sidebar-brand img.brand-logo {
    width: 100%; height: auto;
    display: block;
    filter: invert(1) brightness(1.4);
    mix-blend-mode: screen;
    padding: 6px;
  }
  .logo-text {
    display: block;
    font-size: 1.5rem; font-weight: 800; letter-spacing: 4px;
    color: white; font-family: 'Georgia', serif;
    margin: 2px 0 0;
  }
  .logo-subtitle {
    display: block;
    font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,0.65); font-weight: 500;
    margin-bottom: 10px;
  }
  .sidebar-nav { display: flex; flex-direction: column; gap: 10px; }
  .sidebar-nav a { color: #bbb; text-decoration: none; padding: 10px 15px; border-radius: 6px;
    transition: all 0.3s; display: flex; align-items: center; gap: 10px; font-size: 0.95rem; }
  .sidebar-nav a:hover { background: rgba(217, 127, 127, 0.2); color: #D97F7F; }
  .sidebar-nav a.active { background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%); color: white; }
  .sidebar-nav a i { width: 20px; text-align: center; }
  .sidebar-divider { margin: 1rem 0; border: none; border-top: 1px solid rgba(255,255,255,0.15); }
  .sidebar-user { padding: 12px 15px; background: rgba(255,255,255,0.08); border-radius: 6px; margin-top: 10px; }
  .sidebar-user .user-name { font-weight: 600; font-size: 0.9rem; margin-bottom: 3px; }
  .sidebar-user .user-email { font-size: 0.75rem; opacity: 0.7; margin-bottom: 5px; }
  .sidebar-user .user-role { display: inline-block; font-size: 0.7rem; background: rgba(255,255,255,0.2);
    padding: 2px 8px; border-radius: 3px; font-weight: 600; text-transform: uppercase; }
  .logout-btn { display: flex; align-items: center; gap: 10px; width: 100%; margin-top: 10px; padding: 10px 15px;
    background: rgba(217, 127, 127, 0.15); color: #D97F7F; border: 1px solid rgba(217, 127, 127, 0.3);
    border-radius: 6px; text-decoration: none; font-size: 0.9rem; cursor: pointer; font-weight: 600;
    transition: all 0.3s; }
  .logout-btn:hover { background: rgba(217, 127, 127, 0.3); color: #D97F7F; }

  /* HAMBURGER */
  .hamburger-btn {
    display: none; position: fixed; top: 12px; left: 12px; z-index: 2000;
    background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%);
    border: none; border-radius: 8px; padding: 10px 12px; cursor: pointer; color: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3); font-size: 1.1rem;
  }
  .sidebar-overlay {
    display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5); z-index: 999;
  }
  .sidebar-overlay.active { display: block; }

  @media (max-width: 768px) {
    .hamburger-btn { display: block; }
    .sidebar { left: -280px; }
    .sidebar.open { left: 0; }
    .main-content, .content-area { margin-left: 0 !important; padding-top: 60px !important; }
  }
</style>

<!-- Botón hamburger (solo mobile) -->
<button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()">
  <i class="bi bi-list" style="font-size:1.4rem;"></i>
</button>

<!-- Overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <img src="/images/logo-lyl-clean.svg" alt="L & L" class="brand-logo">
    <span class="logo-text">L y L</span>
    <span class="logo-subtitle">Consultorio privado</span>
  </div>

  <nav class="sidebar-nav">
    <% if (user.rol !== 'secretaria') { %>
    <a href="/doctor/dashboard" class="<%= (locals.page === 'dashboard') ? 'active' : '' %>">
      <i class="bi bi-bar-chart-line"></i>
      <span>Inicio</span>
    </a>
    <% } %>
    <a href="/doctor/pacientes" class="<%= (locals.page === 'pacientes') ? 'active' : '' %>">
      <i class="bi bi-people"></i>
      <span>Pacientes</span>
    </a>
    <a href="/doctor/turnos" class="<%= (locals.page === 'turnos') ? 'active' : '' %>">
      <i class="bi bi-calendar-check"></i>
      <span>Turnos</span>
    </a>
    <a href="/notificaciones" class="<%= (locals.page === 'notificaciones') ? 'active' : '' %>">
      <i class="bi bi-bell"></i>
      <span>Notificaciones</span>
      <span id="badge-notif-shared" class="badge bg-danger ms-auto" style="display:none;font-size:10px;"></span>
    </a>
  </nav>

  <hr class="sidebar-divider">

  <div class="sidebar-user">
    <div class="user-name"><%= user.nombre %> <%= user.apellido %></div>
    <div class="user-email"><%= user.email %></div>
    <div class="user-role"><%= user.rol %></div>
  </div>

  <a class="logout-btn" href="javascript:void(0)" onclick="logout()">
    <i class="bi bi-box-arrow-right"></i>
    Cerrar Sesión
  </a>
</aside>

<script>
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('active');
  }

  // Badge contador sidebar
  (async function() {
    try {
      const r = await fetch('/api/solicitudes-turno/count', { credentials: 'include' });
      const d = await r.json();
      const badge = document.getElementById('badge-notif-shared');
      if (badge && d.count > 0) { badge.textContent = d.count; badge.style.display = 'inline'; }
    } catch(e) {}
  })();

  // ============================================================
  // NOTIFICACIONES DE ESCRITORIO (Web Notifications API)
  // Solo dispara si el permiso ya fue concedido.
  // Para activar por primera vez: ir a /notificaciones y hacer clic en el botón.
  // ============================================================
  (function() {
    if (!('Notification' in window) || Notification.permission !== 'granted') return;

    async function mostrarNotificaciones() {
      try {
        const r = await fetch('/api/notificaciones-escritorio', { credentials: 'include' });
        if (!r.ok) return;
        const d = await r.json();
        if (!d.items || d.items.length === 0) return;
        for (const item of d.items) {
          const key = `dnotif_${item.tipo}_${item.id}`;
          if (sessionStorage.getItem(key)) continue;
          const fechaStr = item.fecha_sugerida ? new Date(item.fecha_sugerida).toLocaleDateString('es-AR') : 'Sin fecha';
          const vencida = item.fecha_sugerida && new Date(item.fecha_sugerida) < new Date();
          const tipoLabel = item.tipo === 'solicitud' ? 'Solicitud de turno' : 'Próxima visita';
          const notif = new Notification(
            vencida ? `⚠️ ${tipoLabel} VENCIDA` : `🔔 ${tipoLabel} pendiente`,
            { body: `${item.paciente_nombre}\n${item.motivo || 'Sin motivo'} — ${fechaStr}`,
              icon: '/icons/icon-192.png', tag: key, requireInteraction: vencida }
          );
          notif.onclick = () => { window.focus(); window.location.href = '/notificaciones'; notif.close(); };
          fetch(`/api/notificaciones-escritorio/${item.tipo}/${item.id}/aviso`, { method: 'POST', credentials: 'include' }).catch(() => {});
          sessionStorage.setItem(key, '1');
          await new Promise(res => setTimeout(res, 2000));
        }
      } catch(e) {}
    }

    async function mostrarConForzar() {
      try {
        const r = await fetch('/api/notificaciones-escritorio?forzar=1', { credentials: 'include' });
        if (!r.ok) return;
        const d = await r.json();
        if (!d.items || d.items.length === 0) return;
        for (const item of d.items) {
          const key = `dnotif_${item.tipo}_${item.id}`;
          if (sessionStorage.getItem(key)) continue;
          const fechaStr = item.fecha_sugerida ? new Date(item.fecha_sugerida).toLocaleDateString('es-AR') : 'Sin fecha';
          const vencida = item.fecha_sugerida && new Date(item.fecha_sugerida) < new Date();
          const tipoLabel = item.tipo === 'solicitud' ? 'Solicitud de turno' : 'Próxima visita';
          const notif = new Notification(
            vencida ? `⚠️ ${tipoLabel} VENCIDA` : `🔔 ${tipoLabel} pendiente`,
            { body: `${item.paciente_nombre}\n${item.motivo || 'Sin motivo'} — ${fechaStr}`,
              icon: '/icons/icon-192.png', tag: key, requireInteraction: vencida }
          );
          notif.onclick = () => { window.focus(); window.location.href = '/notificaciones'; notif.close(); };
          fetch(`/api/notificaciones-escritorio/${item.tipo}/${item.id}/aviso`, { method: 'POST', credentials: 'include' }).catch(() => {});
          sessionStorage.setItem(key, '1');
          await new Promise(res => setTimeout(res, 2000));
        }
      } catch(e) {}
    }
    setTimeout(mostrarConForzar, 1000);
    setInterval(mostrarConForzar, 30 * 60 * 1000);
  })();
</script>
