<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1a3a3a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="L & L">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">

    <title><%= title %> - L & L Consultorio Privado</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary-900: #04342C;
            --primary-800: #085041;
            --primary-600: #0F6E56;
            --primary-400: #1D9E75;
            --primary-100: #9FE1CB;
            --primary-50:  #E1F5EE;
            --gray-50:     #F8F8F6;
            --gray-200:    #D3D1C7;
            --gray-500:    #888780;
            --gray-800:    #444441;
        }

        body {
            background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-container { width: 100%; max-width: 450px; }

        .login-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(4,52,44,0.15);
            overflow: hidden;
            background: white;
        }

        .login-header {
            background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%);
            padding: 0;
            text-align: center;
        }

        .login-body { padding: 36px 32px; background: white; }

        .form-control, .form-select {
            border-radius: 8px;
            border: 1.5px solid var(--gray-200);
            padding: 12px 15px;
            font-size: 1rem;
            background: var(--gray-50);
            transition: all 0.2s ease;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary-400);
            box-shadow: 0 0 0 3px rgba(29,158,117,0.15);
            background: white;
        }
        .form-label {
            margin-bottom: 6px;
            color: var(--gray-800);
            font-weight: 600;
            font-size: 0.9rem;
        }
        .btn-login {
            background: var(--primary-600);
            border: none;
            padding: 13px;
            font-weight: 700;
            border-radius: 8px;
            transition: all 0.2s ease;
            color: white;
            font-size: 1rem;
            letter-spacing: 0.5px;
        }
        .btn-login:hover {
            background: var(--primary-800);
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(15,110,86,0.3);
        }
        .btn-login:active { transform: none; }
        .forgot-password { text-align: right; margin-top: 12px; }
        .forgot-password a {
            color: var(--primary-600);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.875rem;
        }
        .forgot-password a:hover { text-decoration: underline; }
        .divider { text-align: center; margin: 20px 0; position: relative; }
        .divider::before {
            content: ''; position: absolute; left: 0; top: 50%;
            width: 100%; height: 1px; background: var(--gray-200);
        }
        .divider span {
            background: white; padding: 0 10px;
            position: relative; color: var(--gray-500); font-size: 0.85rem;
        }
        .help-text {
            background: var(--primary-50);
            border-left: 3px solid var(--primary-400);
            padding: 10px 14px; border-radius: 6px;
            margin-top: 16px; font-size: 0.875rem;
            color: var(--primary-800);
        }
        .form-group { margin-bottom: 18px; }
        h4.mb-4 { color: var(--primary-900); font-weight: 700; }
        .form-check-input:checked { background-color: var(--primary-600); border-color: var(--primary-600); }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <!-- Header -->
            <div class="login-header" style="padding:0;position:relative;text-align:center;">
                <!-- Logo completo -->
                <img src="/images/logo-lyl-clean.svg" alt="L & L"
                     style="width:100%;max-height:240px;object-fit:contain;display:block;mix-blend-mode:multiply;">
                <!-- Texto abajo -->
                <div style="padding:10px 24px 18px;text-align:center;">
                    <span style="display:block;font-size:1.5rem;font-weight:800;letter-spacing:4px;color:white;font-family:'Georgia',serif;text-shadow:0 1px 6px rgba(0,0,0,0.2);">L y L</span>
                    <span style="display:block;font-size:0.65rem;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.75);font-weight:500;">Consultorio privado</span>
                </div>
            </div>
            
            <!-- Body -->
            <div class="login-body">
                <h4 class="mb-4">Iniciar Sesión</h4>
                
                <!-- Alert Messages -->
                <div id="alertContainer"></div>
                
                <form id="loginForm">
                    <!-- Email -->
                    <div class="form-group">
                        <label class="form-label">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background: transparent; border-right: none;">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input 
                                type="email" 
                                class="form-control" 
                                id="email"
                                placeholder="tu@correo.com"
                                required
                            >
                        </div>
                    </div>
                    
                    <!-- Password -->
                    <div class="form-group">
                        <label class="form-label">Contraseña</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background: transparent; border-right: none;">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input 
                                type="password" 
                                class="form-control" 
                                id="password"
                                placeholder="Contraseña"
                                required
                            >
                        </div>
                    </div>
                    
                    <!-- Remember Me / Forgot Password -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="remember" name="remember">
                            <label class="form-check-label" for="remember">
                                Recuérdame
                            </label>
                        </div>
                        <a href="/forgot-password" class="text-decoration-none" style="color: #D97F7F; font-size: 0.9rem;">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>
                    
                    <!-- Login Button -->
                    <button type="submit" class="btn btn-login w-100 mb-3" id="submitBtn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Iniciar Sesión
                    </button>
                </form>
                
                <!-- Help Text -->
               <div class="help-text">
                     <i class="bi bi-info-circle"></i>
                    <strong>Prueba:</strong> doctor@lemes.com / doctor123
                    Secretaria: secretaria@lemes.com / secretaria123
               </div>
            </div>
        </div>
    </div>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Login Script -->
    <script>
        const loginForm = document.getElementById('loginForm');
        const alertContainer = document.getElementById('alertContainer');
        const submitBtn = document.getElementById('submitBtn');
        
        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            // Limpiar alertas previas
            alertContainer.innerHTML = '';
            
            // Deshabilitar botón
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Ingresando...';
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email, password })
                });
                
                const data = await response.json();
                
                if (!response.ok) {
                    // Error en login
                    alertContainer.innerHTML = `
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle"></i>
                            ${data.message || 'Error al iniciar sesión'}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    `;
                } else {
                    // Login exitoso - guardar token en localStorage
                    localStorage.setItem('token', data.data.access_token);
                    
                    alertContainer.innerHTML = `
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i>
                            ¡Bienvenido! Redirigiendo...
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    `;
                    
                    // Redirigir según el rol del usuario
                    const userRole = data.data.medico.role;
                    let redirectUrl = '/dashboard';
                    
                    if (userRole === 'admin') {
                        redirectUrl = '/admin/dashboard';
                    } else if (userRole === 'doctor') {
                        redirectUrl = '/doctor/dashboard';
                     } else if (userRole === 'secretaria') {
                          redirectUrl = '/doctor/turnos';
}
                    
                    setTimeout(() => {
                        window.location.href = redirectUrl;
                    }, 1000);
                }
            } catch (error) {
                console.error('Error:', error);
                alertContainer.innerHTML = `
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle"></i>
                        Error de conexión. Intenta nuevamente.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            } finally {
                // Reabilitar botón
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión';
            }
        });
    </script>

<script>if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js'); }</script>
</body>
</html>
