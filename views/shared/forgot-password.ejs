<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña - LEMES Sistema Médico</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        body {
            background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card-container {
            width: 100%;
            max-width: 450px;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        .card-header-custom {
            background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%);
            color: white;
            padding: 40px 30px;
            text-align: center;
        }
        .card-header-custom i { font-size: 3rem; display: block; margin-bottom: 15px; }
        .card-header-custom h2 { margin: 0; font-weight: 700; }
        .card-header-custom p { margin: 5px 0 0 0; opacity: 0.9; }
        .card-body-custom { padding: 40px 30px; }
        .form-control {
            border-radius: 8px;
            border: 1px solid #dee2e6;
            padding: 12px 15px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        .form-control:focus {
            border-color: #D97F7F;
            box-shadow: 0 0 0 0.2rem rgba(217,127,127,0.25);
        }
        .btn-primary-custom {
            background: linear-gradient(135deg, #D97F7F 0%, #5CAEA3 100%);
            border: none;
            padding: 12px;
            font-weight: 600;
            border-radius: 8px;
            color: white;
            width: 100%;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        .btn-primary-custom:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }
        .back-link { color: #D97F7F; text-decoration: none; font-size: 0.9rem; }
        .back-link:hover { text-decoration: underline; color: #D97F7F; }
    </style>
</head>
<body>
    <div class="card-container">
        <div class="card">
            <div class="card-header-custom">
                <i class="bi bi-key"></i>
                <h2>LEMES</h2>
                <p>Recuperar Contraseña</p>
            </div>
            <div class="card-body-custom">
                <p class="text-muted mb-4" style="font-size:0.95rem;">
                    Ingresá tu email y te enviaremos un enlace para restablecer tu contraseña.
                </p>

                <div id="alertContainer"></div>

                <form id="forgotForm">
                    <div class="mb-3">
                        <label class="form-label fw-500">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:transparent; border-right:none;">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input
                                type="email"
                                class="form-control"
                                id="email"
                                placeholder="tu@correo.com"
                                required
                            >
                        </div>
                    </div>

                    <button type="submit" class="btn-primary-custom mb-3" id="submitBtn">
                        <i class="bi bi-send"></i> Enviar enlace de recuperación
                    </button>
                </form>

                <div class="text-center">
                    <a href="/login" class="back-link">
                        <i class="bi bi-arrow-left"></i> Volver al inicio de sesión
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const form = document.getElementById('forgotForm');
        const alertContainer = document.getElementById('alertContainer');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;

            alertContainer.innerHTML = '';
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Enviando...';

            try {
                const response = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await response.json();

                if (response.ok) {
                    alertContainer.innerHTML = `
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            ${data.message}
                        </div>
                    `;
                    form.reset();
                } else {
                    alertContainer.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle"></i>
                            ${data.message || 'Error al enviar el email'}
                        </div>
                    `;
                }
            } catch (error) {
                alertContainer.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i>
                        Error de conexión. Intentá nuevamente.
                    </div>
                `;
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-send"></i> Enviar enlace de recuperación';
            }
        });
    </script>
</body>
</html>
