          <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
            ${_esDoctor
              ? `<a href="/doctor/historia-nueva?paciente_id=${p.paciente_id}" class="btn-acc" style="background:#ef4444;color:white;display:inline-flex;align-items:center;gap:4px;text-decoration:none;padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;">
                  <i class="fas fa-plus"></i> Crear Historia Clínica
