  // Solo mostrar "datos incompletos" aquí si no se mostró antes (doctor los ve primero = sin_hc primero)
  if (primero !== 'datos_incompletos' && datos_incompletos.length > 0) {
    html += `
      <div style="font-size:0.85rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;">
        <i class="fas fa-exclamation-circle" style="color:#f59e0b;"></i> Datos incompletos (${datos_incompletos.length})
