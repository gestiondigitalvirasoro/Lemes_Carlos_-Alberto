              ? `<a href="${p.tiene_hc ? '/historia/' + p.paciente_id : '/doctor/historia-nueva?paciente_id=' + p.paciente_id}" class="btn-acc" style="background:#1a3a3a;color:white;display:inline-flex;align-items:center;gap:4px;text-decoration:none;padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;">
                  <i class="fas fa-notes-medical"></i> ${p.tiene_hc ? 'Ver Historia Clínica' : 'Crear Historia Clínica'}
                 </a>`
              : ''
            }
          </div>
        </div>
      </div>`).join('');
  }

  // Si es doctor, al final muestra sin HC también (ya mostró datos incompletos primero arriba en este caso no aplica)
  // Si es secretaria, sin_hc ya se mostró arriba y datos_incompletos acá

  contenedor.innerHTML = html;
}

function abrirEditarPaciente(p) {
  document.getElementById('edit-pac-id').value = p.paciente_id;
  document.getElementById('edit-pac-nombre').value = p.nombre || '';
  document.getElementById('edit-pac-apellido').value = p.apellido || '';
  document.getElementById('edit-pac-email').value = p.email || '';
  document.getElementById('edit-pac-telefono').value = p.telefono || '';
  document.getElementById('edit-pac-fecha-nac').value = p.fecha_nacimiento || '';
  document.getElementById('edit-pac-sexo').value = p.sexo || '';
  document.getElementById('edit-pac-obra-social').value = p.obra_social || '';
  document.getElementById('edit-pac-num-afiliado').value = p.numero_afiliado || '';
  new bootstrap.Modal(document.getElementById('modalEditarPacienteNotif')).show();
}

async function guardarEdicionPacienteNotif() {
  const id = document.getElementById('edit-pac-id').value;
  const nombre = document.getElementById('edit-pac-nombre').value.trim();
  const apellido = document.getElementById('edit-pac-apellido').value.trim();
  if (!nombre || !apellido) { alert('Nombre y apellido son obligatorios'); return; }

  const btnGuardar = document.getElementById('btn-guardar-edit');
  btnGuardar.disabled = true;
  try {
    const resp = await fetch(`/api/pacientes/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({
        nombre,
        apellido,
        email:            document.getElementById('edit-pac-email').value.trim(),
        telefono:         document.getElementById('edit-pac-telefono').value.trim(),
        fecha_nacimiento: document.getElementById('edit-pac-fecha-nac').value || null,
        sexo:             document.getElementById('edit-pac-sexo').value,
        obra_social:      document.getElementById('edit-pac-obra-social').value.trim(),
        numero_afiliado:  document.getElementById('edit-pac-num-afiliado').value.trim()
      })
    });
    const data = await resp.json();
    if (resp.ok) {
      bootstrap.Modal.getInstance(document.getElementById('modalEditarPacienteNotif')).hide();
      await cargarTodo();
      cambiarTab('admin');
    } else {
      alert('Error: ' + (data.error || 'No se pudo guardar'));
    }
  } catch(e) {
    alert('Error de red al guardar');
  }
  btnGuardar.disabled = false;
}

