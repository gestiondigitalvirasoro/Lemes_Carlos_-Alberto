    // ============================================================
    // INICIAR CONSULTA CON VERIFICACIÓN DE ALTA
    // ============================================================
    async function iniciarConsultaConAlta(turnoId) {
      mostrarLoading('Verificando datos del paciente...');
      try {
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ estado: 'EN_CONSULTA' })
        });

        const resultado = await response.json();
        ocultarLoading();

        if (response.status === 422 && resultado.pacienteIncompleto) {
          // Paciente sin alta → abrir modal para completar datos
          abrirModalAlta(turnoId, resultado.datosActuales || {});
          return;
        }

        if (response.ok && resultado.success) {
          await cargarTurnos();
          return;
        }

        if (response.status === 409) {
          alert('⚠️ Ya hay otra consulta en curso. Finalizala antes de iniciar una nueva.');
          return;
        }

        throw new Error(resultado.message || 'Error al iniciar consulta');
      } catch (error) {
        ocultarLoading();
        alert('❌ ' + error.message);
      }
    }

