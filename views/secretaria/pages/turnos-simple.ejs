      if (filtroNombre) filtroNombre.addEventListener('input', filtrarTurnos);
      if (filtroEstado) filtroEstado.addEventListener('change', filtrarTurnos);
      if (filtroFecha) filtroFecha.addEventListener('change', filtrarTurnos);

      console.log('✅ Event listeners de filtros inicializados');
    }

