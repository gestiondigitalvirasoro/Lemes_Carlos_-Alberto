<script>
// ============================================================
// CALENDARIO PARA AGENDAR TURNO - CON SLOTS Y BLOQUEOS
// ============================================================

const FERIADOS = new Set([
  // 2025
  '2025-01-01','2025-03-03','2025-03-04','2025-04-02','2025-04-18',
  '2025-05-01','2025-05-25','2025-06-20','2025-07-09','2025-08-17',
  '2025-10-12','2025-11-20','2025-12-08','2025-12-25',
  // 2026
  '2026-01-01','2026-02-16','2026-02-17','2026-04-02','2026-04-03',
  '2026-05-01','2026-05-25','2026-06-20','2026-07-09','2026-08-17',
  '2026-10-12','2026-11-20','2026-12-08','2026-12-25',
  // 2027
  '2027-01-01','2027-02-08','2027-02-09','2027-03-24','2027-04-02',
  '2027-05-01','2027-05-25','2027-06-20','2027-07-09','2027-08-16',
  '2027-10-11','2027-11-20','2027-12-08','2027-12-25'
]);

function generarSlots() {
  const slots = [];
  for (let h = 8; h < 12; h++) {
    slots.push(`${String(h).padStart(2,'0')}:00`);
    slots.push(`${String(h).padStart(2,'0')}:30`);
  }
  slots.push('12:00');
  for (let h = 17; h < 20; h++) {
    slots.push(`${String(h).padStart(2,'0')}:00`);
    slots.push(`${String(h).padStart(2,'0')}:30`);
  }
  slots.push('20:00');
  return slots;
}

async function abrirCalendarioAgendar() {
  _carga('Abriendo calendario...');
  try {
  // Contar slots USADOS por fecha (considerando duración de cada turno)
  const slotsPorFecha = {};
  if (typeof turnosGlobales !== 'undefined' && turnosGlobales) {
    turnosGlobales.forEach(t => {
      if (['PENDIENTE', 'EN_CONSULTA'].includes(t.estado?.nombre)) {
        const partes = t.fecha.split('/');
        if (partes.length === 3) {
          const key = `${partes[2]}-${String(partes[1]).padStart(2,'0')}-${String(partes[0]).padStart(2,'0')}`;
          const slotsUsados = Math.ceil((t.duracion_minutos || 30) / 30);
          slotsPorFecha[key] = (slotsPorFecha[key] || 0) + slotsUsados;
        }
      }
    });
  }

  let diasBloqueados = [];
  try {
    const r = await fetch('/api/disponibilidad/bloqueados', { credentials: 'include' });
    if (r.ok) { const d = await r.json(); diasBloqueados = d.bloqueados || []; }
  } catch(e) {}

  const diasBloqueadosSet = new Set();
  const horasBloqueadasSet = new Set();
  window._calDiasBloqueadosInfo = {};
  diasBloqueados.forEach(b => {
    if (!b.hora) {
      diasBloqueadosSet.add(b.fecha);
      window._calDiasBloqueadosInfo[b.fecha] = { motivo: b.motivo };
    } else {
      horasBloqueadasSet.add(`${b.fecha}|${b.hora}`);
    }
  });

  const slots = generarSlots();
  const hoy = new Date();
  hoy.setHours(0,0,0,0);
  let mesActual = hoy.getMonth();
  let anioActual = hoy.getFullYear();

  function contarSlotsLibres(fechaISO) {
    if (diasBloqueadosSet.has(fechaISO)) return 0;
    const slotsUsados = slotsPorFecha[fechaISO] || 0;
    const bloqueadosHora = slots.filter(h => horasBloqueadasSet.has(`${fechaISO}|${h}`)).length;
    return Math.max(0, slots.length - slotsUsados - bloqueadosHora);
  }

  function renderCalendario(mes, anio) {
    const diasSemana = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
    const mesesNombre = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    const primerDia = new Date(anio, mes, 1).getDay();
    const diasEnMes = new Date(anio, mes + 1, 0).getDate();
    const hoyISO = `${hoy.getFullYear()}-${String(hoy.getMonth()+1).padStart(2,'0')}-${String(hoy.getDate()).padStart(2,'0')}`;

    let celdas = '';
    for (let i = 0; i < primerDia; i++) {
      celdas += `<div style="padding:6px;"></div>`;
    }
    for (let d = 1; d <= diasEnMes; d++) {
      const fechaISO = `${anio}-${String(mes+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const fechaObj = new Date(anio, mes, d);
      const diaSemana = fechaObj.getDay();
      const esPasado = fechaObj < hoy;
      const esFinde = diaSemana === 0 || diaSemana === 6;
      const esFeriado = FERIADOS.has(fechaISO);
      const esBloqueado = diasBloqueadosSet.has(fechaISO);
      const esHoy = fechaISO === hoyISO;

      if (esPasado || esFinde || esFeriado || esBloqueado) {
        const label = esFeriado ? 'Feriado' : esBloqueado ? '🚫' : diaSemana === 6 ? 'Sáb' : 'Dom';
        celdas += `<div style="padding:6px;border-radius:8px;background:#f9fafb;border:1px solid #e5e7eb;opacity:0.5;text-align:center;cursor:not-allowed;">
          <div style="font-weight:700;font-size:14px;color:#9ca3af;">${d}</div>
          <div style="font-size:9px;color:#d1d5db;">${label}</div>
        </div>`;
      } else {
        const libres = contarSlotsLibres(fechaISO);
        let bg, colorNum, border;
        if (libres === 0) { bg='#fee2e2'; colorNum='#dc2626'; border='1px solid #fca5a5'; }
        else if (libres <= 3) { bg='#fef3c7'; colorNum='#d97706'; border='1px solid #fde68a'; }
        else if (libres <= 7) { bg='#dbeafe'; colorNum='#1d4ed8'; border='1px solid #bfdbfe'; }
        else { bg='#f0fdf4'; colorNum='#059669'; border='1px solid #bbf7d0'; }

        celdas += `<div onclick="abrirSlotsDelDia('${fechaISO}')" style="padding:6px;border-radius:8px;background:${bg};border:${border};text-align:center;cursor:pointer;transition:transform .1s;${esHoy ? 'box-shadow:0 0 0 2px #1D9E75;' : ''}"
          onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'">
          <div style="font-weight:700;font-size:14px;color:#1a3a3a;">${d}${esHoy ? ' <span style="font-size:8px;color:#1D9E75;">HOY</span>' : ''}</div>
          <div style="font-size:9px;font-weight:600;color:${colorNum};">${libres > 0 ? libres + ' libre' + (libres > 1 ? 's' : '') : 'sin lugar'}</div>
        </div>`;
      }
    }

    const puedoAnterior = new Date(anio, mes, 1) > hoy;
    document.getElementById('calBody').innerHTML = celdas;
    document.getElementById('calTitulo').textContent = `${mesesNombre[mes]} ${anio}`;
    document.getElementById('calBtnAnterior').style.opacity = puedoAnterior ? '1' : '0.3';
    document.getElementById('calBtnAnterior').style.pointerEvents = puedoAnterior ? 'auto' : 'none';
  }

  let container = document.getElementById('modalCalendarioContainer');
  if (!container) {
    container = document.createElement('div');
    container.id = 'modalCalendarioContainer';
    document.body.appendChild(container);
  }

  const diasSemana = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const headers = diasSemana.map(d => `<div style="text-align:center;font-size:11px;font-weight:700;color:#888;padding:4px;">${d}</div>`).join('');

  container.innerHTML = `
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.65);display:flex;justify-content:center;align-items:center;z-index:9999;padding:16px;" onclick="cerrarCalendario()">
      <div style="background:white;border-radius:16px;padding:24px;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,0.3);" onclick="event.stopPropagation()">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
          <h3 style="font-size:16px;font-weight:700;color:#1a3a3a;margin:0;">📅 Elegí el día del turno</h3>
          <div style="display:flex;gap:8px;align-items:center;">
            <button onclick="abrirGestionDisponibilidad()" style="background:#fee2e2;border:none;border-radius:6px;padding:4px 8px;cursor:pointer;font-size:11px;color:#dc2626;font-weight:600;">🚫 Bloquear</button>
            <button onclick="cerrarCalendario()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#999;line-height:1;">✕</button>
          </div>
        </div>

        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
          <span style="font-size:10px;display:flex;align-items:center;gap:3px;"><span style="width:10px;height:10px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:2px;display:inline-block;"></span>Muchos libres</span>
          <span style="font-size:10px;display:flex;align-items:center;gap:3px;"><span style="width:10px;height:10px;background:#dbeafe;border:1px solid #bfdbfe;border-radius:2px;display:inline-block;"></span>Algunos</span>
          <span style="font-size:10px;display:flex;align-items:center;gap:3px;"><span style="width:10px;height:10px;background:#fef3c7;border:1px solid #fde68a;border-radius:2px;display:inline-block;"></span>Pocos</span>
          <span style="font-size:10px;display:flex;align-items:center;gap:3px;"><span style="width:10px;height:10px;background:#fee2e2;border:1px solid #fca5a5;border-radius:2px;display:inline-block;"></span>Sin lugar</span>
        </div>

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
          <button id="calBtnAnterior" onclick="navegarCalendario(-1)" style="background:#f3f4f6;border:none;border-radius:8px;padding:6px 12px;cursor:pointer;font-weight:700;">‹</button>
          <span id="calTitulo" style="font-weight:700;font-size:15px;color:#1a3a3a;"></span>
          <button onclick="navegarCalendario(1)" style="background:#f3f4f6;border:none;border-radius:8px;padding:6px 12px;cursor:pointer;font-weight:700;">›</button>
        </div>

        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;">
          ${headers}
          <div id="calBody" style="display:contents;"></div>
        </div>
      </div>
    </div>`;

  renderCalendario(mesActual, anioActual);
  window._calMes = mesActual;
  window._calAnio = anioActual;
  window._calHorasBloqueadas = horasBloqueadasSet;
  window._calDiasBloqueados = diasBloqueadosSet;
  window._calSlotsPorFecha = slotsPorFecha;
  window.navegarCalendario = function(dir) {
    window._calMes += dir;
    if (window._calMes > 11) { window._calMes = 0; window._calAnio++; }
    if (window._calMes < 0) { window._calMes = 11; window._calAnio--; }
    renderCalendario(window._calMes, window._calAnio);
  };
  } catch(e) { console.error('abrirCalendarioAgendar:', e); } finally { _listo(); }
}

function horaAMinutos(h) { const [hh,mm] = (h||'00:00').split(':').map(Number); return hh*60+mm; }

async function abrirSlotsDelDia(fechaISO) {
  _carga('Cargando horarios...');
  try {
  // Calcular slots ocupados desde turnosGlobales (evita problemas de timezone con la API)
  const allSlots = generarSlots();
  const ocupadasSet = new Set();

  if (typeof turnosGlobales !== 'undefined' && turnosGlobales) {
    turnosGlobales.forEach(t => {
      if (['PENDIENTE', 'EN_CONSULTA'].includes(t.estado?.nombre)) {
        const partes = t.fecha.split('/');
        if (partes.length === 3) {
          const tFechaISO = `${partes[2]}-${String(partes[1]).padStart(2,'0')}-${String(partes[0]).padStart(2,'0')}`;
          if (tFechaISO === fechaISO) {
            const hora = (t.hora || '').substring(0, 5);
            const dur = t.duracion_minutos || 30;
            const ini = horaAMinutos(hora);
            const fin = ini + dur;
            allSlots.forEach(s => { const sm = horaAMinutos(s); if (sm >= ini && sm < fin) ocupadasSet.add(s); });
          }
        }
      }
    });
  }

  // Obtener horas bloqueadas y estado del día desde la API
  let horasBloqueadasAPI = [];
  let diaBloqueadoTotal = false;
  try {
    const r = await fetch(`/api/disponibilidad/turnos-del-dia?fecha=${fechaISO}`, { credentials: 'include' });
    if (r.ok) {
      const d = await r.json();
      horasBloqueadasAPI = d.horasBloqueadas || [];
      diaBloqueadoTotal = d.diaBloqueado || false;
    }
  } catch(e) {}

  // Si el día está bloqueado completo, mostrar mensaje y no continuar
  if (diaBloqueadoTotal) {
    const [anio2, mes2, dia2] = fechaISO.split('-');
    const fechaLabel2 = `${dia2}/${mes2}/${anio2}`;
    const diasNombre2 = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
    const diaNombre2 = diasNombre2[new Date(parseInt(anio2), parseInt(mes2)-1, parseInt(dia2)).getDay()];
    // Buscar motivo en la lista de bloqueos del calendario
    const bloqInfo = (window._calDiasBloqueadosInfo || {})[fechaISO] || {};
    const motivoTexto = bloqInfo.motivo ? ` — ${bloqInfo.motivo}` : '';
    let container = document.getElementById('modalCalendarioContainer');
    if (!container) { container = document.createElement('div'); container.id = 'modalCalendarioContainer'; document.body.appendChild(container); }
    container.innerHTML = `
      <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.65);display:flex;justify-content:center;align-items:center;z-index:9999;padding:16px;" onclick="cerrarCalendario()">
        <div style="background:white;border-radius:16px;padding:24px;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,0.3);" onclick="event.stopPropagation()">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <button onclick="abrirCalendarioAgendar()" style="background:#f3f4f6;border:none;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px;color:#666;">← Volver</button>
            <button onclick="cerrarCalendario()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#999;line-height:1;">✕</button>
          </div>
          <h3 style="font-size:16px;font-weight:700;color:#1a3a3a;margin-bottom:8px;">🚫 ${diaNombre2} ${fechaLabel2}</h3>
          <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:16px;text-align:center;">
            <div style="font-size:14px;font-weight:600;color:#dc2626;">No hay atención este día${motivoTexto}</div>
            <div style="font-size:12px;color:#9ca3af;margin-top:6px;">Seleccioná otro día en el calendario</div>
          </div>
          <button onclick="abrirCalendarioAgendar()" style="margin-top:14px;width:100%;padding:10px;background:#f3f4f6;border:none;border-radius:8px;cursor:pointer;font-weight:600;color:#374151;">← Volver al calendario</button>
        </div>
      </div>`;
    return;
  }

  // Combinar bloqueos manuales (del calendario) + los del servidor
  const bloqueadasSet = new Set([
    ...horasBloqueadasAPI,
    ...[...(window._calHorasBloqueadas || [])].filter(k => k.startsWith(fechaISO+'|')).map(k => k.split('|')[1])
  ]);
  const slots = generarSlots();
  const mañana = slots.filter(h => parseInt(h) < 13);
  const tarde = slots.filter(h => parseInt(h) >= 17);

  const [anio, mes, dia] = fechaISO.split('-');
  const fechaLabel = `${dia}/${mes}/${anio}`;
  const diasNombre = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const diaNombre = diasNombre[new Date(parseInt(anio), parseInt(mes)-1, parseInt(dia)).getDay()];

  // Validación de horarios pasados
  const ahora = new Date();
  const hoyISO = `${ahora.getFullYear()}-${String(ahora.getMonth()+1).padStart(2,'0')}-${String(ahora.getDate()).padStart(2,'0')}`;
  const esMismoDia = fechaISO === hoyISO;
  const minutosActuales = ahora.getHours() * 60 + ahora.getMinutes();

  function renderSlots(lista) {
    return lista.map(hora => {
      const [hh, mm] = hora.split(':').map(Number);
      const minutosSlot = hh * 60 + mm;
      const pasado = esMismoDia && minutosSlot <= minutosActuales;
      const ocupado = !pasado && ocupadasSet.has(hora);
      const bloqueado = !pasado && bloqueadasSet.has(hora);
      const clickable = !pasado && !ocupado && !bloqueado;
      let bg, color, label;
      if (pasado)   { bg='#f3f4f6'; color='#9ca3af'; label='Pasado'; }
      else if (bloqueado) { bg='#f3f4f6'; color='#9ca3af'; label='Bloqueado'; }
      else if (ocupado)   { bg='#fee2e2'; color='#dc2626'; label='Ocupado'; }
      else { bg='#f0fdf4'; color='#059669'; label='Libre'; }
      return `<div onclick="${clickable ? `seleccionarSlot('${fechaISO}','${hora}')` : ''}"
        style="padding:8px 4px;border-radius:8px;background:${bg};border:1px solid ${bg};text-align:center;cursor:${clickable ? 'pointer' : 'not-allowed'};"
        ${clickable ? `onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"` : ''}>
        <div style="font-weight:700;font-size:13px;color:#1a3a3a;">${hora}</div>
        <div style="font-size:9px;color:${color};">${label}</div>
      </div>`;
    }).join('');
  }

  let container = document.getElementById('modalCalendarioContainer');
  if (!container) { container = document.createElement('div'); container.id = 'modalCalendarioContainer'; document.body.appendChild(container); }

  container.innerHTML = `
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.65);display:flex;justify-content:center;align-items:center;z-index:9999;padding:16px;" onclick="cerrarCalendario()">
      <div style="background:white;border-radius:16px;padding:24px;width:100%;max-width:420px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.3);" onclick="event.stopPropagation()">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
          <button onclick="abrirCalendarioAgendar()" style="background:#f3f4f6;border:none;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px;color:#666;">← Volver</button>
          <button onclick="cerrarCalendario()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#999;line-height:1;">✕</button>
        </div>

        <h3 style="font-size:16px;font-weight:700;color:#1a3a3a;margin-bottom:4px;">🕐 ${diaNombre} ${fechaLabel}</h3>
        <p style="font-size:12px;color:#666;margin-bottom:16px;">Seleccioná un horario disponible</p>

        <div style="margin-bottom:14px;">
          <div style="font-size:11px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">☀️ Mañana</div>
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;">
            ${renderSlots(mañana)}
          </div>
        </div>

        <div style="margin-bottom:14px;">
          <div style="font-size:11px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">🌙 Tarde</div>
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;">
            ${renderSlots(tarde)}
          </div>
        </div>

        <div style="padding:10px;background:#fef3c7;border-radius:8px;">
          <p style="font-size:11px;color:#92400e;margin:0;">💡 También podés agendar sin horario fijo — <a href="/doctor/agendar-turno?fecha=${fechaISO}" style="color:#d97706;font-weight:600;">abrir formulario</a></p>
        </div>
      </div>
    </div>`;
  } catch(e) { console.error('abrirSlotsDelDia:', e); } finally { _listo(); }
}

function seleccionarSlot(fechaISO, hora) {
  cerrarCalendario();
  window.location.href = `/doctor/agendar-turno?fecha=${fechaISO}&hora=${encodeURIComponent(hora)}`;
}

function cerrarCalendario() {
  const c = document.getElementById('modalCalendarioContainer');
  if (c) c.innerHTML = '';
}

function abrirGestionDisponibilidad() {
  cerrarCalendario();
  let container = document.getElementById('modalCalendarioContainer');
  if (!container) { container = document.createElement('div'); container.id = 'modalCalendarioContainer'; document.body.appendChild(container); }

  const hoy = new Date();
  const hoyISO = `${hoy.getFullYear()}-${String(hoy.getMonth()+1).padStart(2,'0')}-${String(hoy.getDate()).padStart(2,'0')}`;

  container.innerHTML = `
    <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.65);display:flex;justify-content:center;align-items:center;z-index:9999;padding:16px;" onclick="cerrarCalendario()">
      <div style="background:white;border-radius:16px;padding:24px;width:100%;max-width:420px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.3);" onclick="event.stopPropagation()">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
          <h3 style="font-size:16px;font-weight:700;color:#1a3a3a;margin:0;">🚫 Gestión de Disponibilidad</h3>
          <button onclick="cerrarCalendario()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#999;line-height:1;">✕</button>
        </div>

        <p style="font-size:13px;color:#666;margin-bottom:16px;">Bloqueá días u horarios para que no aparezcan como disponibles en el calendario.</p>

        <div style="background:#f9fafb;border-radius:10px;padding:16px;margin-bottom:16px;">
          <div style="font-size:13px;font-weight:600;color:#374151;margin-bottom:12px;">Nuevo bloqueo</div>
          <div style="margin-bottom:10px;">
            <label style="font-size:12px;color:#666;display:block;margin-bottom:4px;">Fecha *</label>
            <input type="date" id="bloqueoFecha" min="${hoyISO}" style="width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;">
          </div>
          <div style="margin-bottom:10px;">
            <label style="font-size:12px;color:#666;display:block;margin-bottom:4px;">Hora (dejar vacío para bloquear el día entero)</label>
            <select id="bloqueoHora" style="width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;">
              <option value="">— Día completo —</option>
              ${generarSlots().map(h => `<option value="${h}">${h}</option>`).join('')}
            </select>
          </div>
          <div style="margin-bottom:12px;">
            <label style="font-size:12px;color:#666;display:block;margin-bottom:4px;">Motivo (opcional)</label>
            <input type="text" id="bloqueoMotivo" placeholder="Ej: Feriado local, reunión..." style="width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;">
          </div>
          <button onclick="guardarBloqueoManual()" style="width:100%;padding:9px;background:#dc2626;color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:13px;">🚫 Guardar bloqueo</button>
        </div>

        <div>
          <div style="font-size:13px;font-weight:600;color:#374151;margin-bottom:10px;">Bloqueos activos</div>
          <div id="listaBloqueos">
            <div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px;">Cargando...</div>
          </div>
        </div>
      </div>
    </div>`;

  cargarListaBloqueos();
}

async function cargarListaBloqueos() {
  try {
    const r = await fetch('/api/disponibilidad/bloqueados', { credentials: 'include' });
    const data = await r.json();
    const lista = data.bloqueados || [];
    const el = document.getElementById('listaBloqueos');
    if (!el) return;
    if (lista.length === 0) {
      el.innerHTML = '<div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px;">Sin bloqueos activos</div>';
      return;
    }
    el.innerHTML = lista.map(b => `
      <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 10px;background:#f9fafb;border-radius:6px;margin-bottom:6px;">
        <div>
          <span style="font-size:13px;font-weight:600;color:#1a3a3a;">${b.fecha}</span>
          ${b.hora ? `<span style="font-size:12px;color:#666;margin-left:6px;">🕐 ${b.hora}</span>` : '<span style="font-size:11px;color:#dc2626;margin-left:6px;">Día completo</span>'}
          ${b.motivo ? `<div style="font-size:11px;color:#9ca3af;">${b.motivo}</div>` : ''}
        </div>
        <button onclick="eliminarBloqueo('${b.fecha}','${b.hora||''}')" style="background:#fee2e2;border:none;border-radius:6px;padding:4px 8px;cursor:pointer;font-size:11px;color:#dc2626;">✕</button>
      </div>`).join('');
  } catch(e) {
    const el = document.getElementById('listaBloqueos');
    if (el) el.innerHTML = '<div style="color:#dc2626;font-size:12px;padding:8px;">Error al cargar bloqueos</div>';
  }
}

async function guardarBloqueoManual() {
  const fecha = document.getElementById('bloqueoFecha').value;
  const hora = document.getElementById('bloqueoHora').value;
  const motivo = document.getElementById('bloqueoMotivo').value;
  if (!fecha) { alert('Por favor ingresá una fecha'); return; }
  _carga('Guardando bloqueo...');
  try {
    const r = await fetch('/api/disponibilidad/bloquear', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ fecha, hora: hora || null, motivo: motivo || null })
    });
    const data = await r.json();
    if (r.ok && data.success) {
      document.getElementById('bloqueoFecha').value = '';
      document.getElementById('bloqueoHora').value = '';
      document.getElementById('bloqueoMotivo').value = '';
      cargarListaBloqueos();
    } else {
      alert('Error: ' + (data.error || data.message || 'No se pudo guardar'));
    }
  } catch(e) { alert('Error de conexión'); } finally { _listo(); }
}

async function eliminarBloqueo(fecha, hora) {
  if (!confirm(`¿Eliminar bloqueo${hora ? ' del horario ' + hora : ' del día completo'}?`)) return;
  _carga('Eliminando bloqueo...');
  try {
    const r = await fetch('/api/disponibilidad/desbloquear', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ fecha, hora: hora || null })
    });
    const data = await r.json();
    if (r.ok && data.success) { cargarListaBloqueos(); }
    else { alert('Error: ' + (data.error || data.message || 'No se pudo eliminar')); }
  } catch(e) { alert('Error de conexión'); } finally { _listo(); }
}
</script>
</body>
</html>
