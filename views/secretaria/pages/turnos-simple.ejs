    async function guardarAltaEIniciar(turnoId) {
      const nombre = document.getElementById('altaNombre').value.trim();
      const apellido = document.getElementById('altaApellido').value.trim();
      if (!nombre || !apellido) {
        alert('Nombre y Apellido son obligatorios');
        return;
      }
      const btn = document.getElementById('btnGuardarAlta');
      btn.disabled = true; btn.innerHTML = '⏳ Guardando...';

      mostrarLoading('Dando de alta e iniciando consulta...');
      try {
        const response = await fetch(`/api/turnos/${turnoId}/confirmar-llegada`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            nombre,
            apellido,
            telefono: document.getElementById('altaTelefono').value.trim() || null,
            email: document.getElementById('altaEmail').value.trim() || null,
            obra_social: document.getElementById('altaObraSocial').value.trim() || null,
            numero_afiliado: document.getElementById('altaNumeroAfiliado').value.trim() || null
          })
        });
        const resultado = await response.json();
        ocultarLoading();

        if (response.ok && resultado.success) {
          document.getElementById('modalConfirmarContainer').innerHTML = '';
          await cargarTurnos();
        } else {
          throw new Error(resultado.message || 'Error al dar de alta');
        }
      } catch (error) {
        ocultarLoading();
        btn.disabled = false; btn.innerHTML = '✅ Guardar e Iniciar Consulta';
        alert('❌ ' + error.message);
      }
    }

