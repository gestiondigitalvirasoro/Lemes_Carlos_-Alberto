    async function _cancelarForzado(turnoId) {
      mostrarLoading('Cancelando turno...');
      try {
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ estado: 'CANCELADA' })
        });
        if (!response.ok) throw new Error(await response.text());
        ocultarLoading();
        await cargarTurnos();
      } catch (error) {
        ocultarLoading();
        alert('❌ Error al cancelar: ' + error.message);
      }
    }

    function filtrarTurnos() {
      mostrarLoading('Filtrando turnos...');
      setTimeout(() => {
        const nombre = document.getElementById('filtroNombre').value.toLowerCase().trim() || '';
        const estado = document.getElementById('filtroEstado').value.toUpperCase().trim() || '';
        const fechaInput = document.getElementById('filtroFecha').value || ''; // Formato: YYYY-MM-DD
        
        const filtrados = turnosGlobales.filter(t => {
          // Filtro por nombre (busca en nombre O apellido)
          let coincideNombre = true;
          if (nombre) {
            const personaNombre = (t.persona?.nombre || '').toLowerCase();
            const personaApellido = (t.persona?.apellido || '').toLowerCase();
            coincideNombre = personaNombre.includes(nombre) || personaApellido.includes(nombre);
          }
          
          // Filtro por estado (ahora t.estado es un objeto { id, nombre })
          const coincideEstado = !estado || t.estado?.nombre === estado;
          
          // Filtro por fecha (convertir formato DD/MM/YYYY a YYYY-MM-DD para comparación)
          let coincideFecha = true;
          if (fechaInput) {
            const [day, month, year] = t.fecha.split('/');
            const fechaBD = `${year}-${month.padStart(2,'0')}-${day.padStart(2,'0')}`;
            coincideFecha = fechaBD === fechaInput;
          }
          
          return coincideNombre && coincideEstado && coincideFecha;
        });
        
        console.log(`Filtrado: nombre="${nombre}", estado="${estado}", fecha="${fechaInput}" - Resultados: ${filtrados.length}`);
        mostrarTurnos(filtrados);
        ocultarLoading();
      }, 100);
    }

    async function cambiarEstado(turnoId, nuevoEstado) {
      // Validar que no sea el mismo estado
      const turnoActual = turnosGlobales.find(t => String(t.id) === String(turnoId));
      if (!turnoActual) {
        alert('❌ Turno no encontrado');
        return;
      }

      const estadoActual = turnoActual.estado?.nombre || turnoActual.estado;
      if (estadoActual === nuevoEstado) {
        return; // No hacer nada si es el mismo estado
      }

      // Si es ELIMINAR
      if (nuevoEstado === 'ELIMINAR') {
        if (!confirm('⚠️ ¿Estás seguro que deseas ELIMINAR este turno? Esta acción no se puede deshacer.')) {
          await cargarTurnos();
          return;
        }
        
        mostrarLoading('Eliminando turno...');
        try {
          const response = await fetch(`/api/turnos/${turnoId}`, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            },
            credentials: 'include'
          });

          if (!response.ok) {
            throw new Error(`Error ${response.status} al eliminar turno`);
          }

          const resultado = await response.json();
          if (resultado.success) {
            alert('✅ Turno eliminado correctamente');
            await cargarTurnos();
          } else {
            throw new Error(resultado.message || 'Error al eliminar');
          }
        } catch (error) {
          ocultarLoading();
          alert('❌ Error al eliminar turno: ' + error.message);
          await cargarTurnos();
        }
        return;
      }

      // Si el turno está EN_CONSULTA, verificar consulta registrada
      if (turnoActual.estado?.nombre === 'EN_CONSULTA') {
        mostrarLoading('Verificando consulta...');
        let tieneConsulta = false;
        try {
          const resp = await fetch(`/api/turnos/${turnoId}/tiene-historia-clinica`, { credentials: 'include' });
          const resultado = await resp.json();
          tieneConsulta = resultado.tiene_historia;
        } catch (e) {}
        ocultarLoading();

        if (nuevoEstado === 'FINALIZADA' && !tieneConsulta) {
          mostrarModalSinHC(turnoId, turnoActual);
          return;
        }

        if (nuevoEstado === 'CANCELADA' && tieneConsulta) {
          mostrarModalCancelarConConsulta(turnoId, turnoActual);
          return;
        }
      }

      mostrarLoading(`Actualizando estado...`);
      try {
        console.log(`📤 Enviando cambio de estado: turnoId=${turnoId}, nuevoEstado=${nuevoEstado}`);
        
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'include',
          body: JSON.stringify({ estado: nuevoEstado })
        });

        console.log(`📥 Response status: ${response.status}, ok: ${response.ok}`);

        if (!response.ok) {
          const errorText = await response.text();
          console.error('Response body:', errorText);
          throw new Error(`Error ${response.status}: ${errorText}`);
        }

        const resultado = await response.json();
        console.log('📨 Respuesta del servidor:', resultado);
        
        if (resultado.success) {
          await cargarTurnos();
        } else {
          throw new Error(resultado.message || 'Error desconocido del servidor');
        }
      } catch (error) {
        console.error('❌ Error completo:', error);
        alert('❌ Error al cambiar estado: ' + error.message);
        // Recargar la tabla para evitar inconsistencias
        await cargarTurnos();
      } finally {
        ocultarLoading();
      }
    }

    // Cargar estados desde backend
    async function cargarEstados() {
      try {
        console.log('📥 Cargando estados desde /api/estados-turnos...');
        const response = await fetch('/api/estados-turnos', {
          credentials: 'include'
        });
        
        if (!response.ok) {
          console.error(`❌ Error en respuesta: ${response.status}`);
          throw new Error(`HTTP Error: ${response.status}`);
        }
        
        const datos = await response.json();
        console.log('✅ Respuesta recibida:', datos);
        
        if (datos.success && datos.data && datos.data.length > 0) {
          estadosTurnos = datos.data;
          console.log(`✅ ${estadosTurnos.length} estados cargados:`, estadosTurnos.map(e => e.nombre));
          
          // Actualizar select de filtros
          const selectEstado = document.getElementById('filtroEstado');
          if (selectEstado) {
            const optionActual = selectEstado.value;
            selectEstado.innerHTML = '<option value="">Todos los estados</option>';
            estadosTurnos.forEach(estado => {
              const option = document.createElement('option');
              option.value = estado.nombre;
              option.textContent = estado.nombre.replace(/_/g, ' ');
              selectEstado.appendChild(option);
            });
            selectEstado.value = optionActual;
            console.log('✅ Select de filtros actualizado');
          }
        } else {
          console.error('❌ Respuesta sin datos:', datos);
          estadosTurnos = [];
        }
      } catch (err) {
        console.error('❌ Error al cargar estados:', err);
        estadosTurnos = [];
      }
    }

    // Inicializar event listeners para filtros
