    function abrirWhatsAppTurno() {
      const tel = document.getElementById('compartirTelefono').value.replace(/\D/g, '');
      if (!tel) { alert('Ingresá un número de teléfono'); return; }
      const d = window._compartirData || {};
      const msg = encodeURIComponent(`Hola ${d.nombre}! Tu turno con ${d.medico} quedó CONFIRMADO para el ${d.fecha} a las ${d.hora}. Ante cualquier consulta comuníquese con el consultorio. Consultorio L &amp; L.`);
      window.open(`https://wa.me/549${tel}?text=${msg}`, '_blank');
    }

    async function enviarEmailTurnoNotif() {
      const email = document.getElementById('compartirEmail').value.trim();
      if (!email) { alert('Ingresá un email'); return; }
      const d = window._compartirData || {};
      const statusEl = document.getElementById('emailNotifStatus');
      statusEl.style.color = '#666';
      statusEl.textContent = 'Enviando...';
      try {
        const resp = await fetch('/api/notificar-turno', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, nombrePaciente: d.nombre, fechaTurno: d.fecha, horaTurno: d.hora, medico: d.medico })
        });
        const result = await resp.json();
        if (result.success) {
          statusEl.style.color = '#10b981';
          statusEl.textContent = '✅ Email enviado correctamente';
        } else {
          statusEl.style.color = '#ef4444';
          statusEl.textContent = '❌ ' + result.message;
        }
      } catch (e) {
        statusEl.style.color = '#ef4444';
        statusEl.textContent = '❌ Error al enviar email';
      }
    }

    async function accionSolTurno(accion, id, extra) {
      const card = document.getElementById(`sol-row-${id}`);
      try {
        if (accion === 'wa') {
          window.open(extra, '_blank');
          await fetch(`/api/solicitudes-turno/${id}/notificar`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            credentials: 'include', body: JSON.stringify({ canal: 'whatsapp' })
          });
          if (card) card.querySelector('[style*="ffc107"],[style*="17a2b8"]') && (card.innerHTML = card.innerHTML.replace(/Pendiente|Notificado/, 'Notificado'));
        } else if (accion === 'email') {
          const resp = await fetch(`/api/solicitudes-turno/${id}/notificar`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            credentials: 'include', body: JSON.stringify({ canal: 'email', email: extra })
          });
          const data = await resp.json();
          alert(data.success ? '✅ Email enviado' : '❌ ' + (data.error || 'Error'));
        } else if (accion === 'notificado') {
          await fetch(`/api/solicitudes-turno/${id}/estado`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            credentials: 'include', body: JSON.stringify({ estado: 'Notificado' })
          });
          alert('✅ Marcado como Notificado');
        } else if (accion === 'asignado' || accion === 'cancelar') {
          const estado = accion === 'asignado' ? 'Turno asignado' : 'Cancelada';
          await fetch(`/api/solicitudes-turno/${id}/estado`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            credentials: 'include', body: JSON.stringify({ estado })
          });
          if (card) { card.style.transition = 'opacity 0.3s'; card.style.opacity = '0'; setTimeout(() => card.remove(), 300); }
        } else if (accion === 'cerrar') {
          if (card) { card.style.transition = 'opacity 0.3s'; card.style.opacity = '0'; setTimeout(() => card.remove(), 300); }
        }
        // Actualizar badge
        cargarBadgeSolicitudes();
      } catch(e) { alert('Error al procesar acción'); }
    }

    async function cargarBadgeSolicitudes() {
      try {
        const resp = await fetch('/api/solicitudes-turno/count', { credentials: 'include' });
        const data = await resp.json();
        const badge = document.getElementById('badge-solicitudes');
        if (badge) {
          badge.textContent = data.count || '';
          badge.style.display = data.count > 0 ? 'inline-flex' : 'none';
        }
      } catch(e) {}
    }

    async function notificarSolSec(id, telefono, email) {
      const canal = telefono ? (confirm('¿Enviar por WhatsApp?\nCancelar = Email') ? 'whatsapp' : 'email') : 'email';
      if (canal === 'email' && !email) { alert('El paciente no tiene email registrado.'); return; }
      try {
        const resp = await fetch(`/api/solicitudes-turno/${id}/notificar`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ canal, telefono, email })
        });
        const data = await resp.json();
        if (canal === 'whatsapp' && data.url) { window.open(data.url, '_blank'); }
        else { alert(data.success ? '✅ Email enviado' : '❌ ' + data.error); }
      } catch(e) { alert('Error al notificar'); }
    }

    // ============================================================================
    // CONFIRMAR LLEGADA DEL PACIENTE
    // ============================================================================
    function abrirConfirmarLlegada(turnoId, paciente, turno) {
      document.getElementById('modalTurnoId').value = turnoId;
      document.getElementById('modalPacienteNombre').value = paciente.nombre + ' ' + paciente.apellido;
      document.getElementById('modalPacienteDni').value = paciente.dni;
      document.getElementById('modalPacienteTelefono').value = paciente.telefono || '';
      document.getElementById('modalFecha').value = new Date(turno.fecha).toLocaleDateString('es-AR');
      document.getElementById('modalHora').value = turno.hora;
      document.getElementById('modalObraSocial').value = paciente.paciente?.obra_social || '';
      document.getElementById('modalNumeroAfiliado').value = paciente.paciente?.numero_afiliado || '';
      
      const modal = new bootstrap.Modal(document.getElementById('modalConfirmarLlegada'));
      modal.show();
    }

    function guardarConfirmacionLlegada() {
      const turnoId = document.getElementById('modalTurnoId').value;
      const obraSocial = document.getElementById('modalObraSocial').value;
      const numeroAfiliado = document.getElementById('modalNumeroAfiliado').value;
      
      fetch(`/api/turnos/${turnoId}/confirmar-llegada`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          obra_social: obraSocial,
          numero_afiliado: numeroAfiliado
        }),
        credentials: 'include'
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('✅ Llegada confirmada exitosamente');
          bootstrap.Modal.getInstance(document.getElementById('modalConfirmarLlegada')).hide();
          setTimeout(() => window.location.reload(), 1500);
        } else {
          alert('❌ Error: ' + (data.error || 'No se pudo confirmar la llegada'));
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }
  </script>

