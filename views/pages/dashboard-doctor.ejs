  <!-- MODAL: CONSULTA ACTIVA DETECTADA -->
  <div class="modal fade" id="modalConsultaActiva" tabindex="-1" backdrop="static" keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header" style="background: #DC3545; color: white; border: none;">
          <h5 class="modal-title">
            <i class="bi bi-exclamation-circle"></i> Consulta Activa Detectada
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="alert alert-warning mb-3">
            <strong>⚠️ Ya hay una consulta en curso</strong>
            <p class="mb-2 mt-2">Paciente: <strong id="consulta-activa-paciente">-</strong></p>
            <p class="mb-0">Hora: <strong id="consulta-activa-hora">--:--</strong></p>
          </div>
          <p class="mb-0"><strong>Opción 1:</strong> Finalizar la consulta actual para pasar al siguiente paciente</p>
          <p class="mb-0"><strong>Opción 2:</strong> Cancelar la consulta actual si fue cancelada por el paciente</p>
        </div>
        <div class="modal-footer gap-2">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
            <i class="bi bi-arrow-left"></i> Atrás
          </button>
          <button type="button" class="btn btn-success" onclick="terminarConsultaActivaDashboard()" style="width: auto;">
            <i class="bi bi-check-circle"></i> Finalizar Consulta
          </button>
          <button type="button" class="btn btn-danger" onclick="cancelarConsultaActivaDashboard()" style="width: auto;">
            <i class="bi bi-x-circle"></i> Cancelar Consulta
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- LOADER OVERLAY -->
  <div class="loader-overlay" id="loaderOverlay">
    <div class="loader-container">
      <div class="spinner"></div>
      <div class="loader-text" id="loaderText">Procesando...</div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 🔐 TOKEN PASADO POR EL SERVIDOR
    const TOKEN_FROM_SERVER = '<%= token %>';
    console.log('🔐 Token recibido del servidor:', TOKEN_FROM_SERVER.substring(0, 50) + '...');
    
    // Guardar en localStorage
    if (TOKEN_FROM_SERVER && TOKEN_FROM_SERVER.trim().length > 10) {
      localStorage.setItem('token', TOKEN_FROM_SERVER);
      console.log('✅ Token guardado en localStorage');
    }
    
    let turnosHoy = [];
    let historiasData = {};
    let pacientesList = [];
    let consultaActivaData = null;
    let turnoEnIntento = null;

    // Funciones para el loader
    function showLoading(mensaje = 'Procesando...') {
      document.getElementById('loaderText').textContent = mensaje;
      document.getElementById('loaderOverlay').classList.add('active');
    }

    function hideLoading() {
      document.getElementById('loaderOverlay').classList.remove('active');
    }

    document.addEventListener('DOMContentLoaded', function () {
      cargarTurnos();
      cargarAlertas();
      cargarPacientes();
      // ❌ ELIMINADO: setInterval por consumo de recursos
      // Las recarga es manual mediante botones o acciones del usuario
    });

    // ============================================================
    // CARGAR LISTA DE PACIENTES (para autocomplete)
    // ============================================================
    function cargarPacientes() {
      fetch('/api/pacientes-lista', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            pacientesList = data.data;
            console.log('👥 Pacientes cargados:', pacientesList.length);
          }
        })
        .catch(error => console.error('Error:', error));
    }

    // ============================================================
    // CARGAR TURNOS DE HOY
    // ============================================================
    function cargarTurnos() {
      fetch('/api/dashboard-turnos', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => {
          console.log('📡 Response status:', res.status);
          return res.json();
        })
        .then(data => {
          console.log('📊 Turnos cargados:', data);
          if (data.success && data.data) {
            // 🔄 Ordenar por PRIORIDAD de estado + hora
            turnosHoy = data.data.sort((a, b) => {
              // Prioridad de estados: EN_CONSULTA > PENDIENTE > FINALIZADA/CANCELADA
              const prioridad = {
                'EN_CONSULTA': 1,
                'PENDIENTE': 2,
                'FINALIZADA': 3,
                'CANCELADA': 4
              };
              
              const prioA = prioridad[a.estado] || 99;
              const prioB = prioridad[b.estado] || 99;
              
              // Primero comparar por prioridad
              if (prioA !== prioB) {
                return prioA - prioB;
              }
              
              // Si tienen la misma prioridad, ordenar por hora
              return a.hora.localeCompare(b.hora);
            });
            
            console.log('✅ Turnos ordenados por prioridad:', turnosHoy.length);
            console.log('   Próximo:', turnosHoy[0]?.estado, turnosHoy[0]?.hora);
            mostrarSiguientePaciente();
            mostrarTablaTurnos();
          } else {
            console.error('❌ Error en respuesta:', data);
          }
        })
        .catch(error => {
          console.error('❌ Error en fetch:', error);
        });
    }

    // ============================================================
    // MOSTRAR SIGUIENTE PACIENTE (PRIORIZA EN_CONSULTA)
    // ============================================================
    function mostrarSiguientePaciente() {
      if (turnosHoy.length === 0) {
        document.getElementById('siguiente-nombre').textContent = 'Sin turnos próximos';
        document.getElementById('siguiente-hora').textContent = '--:--';
        document.getElementById('siguiente-fecha').textContent = '--/--/----';
        document.getElementById('siguiente-botones').innerHTML = '<p class="text-muted">No hay pacientes pendientes</p>';
        return;
      }

      // 🔥 PRIORIZAR EN_CONSULTA sobre PENDIENTE
      let siguiente = turnosHoy.find(t => t.estado === 'EN_CONSULTA');
      if (!siguiente) {
        siguiente = turnosHoy.find(t => t.estado === 'PENDIENTE');
      }
      
      if (!siguiente) {
        document.getElementById('siguiente-nombre').textContent = 'Sin turnos próximos';
        document.getElementById('siguiente-hora').textContent = '--:--';
        document.getElementById('siguiente-botones').innerHTML = '<p class="text-muted">Todos los turnos han sido completados</p>';
        return;
      }

      const paciente = siguiente.paciente;

      // Formatear fecha
      const fechaObj = new Date(siguiente.hora.split(':')[0] === '0' ? new Date() : new Date());
      const [year, month, day] = [fechaObj.getFullYear(), String(fechaObj.getMonth() + 1).padStart(2, '0'), String(fechaObj.getDate()).padStart(2, '0')];
      const fechaFormato = `${day}/${month}/${year}`;

      document.getElementById('siguiente-nombre').textContent = `${paciente.nombre} ${paciente.apellido}`;
      document.getElementById('siguiente-hora').textContent = siguiente.hora;
      document.getElementById('siguiente-fecha').textContent = fechaFormato;
      document.getElementById('siguiente-dni').textContent = paciente.dni;
      document.getElementById('siguiente-telefono').textContent = paciente.telefono || '-';
      document.getElementById('siguiente-edad').textContent = paciente.edad;
      document.getElementById('siguiente-obra').textContent = paciente.obraSocial || '-';

      const estadoBadge = document.getElementById('siguiente-estado');
      estadoBadge.textContent = siguiente.estado;
      estadoBadge.className = `estado-badge estado-${siguiente.estado}`;

      // 🔥 BOTONES SEGÚN ESTADO
      const botonesDiv = document.getElementById('siguiente-botones');
      botonesDiv.innerHTML = '';

      if (siguiente.estado === 'PENDIENTE') {
        // PENDIENTE: Iniciar, Cancelar
        botonesDiv.innerHTML = `
          <button class="btn btn-primary" style="width: 100%; padding: 12px; font-weight: 600; margin-bottom: 8px;" onclick="iniciarConsultaTurno(${siguiente.id})">
            <i class="bi bi-play-circle"></i> Iniciar Consulta
          </button>
          <button class="btn btn-outline-danger" style="width: 100%; padding: 12px; font-weight: 600;" onclick="cancelarConsultaTurno(${siguiente.id})">
            <i class="bi bi-x-circle"></i> Cancelar Consulta
          </button>
        `;
      } else if (siguiente.estado === 'EN_CONSULTA') {
        // EN_CONSULTA: Ver Historia, Finalizar, Cancelar
        botonesDiv.innerHTML = `
          <button class="btn btn-info" style="width: 100%; padding: 12px; font-weight: 600; margin-bottom: 8px;" onclick="abrirHistoriaClinica(${siguiente.id}, ${siguiente.paciente.id})">
            <i class="bi bi-file-earmark-text"></i> Ver Historia Clínica
          </button>
          <button class="btn btn-success" style="width: 100%; padding: 12px; font-weight: 600; margin-bottom: 8px;" onclick="finalizarConsultaTurno(${siguiente.id})">
            <i class="bi bi-check-circle"></i> Finalizar Consulta
          </button>
          <button class="btn btn-outline-danger" style="width: 100%; padding: 12px; font-weight: 600;" onclick="cancelarConsultaTurno(${siguiente.id})">
            <i class="bi bi-x-circle"></i> Cancelar Consulta
          </button>
        `;
      }

      console.log('✅ Próximo paciente mostrado:', siguiente.estado, paciente.nombre);
    }

    // ============================================================
    // CAMBIAR ESTADO DEL TURNO
    // ============================================================
    async function iniciarConsultaTurno(turnoId) {
      try {
        showLoading('Iniciando consulta y abriendo historia clínica...');
        console.log('🔄 Iniciando consulta para turno:', turnoId);
        const token = localStorage.getItem('token');
        console.log('🔑 Token en localStorage:', token ? '✅ Presente' : '❌ No presente');
        
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',  // 👈 ENVIAR COOKIES AUTOMÁTICAMENTE
          body: JSON.stringify({ estado: 'EN_CONSULTA' })
        });

        console.log('📡 Response status:', response.status);
        const data = await response.json();
        console.log('📊 Response data:', data);

        if (!response.ok) {
          if (response.status === 401) {
            console.error('❌ AUTHENTICATION ERROR');
            hideLoading();
            throw new Error('🔐 AUTENTICACIÓN: Token inválido o expirado. Contacta al administrador.');
          }
          
          if (response.status === 403) {
            console.error('❌ PERMISSION ERROR');
            hideLoading();
            throw new Error('❌ PERMISO: Solo doctor o secretaria pueden cambiar el estado del turno');
          }
          
          if (response.status === 409) {
            console.warn('⚠️ CONFLICT: Ya hay una consulta activa');
            hideLoading();
            // Guardar datos para gestión de conflicto
            consultaActivaData = data.consultaActiva || {};
            turnoEnIntento = turnoId;
            // Mostrar modal en lugar de alert
            mostrarModalConsultaActiva(data);
            return;
          }
          
          hideLoading();
          throw new Error(data.message || 'Error al cambiar el estado');
        }

        console.log('✅ Consulta iniciada:', data);
        
        // 🎯 Obtener paciente_id del response
        const pacienteId = data.data?.paciente_id;
        console.log('👤 Paciente ID:', pacienteId);
        
        if (!pacienteId) {
          throw new Error('No se pudo obtener el ID del paciente');
        }

        // 📂 Abrir historia clínica automáticamente en nueva pestaña
        console.log('📂 Abriendo historia clínica automáticamente...');
        const historiaUrl = `/doctor/pacientes/${pacienteId}?turno_id=${turnoId}`;
        const ventanaHistoria = window.open(historiaUrl, '_blank');
        
        if (!ventanaHistoria) {
          console.warn('⚠️ La ventana emergente fue bloqueada por el navegador');
        }
        
        hideLoading();
        
        // Recargar los turnos en la pestaña actual después de un pequeño delay
        setTimeout(() => {
          console.log('🔄 Recargando turnos en la pestaña actual...');
          cargarTurnos();
        }, 500);
        
      } catch (error) {
        hideLoading();
        console.error('❌ Error:', error);
        alert('Error: ' + error.message);
      }
    }

    async function finalizarConsultaTurno(turnoId) {
      try {
        showLoading('Finalizando consulta...');
        console.log('🔄 Finalizando consulta para turno:', turnoId);
        const token = localStorage.getItem('token');
        console.log('🔑 Token en localStorage:', token ? '✅ Presente' : '❌ No presente');
        
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',  // 👈 ENVIAR COOKIES AUTOMÁTICAMENTE
          body: JSON.stringify({ estado: 'FINALIZADA' })
        });

        console.log('📡 Response status:', response.status);
        const data = await response.json();
        console.log('📊 Response data:', data);

        if (!response.ok) {
          hideLoading();
          if (response.status === 401) {
            console.error('❌ AUTHENTICATION ERROR');
            throw new Error('🔐 AUTENTICACIÓN: Token inválido o expirado');
          }
          if (response.status === 403) {
            console.error('❌ PERMISSION ERROR');
            throw new Error('❌ PERMISO: Solo doctor o secretaria pueden finalizar turnos');
          }
          throw new Error(data.message || 'Error al finalizar la consulta');
        }

        console.log('✅ Consulta finalizada:', data);
        hideLoading();
        alert('✅ Consulta finalizada correctamente');
        // 🔄 Automáticamente cargar el siguiente turno
        setTimeout(() => {
          console.log('🔄 Cargando siguiente turno automáticamente...');
          cargarTurnos();
        }, 500);
      } catch (error) {
        hideLoading();
        console.error('❌ Error:', error);
        alert('Error: ' + error.message);
      }
    }

    // ============================================================
    // CANCELAR CONSULTA
    // ============================================================
    async function cancelarConsultaTurno(turnoId) {
      if (!confirm('¿Estás seguro de que deseas cancelar esta consulta?')) {
        return;
      }

      try {
        showLoading('Cancelando consulta...');
        console.log('🔄 Cancelando consulta para turno:', turnoId);
        const token = localStorage.getItem('token');
        
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',
          body: JSON.stringify({ estado: 'CANCELADA' })
        });

        console.log('📡 Response status:', response.status);
        const data = await response.json();
        console.log('📊 Response data:', data);

        if (!response.ok) {
          hideLoading();
          if (response.status === 401) {
            throw new Error('🔐 AUTENTICACIÓN: Token inválido o expirado');
          }
          if (response.status === 403) {
            throw new Error('❌ PERMISO: Solo doctor o secretaria pueden cancelar turnos');
          }
          throw new Error(data.message || 'Error al cancelar la consulta');
        }

        console.log('✅ Consulta cancelada:', data);
        hideLoading();
        alert('✅ Consulta cancelada correctamente');
        cargarTurnos(); // Recargar datos
      } catch (error) {
        hideLoading();
        console.error('❌ Error:', error);
        alert('Error: ' + error.message);
      }
    }

    // ============================================================
    // ABRIR HISTORIA CLÍNICA EN NUEVA PESTAÑA
    // ============================================================
    function abrirHistoriaClinica(turnoId, pacienteId) {
      const historiaUrl = `/doctor/pacientes/${pacienteId}?turno_id=${turnoId}`;
      console.log('📂 Abriendo historia clínica en nueva pestaña:', historiaUrl);
      window.open(historiaUrl, '_blank');
    }

    // ============================================================
    // MOSTRAR TABLA DE TURNOS CON ACCIONES
    // ============================================================
    function mostrarTablaTurnos() {
      const tbody = document.getElementById('turnos-tabla-body');
      
      if (turnosHoy.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">No hay turnos hoy</td></tr>';
        return;
      }

      tbody.innerHTML = turnosHoy.map(turno => {
        const paciente = turno.paciente;
        let botonesAccion = '';

        // Generar botones según el estado
        if (turno.estado === 'PENDIENTE') {
          botonesAccion = `
            <button class="btn btn-sm btn-success" onclick="iniciarConsultaTurno(${turno.id})" title="Iniciar consulta">
              <i class="bi bi-play-circle"></i> Iniciar
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="cancelarConsultaTurno(${turno.id})" title="Cancelar turno">
              <i class="bi bi-x-circle"></i>
            </button>
          `;
        } else if (turno.estado === 'EN_CONSULTA') {
          botonesAccion = `
            <button class="btn btn-sm btn-info" onclick="abrirHistoriaClinica(${turno.id}, ${turno.paciente.id})" title="Ver historia clínica">
              <i class="bi bi-file-earmark-text"></i> Historia
            </button>
            <button class="btn btn-sm btn-success" onclick="finalizarConsultaTurno(${turno.id})" title="Finalizar consulta">
              <i class="bi bi-check-circle"></i> Finalizar
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="cancelarConsultaTurno(${turno.id})" title="Cancelar turno">
              <i class="bi bi-x-circle"></i>
            </button>
          `;
        } else if (turno.estado === 'FINALIZADA' || turno.estado === 'CANCELADA') {
          botonesAccion = `
            <span class="text-muted" style="font-size: 0.85rem;">—</span>
          `;
        }
        
        return `<tr>
          <td><small class="text-muted">${turno.fecha}</small></td>
          <td><strong>${turno.hora}</strong></td>
          <td>${paciente.nombre} ${paciente.apellido}</td>
          <td>${paciente.edad}</td>
          <td>${paciente.obraSocial || '-'}</td>
          <td><span class="estado-badge estado-${turno.estado}">${turno.estado}</span></td>
          <td style="min-width: 280px;">
            <div style="display: flex; gap: 4px; flex-wrap: wrap;">
              ${botonesAccion}
            </div>
          </td>
        </tr>`;
      }).join('');
    }

    // ============================================================
    // CARGAR ALERTAS CLÍNICAS
    // ============================================================
    function cargarAlertas() {
      fetch('/api/alertas-clinicas', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => res.json())
        .then(data => {
          console.log('🚨 Alertas:', data);
          if (data.success && data.alertas) {
            mostrarAlertas(data.alertas);
          }
        })
        .catch(error => console.error('Error alertas:', error));
    }

    function mostrarAlertas(alertas) {
      const contenedor = document.getElementById('contenedor-alertas');
      
      if (alertas.length === 0) {
        contenedor.innerHTML = `
          <div class="empty-state">
            <i class="bi bi-check-circle"></i>
            <p>Sin alertas críticas</p>
          </div>
        `;
        return;
      }

      contenedor.innerHTML = alertas.map(alerta => {
        const clases = alerta.color === '#DC3545' ? 'alerta-rojo' : 
                       alerta.color === '#FFC107' ? 'alerta-amarillo' : 'alerta-azul';
        return `
          <div class="alerta-item ${clases}">
            <div class="alerta-icono">
              <i class="bi ${alerta.tipo === 'glucemia' ? 'bi-droplet-fill' : alerta.tipo === 'imc' ? 'bi-speedometer' : 'bi-calendar-check'}"></i>
            </div>
            <div class="alerta-contenido">
              <p class="alerta-titulo">${alerta.titulo}</p>
              <p class="alerta-valor"><strong>${alerta.paciente}</strong> - ${alerta.valor}</p>
            </div>
          </div>
        `;
      }).join('');
    }

    function switchTab(tabName) {
      // Ocultar todos los tabs
      document.querySelectorAll('.tab-content').forEach(tab => {
        tab.style.display = 'none';
      });
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.classList.remove('active');
      });

      // Mostrar tab seleccionado
      document.getElementById(`tab-${tabName}`).style.display = 'block';
      event.target.classList.add('active');

      // Cargar contenido según tab
      if (tabName === 'anamnesis' && historiasData.anamnesis !== undefined) {
        document.getElementById('anamnesis-text').textContent = historiasData.anamnesis || 'Sin anamnesis registrada';
      }
      // Aquí agregarías más lógica para otros tabs...
    }

    // ============================================================
    // FUNCIONES PARA BUSCAR PACIENTES (AUTOCOMPLETE)
    // ============================================================
    function filtrarPacientes(input, containerId) {
      const valor = input.value.toLowerCase();
      const container = document.getElementById(containerId);

      if (valor.length < 2) {
        container.innerHTML = '';
        return;
      }

      const filtrados = pacientesList.filter(p =>
        p.nombre.toLowerCase().includes(valor) ||
        p.apellido.toLowerCase().includes(valor) ||
        p.dni.toString().includes(valor)
      ).slice(0, 10);

      container.innerHTML = filtrados.map(p =>
        `<div class="autocomplete-item" onclick="seleccionarPaciente(${p.id}, '${p.nombre}', '${p.apellido}', '${input.id}', '${containerId}')" style="padding:8px; cursor:pointer; border-bottom:1px solid #eee; hover:background:#f0f0f0;">
          ${p.nombre} ${p.apellido} (DNI: ${p.dni}) - ${p.obra_social || 'Sin obra social'}
        </div>`
      ).join('');
    }

    function seleccionarPaciente(id, nombre, apellido, inputId, containerId) {
      document.getElementById(inputId).value = `${nombre} ${apellido}`;
      document.getElementById(inputId.replace('-input', '-id')).value = id;
      document.getElementById(containerId).innerHTML = '';
    }

    // ============================================================
    // FUNCIONES PARA GUARDAR
    // ============================================================
    // ==== MANEJO DE OPCIONES: Buscar vs Crear Paciente ====
    function initOpcionesTurno() {
      const opcionBuscar = document.getElementById('opcion-buscar');
      const opcionCrear = document.getElementById('opcion-crear');
      const seccionBuscar = document.getElementById('seccion-buscar');
      const seccionCrear = document.getElementById('seccion-crear');

      if (!opcionBuscar || !opcionCrear) {
        console.log('⚠️ Elementos no encontrados, reintentando...');
        setTimeout(initOpcionesTurno, 100);
        return;
      }

      opcionBuscar.addEventListener('change', () => {
        if (seccionBuscar) seccionBuscar.style.display = 'block';
        if (seccionCrear) seccionCrear.style.display = 'none';
      });

      opcionCrear.addEventListener('change', () => {
        if (seccionBuscar) seccionBuscar.style.display = 'none';
        if (seccionCrear) seccionCrear.style.display = 'block';
      });
    }

    // Ejecutar cuando el modal se abre
    const modalNuevoTurno = document.getElementById('modalNuevoTurno');
    if (modalNuevoTurno) {
      modalNuevoTurno.addEventListener('show.bs.modal', () => {
        initOpcionesTurno();
      });
    }

    function guardarNuevoTurno() {
      const opcionElement = document.querySelector('input[name="opcion-paciente"]:checked');
      if (!opcionElement) {
        alert('⚠️ Selecciona una opción');
        return;
      }

      const opcion = opcionElement.value;
      const fecha = document.getElementById('turno-fecha').value;
      const hora = document.getElementById('turno-hora').value;

      if (!fecha || !hora) {
        alert('⚠️ Falta Fecha y/o Hora');
        return;
      }

      if (opcion === 'buscar') {
        // Opción: Buscar PERSONA existente CON TURNO
        const personaId = document.getElementById('turno-paciente-id').value;
        if (!personaId) {
          alert('⚠️ Selecciona una persona con turno');
          return;
        }
        const obs = document.getElementById('turno-obs').value;

        showLoading('Creando turno...');
        fetch('/api/turnos/crear', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            persona_id: personaId,
            fecha: fecha,
            hora: hora,
            observaciones: obs
          })
        })
          .then(res => res.json())
          .then(data => {
            hideLoading();
            if (data.success) {
              alert('✅ Turno creado exitosamente');
              const modal = bootstrap.Modal.getInstance(document.getElementById('modalNuevoTurno'));
              if (modal) modal.hide();
              document.getElementById('formNuevoTurno').reset();
              cargarTurnos();
            } else {
              alert('❌ Error: ' + (data.message || data.error));
            }
          })
          .catch(err => {
            hideLoading();
            console.error('Error:', err);
            alert('❌ Error al crear turno');
          });
      } else {
        // Opción: Crear nuevo paciente
        const nombre = document.getElementById('turno-nombre').value.trim();
        const apellido = document.getElementById('turno-apellido').value.trim();
        const dni = document.getElementById('turno-dni').value.trim();

        if (!nombre || !apellido || !dni) {
          alert('⚠️ Completa Nombre, Apellido y DNI');
          return;
        }

        const telefono = document.getElementById('turno-telefono').value?.trim() || null;
        const fecha_nacimiento = document.getElementById('turno-fecha-nac').value || null;
        const obra_social = document.getElementById('turno-obra-social').value?.trim() || null;
        const numero_afiliado = document.getElementById('turno-numero-afiliado').value?.trim() || null;
        const obs = document.getElementById('turno-obs').value;

        showLoading('Creando paciente y turno...');
        fetch('/api/turnos/crear-con-paciente', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre,
            apellido,
            dni,
            telefono,
            fecha_nacimiento,
            obra_social,
            numero_afiliado,
            fecha,
            hora,
            observaciones: obs
          })
        })
          .then(res => res.json())
          .then(data => {
            hideLoading();
            if (data.success) {
              alert('✅ Paciente y Turno creados');
              const modal = bootstrap.Modal.getInstance(document.getElementById('modalNuevoTurno'));
              if (modal) modal.hide();
              document.getElementById('formNuevoTurno').reset();
              document.getElementById('opcion-buscar').checked = true;
              cargarTurnos();
            } else {
              alert('❌ Error: ' + (data.message || data.error));
            }
          })
          .catch(err => {
            hideLoading();
            console.error('Error:', err);
            alert('❌ Error al crear paciente y turno');
          });
      }
    }

    function guardarNuevaConsulta() {
      const pacienteId = document.getElementById('consulta-paciente-id').value;
      const motivo = document.getElementById('consulta-motivo').value;

      if (!pacienteId || !motivo) {
        alert('Completa todos los campos');
        return;
      }

      fetch('/api/consultas/crear', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paciente_id: pacienteId, motivo_consulta: motivo })
      })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✅ Consulta iniciada');
            document.getElementById('formNuevaConsulta').reset();
            bootstrap.Modal.getInstance(document.getElementById('modalNuevaConsulta')).hide();
          } else {
            alert('❌ Error: ' + data.error);
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Error: ' + error.message);
        });
    }

