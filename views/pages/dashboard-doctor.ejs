    // ============================================================
    // GESTIONAR CONSULTA ACTIVA
    // ============================================================
    function mostrarModalConsultaActiva(data) {
      const modal = new bootstrap.Modal(document.getElementById('modalConsultaActiva'));
      const paciente = data.consultaActiva?.paciente || 'Desconocido';
      const hora = data.consultaActiva?.hora || '--:--';
      
      document.getElementById('consulta-activa-paciente').textContent = paciente;
      document.getElementById('consulta-activa-hora').textContent = hora;
      
      // Guardar ID para uso en los botones
      window.consultaActivaId = data.consultaActiva?.id;
      
      modal.show();
    }

    async function terminarConsultaActivaDashboard() {
      const turnoId = window.consultaActivaId;
      if (!turnoId) {
        alert('Error: No se encontró ID de consulta activa');
        return;
      }

      try {
        showLoading('Finalizando consulta activa...');
        const token = localStorage.getItem('token');
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',
          body: JSON.stringify({ estado: 'FINALIZADA' })
        });

        if (!response.ok) {
          hideLoading();
          throw new Error('Error al finalizar consulta');
        }

        hideLoading();
        alert('✅ Consulta finalizada correctamente');
        
        // Cerrar modal
        const modal = bootstrap.Modal.getInstance(document.getElementById('modalConsultaActiva'));
        if (modal) modal.hide();

        // Limpiar datos
        window.consultaActivaId = null;

        // Recargar turnos
        await new Promise(r => setTimeout(r, 500));
        cargarTurnos();
      } catch (error) {
        hideLoading();
        console.error('Error:', error);
        alert('Error al finalizar consulta: ' + error.message);
      }
    }

    async function cancelarConsultaActivaDashboard() {
      if (!confirm('¿Estás seguro de que deseas cancelar la consulta activa?')) {
        return;
      }

      const turnoId = window.consultaActivaId;
      if (!turnoId) {
        alert('Error: No se encontró ID de consulta activa');
        return;
      }

      try {
        showLoading('Cancelando consulta...');
        const token = localStorage.getItem('token');
        const response = await fetch(`/api/turnos/${turnoId}/estado`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            ...(token && { 'Authorization': `Bearer ${token}` })
          },
          credentials: 'include',
          body: JSON.stringify({ estado: 'CANCELADA' })
        });

        if (!response.ok) {
          hideLoading();
          throw new Error('Error al cancelar consulta');
        }

        hideLoading();
        alert('✅ Consulta cancelada correctamente');
        
        // Cerrar modal
        const modal = bootstrap.Modal.getInstance(document.getElementById('modalConsultaActiva'));
        if (modal) modal.hide();

        // Limpiar datos
        window.consultaActivaId = null;

        // Recargar turnos
        await new Promise(r => setTimeout(r, 500));
        cargarTurnos();
      } catch (error) {
        hideLoading();
        console.error('Error:', error);
        alert('Error al cancelar consulta: ' + error.message);
      }
    }

    function abrirAgendaSemanal() {
      // Mostrar modal
      const modal = new bootstrap.Modal(document.getElementById('modalAgendaSemanal'));
      modal.show();

      // Cargar turnos de la semana
      console.log('📅 Abriendo Agenda Semanal...');
      
      fetch('/api/agenda-semanal', {
        method: 'GET',
        credentials: 'include'
      })
        .then(res => res.json())
        .then(data => {
          if (data.success && data.data) {
            console.log('📊 Turnos cargados para agenda:', data.data.length);
            mostraAgendaSemanal(data.data);
          } else {
            console.warn('⚠️ No hay datos en la agenda:', data);
          }
        })
        .catch(error => console.error('❌ Error al cargar agenda:', error));
    }

    function mostraAgendaSemanal(turnos) {
      // Crear vista tipo timeline
      const container = document.getElementById('calendario-timeline');
      container.innerHTML = '';

      // Agrupar turnos por día y por hora
      const hoy = new Date();
      const diasNombre = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
      const horasDisponibles = [];
      for (let h = 8; h <= 18; h++) {
        horasDisponibles.push(`${String(h).padStart(2, '0')}:00`);
      }

      // Agrupar turnos por fecha
      const turnoPorFechaYHora = {};
      turnos.forEach(turno => {
        // Extraer solo la parte de fecha (YYYY-MM-DD)
        let fechaStr = turno.fecha;
        if (typeof fechaStr === 'string' && fechaStr.includes('T')) {
          fechaStr = fechaStr.split('T')[0];  // "2026-02-27T00:00:00Z" → "2026-02-27"
        }
        
        if (!turnoPorFechaYHora[fechaStr]) {
          turnoPorFechaYHora[fechaStr] = {};
        }
        if (!turnoPorFechaYHora[fechaStr][turno.hora]) {
          turnoPorFechaYHora[fechaStr][turno.hora] = [];
        }
        turnoPorFechaYHora[fechaStr][turno.hora].push(turno);
      });

      console.log('📊 Turnos agrupados por fecha:', Object.keys(turnoPorFechaYHora));

      // Crear encabezado con días de la semana
      const headerImg = document.createElement('div');
      headerImg.style.cssText = 'background: #f8f9fa; font-weight: 700; padding: 10px; border-right: 1px solid #ddd;';
      headerImg.textContent = 'Hora';
      container.appendChild(headerImg);

      // Encabezado: Días de la semana
      for (let i = 0; i < 7; i++) {
        const fecha = new Date(hoy);
        fecha.setDate(hoy.getDate() + i);
        const dd = String(fecha.getDate()).padStart(2, '0');
        const mm = String(fecha.getMonth() + 1).padStart(2, '0');
        const yyyy = fecha.getFullYear();
        const fechaKey = `${yyyy}-${mm}-${dd}`;
        const diaLabel = diasNombre[fecha.getDay()];

        const headerCell = document.createElement('div');
        headerCell.style.cssText = 'background: #f8f9fa; font-weight: 700; padding: 10px; text-align: center; border-right: 1px solid #ddd;';
        headerCell.innerHTML = `<div style="font-size: 1.1rem;">${dd}</div><div style="font-size: 0.85rem; color: #666;">${diaLabel}</div>`;
        container.appendChild(headerCell);
      }

      // Filas de horas
      horasDisponibles.forEach(hora => {
        // Celda de hora
        const horCell = document.createElement('div');
        horCell.style.cssText = 'background: #f8f9fa; font-weight: 600; padding: 10px; border-right: 1px solid #ddd; text-align: center; font-size: 0.9rem;';
        horCell.textContent = hora;
        container.appendChild(horCell);

        // Celdas para cada día
        for (let i = 0; i < 7; i++) {
          const fecha = new Date(hoy);
          fecha.setDate(hoy.getDate() + i);
          const dd = String(fecha.getDate()).padStart(2, '0');
          const mm = String(fecha.getMonth() + 1).padStart(2, '0');
          const yyyy = fecha.getFullYear();
          const fechaKey = `${yyyy}-${mm}-${dd}`;

          const cell = document.createElement('div');
          cell.style.cssText = `
            background: white;
            min-height: 60px;
            border-right: 1px solid #ddd;
            border-bottom: 1px solid #ddd;
            padding: 4px;
            position: relative;
            overflow: hidden;
          `;

          // Buscar turnos en esta hora y día
          const turnosenHora = turnoPorFechaYHora[fechaKey]?.[hora] || [];
          
          if (turnosenHora.length > 0) {
            const colores = {
              'PENDIENTE': '#FFC107',
              'CONFIRMADO': '#17A2B8',
              'EN_CONSULTA': '#007BFF',
              'COMPLETA': '#28A745',
              'CANCELADA': '#DC3545',
              'NO_PRESENTADO': '#6C757D'
            };

            turnosenHora.forEach(turno => {
              const block = document.createElement('div');
              const color = colores[turno.estado] || '#ccc';
              
              block.style.cssText = `
                background: ${color};
                color: white;
                padding: 6px;
                border-radius: 4px;
                font-size: 0.8rem;
                margin-bottom: 2px;
                cursor: ${turno.estado === 'PENDIENTE' ? 'pointer' : 'default'};
                font-weight: 600;
                word-wrap: break-word;
              `;

              const persona = turno.persona || turno.paciente; // Soportar ambos formatos
              const nombreCorto = persona.nombre.split(' ')[0];
              block.innerHTML = `
                <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                  ${nombreCorto}
                </div>
                <div style="font-size: 0.75rem; opacity: 0.9;">${turno.hora}</div>
              `;

              block.title = `${persona.nombre} ${persona.apellido} - ${turno.estado}`;
              
              if (turno.estado === 'PENDIENTE') {
                block.onclick = () => iniciarConsultaTurno(turno.id);
                block.style.cursor = 'pointer';
              }

              cell.appendChild(block);
            });
          }

          container.appendChild(cell);
        }
      });
    }

