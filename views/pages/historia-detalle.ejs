                }
            });
            console.log(`🔬 Estudios cargados: ${estudiosSeleccionados.length}`);
        });

        function formatearFecha(fechaStr) {
            if (!fechaStr || fechaStr === '-') return '-';
            
            try {
                const fecha = new Date(fechaStr);
                // Verificar que la fecha sea válida
                if (isNaN(fecha.getTime())) {
                    return '-';
                }
                return fecha.toLocaleDateString('es-AR', { 
                    year: 'numeric', 
                    month: '2-digit', 
                    day: '2-digit' 
                });
            } catch (e) {
                return '-';
            }
        }

        function convertirFechaToInput(fechaStr) {
            if (!fechaStr || fechaStr.trim() === '' || fechaStr === '-' || fechaStr === null) {
                return new Date().toISOString().split('T')[0]; // Fecha de hoy
            }
            
            // Si ya está en formato ISO YYYY-MM-DD (lo que devolvemos del servidor)
            if (/^\d{4}-\d{2}-\d{2}$/.test(fechaStr)) {
                return fechaStr;
            }
            
            // Si está en formato ISO completo "2026-03-16T00:00:00Z"
            if (fechaStr.includes('T')) {
                return fechaStr.split('T')[0];
            }
            
            // Si está en formato local (DD/MM/YYYY)
            const partes = fechaStr.split('/');
            if (partes.length === 3) {
                const dia = partes[0].padStart(2, '0');
                const mes = partes[1].padStart(2, '0');
                const año = partes[2];
                return `${año}-${mes}-${dia}`;
            }
            
            // Fallback: retornar hoy
            return new Date().toISOString().split('T')[0];
        }

        function agregarFilaEstudio() {
            const newRow = document.createElement('tr');
            newRow.style.borderBottom = '1px solid #f0f0f0';
            const newId = 'nuevo-' + Date.now();
            newRow.dataset.estudiadoId = newId;
            newRow.innerHTML = `
                <td style="padding: 8px;">
                    <input type="text" class="estudio-tipo" placeholder="Ej: HbA1c, Glucemia" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;">
                </td>
                <td style="padding: 8px;">
                    <input type="text" class="estudio-resultado" placeholder="Ej: 7.8, 142" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px; color: #e74c3c; font-weight: 600;">
                </td>
                <td style="padding: 8px;">
                    <input type="text" class="estudio-observaciones" placeholder="Observaciones" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;">
                </td>
                <td style="padding: 8px;">
                    <input type="date" class="estudio-fecha" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 4px;">
                </td>
                <td style="padding: 8px;">
                    <button onclick="eliminarFilaEstudio(this)" style="background: #dc3545; color: white; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 11px;">
                        <i class="bi bi-trash"></i> Eliminar
                    </button>
                </td>
            `;
            estudiosTableBody.appendChild(newRow);
            
            // Si el contenedor está vacío, ocultar el mensaje y mostrar tabla
            const estudiosEmpty = document.getElementById('estudiosEmpty');
            if (estudiosEmpty) {
                estudiosEmpty.style.display = 'none';
            }
        }

        function eliminarFilaEstudio(btn) {
            btn.closest('tr').remove();
            actualizarEstudiosCuenta();
        }

        function actualizarEstudiosCuenta() {
            const count = document.querySelectorAll('[data-estudio-idx], [data-estudiado-id]').length;
            document.getElementById('estudiosCount').textContent = count.toString();
            document.getElementById('estudiosCountSidebar').textContent = count.toString();
        }

        // Eventos drag-drop
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => {
                dropZone.style.background = '#e7f3ff';
                dropZone.style.borderColor = '#0066cc';
            });
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => {
                dropZone.style.background = '#f9f9ff';
                dropZone.style.borderColor = '#0066cc';
            });
        });

        // Drop handler
        dropZone.addEventListener('drop', handleDrop);
        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', (e) => handleFiles(e.target.files));

        function handleDrop(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            handleFiles(files);
        }

        async function handleFiles(files) {
            if (!modoEdicion) {
                alert('Habilita modo edición para agregar archivos');
                return;
            }

            console.log('📁 Preview LOCAL de ' + files.length + ' archivo(s) - sin subir aún');
            
            for (const file of files) {
                if (file.size > 10 * 1024 * 1024) {
                    alert('Archivo ' + file.name + ' es muy grande (máx 10MB)');
                    continue;
                }
                
                const adjunto = {
                    id: Date.now() + Math.random(),
                    file: file,
                    nombre_archivo: file.name,
                    tipo: file.type,
                    tamano: (file.size / 1024 / 1024).toFixed(2) + ' MB',
                    preview: true,
                    url: URL.createObjectURL(file)
                };
                
                adjuntosSubidos.push(adjunto);
                console.log('✅ Preview local: ' + file.name);
                mostrarArchivoEnUI(adjunto);
            }
            
            document.getElementById('adjuntosCount').textContent = adjuntosSubidos.length.toString();
        }

        async function subirArchivosACloudinary() {
            const archivosNuevos = adjuntosSubidos.filter(a => a.preview);
            if (archivosNuevos.length === 0) return;
            
            console.log('☁️ Subiendo ' + archivosNuevos.length + ' archivo(s) a Cloudinary...');
            
            for (const adjunto of archivosNuevos) {
                try {
                    const formData = new FormData();
                    formData.append('file', adjunto.file);
                    formData.append('historia_id', historiaId);
                    
                    console.log('📤 Subiendo: ' + adjunto.nombre_archivo);
                    const response = await fetch('/api/upload-documento', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    if (result.success) {
                        console.log('✅ En Cloudinary: ' + result.documento.cloudinary_id);
                        adjunto.preview = false;
                        adjunto.cloudinary_id = result.documento.cloudinary_id;
                        adjunto.url_storage = result.documento.url_storage;
                        adjunto.id = result.documento.id;
                    } else {
                        throw new Error(result.message);
                    }
                } catch (error) {
                    console.error('❌ Error subiendo ' + adjunto.nombre_archivo + ':', error.message);
                    alert('Error: ' + error.message);
                    throw error;
                }
            }
            console.log('✅ Todos los archivos en Cloudinary');
        }

        function mostrarArchivoEnUI(adjunto) {
            // Verificar si el contenedor está vacío
            if (adjuntosContainer.innerHTML.includes('Sin archivos adjuntos')) {
                adjuntosContainer.innerHTML = '';
            }

            const div = document.createElement('div');
            div.className = 'file-card';
            div.dataset.id = adjunto.id;
            div.style.cssText = `
                background: white;
                border: 1px solid #e0e0e0;
                border-radius: 6px;
                padding: 12px;
                text-align: center;
                transition: all 0.2s;
                position: relative;
            `;

            const isImage = adjunto.tipo.includes('image');
            const icon = isImage ? 'bi-image' : 'bi-file';

            let html = `
                <i class="bi ${icon}" style="font-size: 2rem; color: #666; display: block; margin-bottom: 8px;"></i>
                <div style="font-size: 11px; color: #666; word-break: break-word; margin-bottom: 8px;">
                    ${adjunto.nombre_archivo.substring(0, 20)}
                </div>
                <small style="color: #999; display: block; margin-bottom: 10px;">
                    ${new Date(adjunto.fecha_carga).toLocaleDateString('es-AR')}
                </small>
            `;

            if (modoEdicion) {
                html += `
                    <button onclick="removerArchivo(${adjunto.id})" 
                        style="background: #dc3545; color: white; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 11px;">
                        <i class="bi bi-trash"></i> Eliminar
                    </button>
                `;
            }

            div.innerHTML = html;
            adjuntosContainer.appendChild(div);
        }

        function removerArchivo(id) {
            adjuntosSubidos = adjuntosSubidos.filter(a => a.id !== id);
            document.querySelector(`[data-id="${id}"]`)?.remove();
            
            // Actualizar contador
            const count = document.querySelectorAll('[data-id]').length;
            document.getElementById('adjuntosCount').textContent = count.toString();
            
            // Si no hay archivos, mostrar mensaje
            if (count === 0) {
                adjuntosContainer.innerHTML = `
                    <div style="grid-column: 1/-1; text-align: center; padding: 30px; color: #999;">
                        <i class="bi bi-inbox" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                        <p>Sin archivos adjuntos aún</p>
                    </div>
                `;
            }
        }

        // ========== FUNCIONES PARA ARCHIVOS ADJUNTOS ==========
        
        function abrirArchivoModal(url, nombre) {
            const modal = document.getElementById('archivoModal');
            const viewer = document.getElementById('archivoViewer');
            const titulo = document.getElementById('archivoTitulo');
            
            titulo.textContent = nombre;
            
            // Detectar tipo de archivo
            const isPdf = nombre.toLowerCase().includes('pdf');
            const isImage = ['jpg', 'jpeg', 'png', 'gif', 'webp'].some(ext => nombre.toLowerCase().includes(ext));
            const isDocument = ['doc', 'docx', 'xls', 'xlsx', 'ppt', 'pptx'].some(ext => nombre.toLowerCase().includes(ext));
            
            viewer.innerHTML = '';
            
            if (isPdf || isDocument) {
                // Usar Google Docs Viewer para PDFs y documentos Office
                const googleDocsUrl = `https://docs.google.com/gview?url=${encodeURIComponent(url)}&embedded=true`;
                viewer.innerHTML = `
                    <iframe src="${googleDocsUrl}" style="width: 100%; height: 600px; border: none; margin: 0;">
                        <p>Tu navegador no soporta iframes. <a href="${url}" target="_blank">Click aquí para descargar el archivo</a></p>
                    </iframe>
                `;
            } else if (isImage) {
                viewer.innerHTML = `
                    <img src="${url}" alt="${nombre}" style="max-width: 100%; max-height: 600px; object-fit: contain; border-radius: 4px;">
                `;
            } else {
                viewer.innerHTML = `
                    <div style="padding: 40px; text-align: center; color: #666;">
                        <p style="font-size: 32px; margin-bottom: 20px;">📎</p>
                        <p><strong>${nombre}</strong></p>
                        <p style="color: #999; margin-top: 20px;">Tipo de archivo no soportado para vista previa</p>
                        <button class="btn btn-primary" style="margin-top: 20px;" onclick="descargarArchivo('${url}', '${nombre}')">
                            <i class="bi bi-download"></i> Descargar
                        </button>
                    </div>
                `;
            }
            
            modal.style.display = 'block';
        }
        
        function cerrarArchivoModal() {
            const modal = document.getElementById('archivoModal');
            modal.style.display = 'none';
        }
        
        function descargarArchivo(url, nombre) {
            const a = document.createElement('a');
            a.href = url;
            a.download = nombre || 'archivo';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            console.log('⬇️ Descargando: ' + nombre);
        }
        
        async function eliminarAdjunto(id, nombre) {
            if (!confirm('¿Eliminar archivo: ' + nombre + '?')) return;
            
            try {
                console.log('🗑️ Eliminando adjunto:', id);
                const response = await fetch(`/api/documento/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${localStorage.getItem('token')}`
                    }
                });
                
                if (!response.ok) throw new Error('Error al eliminar');
                
                // Eliminar del DOM
                document.querySelector(`[data-id="${id}"]`)?.remove();
                console.log('✅ Archivo eliminado');
                
                // Actualizar contador
                const adjContainer = document.getElementById('adjuntosContainer');
                const count = adjContainer.children.length;
                const adjCount = document.getElementById('adjuntosCount');
                if (adjCount) adjCount.textContent = count;
                
            } catch (error) {
                console.error('❌ Error:', error);
                alert('Error al eliminar el archivo: ' + error.message);
            }
        }
        
        // Cerrar modal al hacer clic fuera de él
        window.addEventListener('click', function(event) {
            const modal = document.getElementById('archivoModal');
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        });
    </script>

    <!-- ========== MODAL PARA VER ARCHIVOS ========== -->
    <div id="archivoModal" style="display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.6); padding: 20px; animation: fadeIn 0.3s ease;">
        <div style="background-color: white; margin: auto; padding: 0; border-radius: 12px; width: 90%; max-width: 1000px; max-height: 85vh; display: flex; flex-direction: column; box-shadow: 0 10px 40px rgba(0,0,0,0.3); animation: slideUp 0.3s ease;">
            <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px 25px; border-bottom: none; display: flex; justify-content: space-between; align-items: center; border-radius: 12px 12px 0 0;">
                <h5 style="margin: 0; font-weight: 700; color: white; font-size: 18px;" id="archivoTitulo">Ver archivo</h5>
                <button type="button" onclick="cerrarArchivoModal()" style="border: none; background: none; font-size: 28px; cursor: pointer; color: white; padding: 0; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.2)'" onmouseout="this.style.transform='scale(1)'">
                  ×
                </button>
            </div>
            <div id="archivoViewer" style="flex: 1; overflow: auto; padding: 30px; display: flex; align-items: center; justify-content: center; background: #f8f9fa;">
                <!-- El contenido se carga dinámicamente -->
            </div>
            <div style="background: #f8f9fa; padding: 18px 25px; border-top: 1px solid #e0e0e0; text-align: right; border-radius: 0 0 12px 12px; display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" class="btn" style="padding: 10px 24px; background: #6c757d; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 14px; transition: background 0.2s;" 
                  onmouseover="this.style.background='#5a6268'" onmouseout="this.style.background='#6c757d'"
                  onclick="cerrarArchivoModal()">
                  Cerrar
                </button>
            </div>
        </div>
    </div>

    <style>
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes slideUp {
        from { 
          opacity: 0;
          transform: translateY(20px);
        }
        to { 
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>

</body>
</html>
