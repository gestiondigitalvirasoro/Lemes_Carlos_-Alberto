        async function guardarCambios() {
            if (!historiaId) {
                alert('Error: Historia ID no encontrado');
                return;
            }

            try {
                // Mostrar loading overlay
                const loadingOverlay = document.getElementById('loadingOverlay');
                if (loadingOverlay) {
                    loadingOverlay.classList.add('active');
                }
                
                // Obtener el ID de la consulta actual o crear una nueva
                let consulta_id = null;
                const consultaActual = historiaData.consultas?.[consultaActualIdx];
                
                if (consultaActual?.id) {
                    // Usar consulta existente
                    consulta_id = consultaActual.id;
                    console.log('📤 Usando consulta existente:', consulta_id);
                } else {
                    // Crear nueva consulta
                    console.log('📝 Creando nueva consulta...');
                    const createResponse = await fetch('/api/consultas/crear', {
                      method: 'POST',
                      headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${localStorage.getItem('token')}`
                      },
                      credentials: 'include',
                      body: JSON.stringify({
                        paciente_id: pacienteId,
                        historia_id: historiaId,
                        turno_id: '<%= turno_id %>' || null,
                        motivo_consulta: document.getElementById('motivoConsulta')?.value || 'Sin especificar'
                      })
                    });
                    
                    if (!createResponse.ok) {
                      const errorData = await createResponse.json();
                      throw new Error('Error al crear consulta: ' + (errorData.message || createResponse.statusText));
                    }
                    
                    const dataCreated = await createResponse.json();
                    consulta_id = dataCreated.data?.id;
                    console.log('✅ Consulta creada:', consulta_id, dataCreated.data);
                    
                    if (!consulta_id) {
                      throw new Error('No se pudo obtener el ID de la nueva consulta');
                    }
                }
                
                if (!consulta_id) {
                    alert('Error: No se pudo obtener el Consulta ID');
                    return;
                }
                
                // PASO 1: Subir archivos adjuntos a Cloudinary si hay nuevos
                console.log('📝 PASO 1: Subiendo archivos adjuntos...');
                await subirArchivosACloudinary();
                // PASO 2: Recolectar y validar datos de estudios
                // Procesar TODOS los estudios del DOM (nuevos y editados)
                const todasLasFilas = document.querySelectorAll('#estudiosTableBody tr[data-estudiado-id], #estudiosTableBody tr[data-estudio-idx]');
                const estudiosActualizados = [];
                const estudiosVistosSet = new Set(); // Para detectar duplicados
                let tieneErrorEstudios = false;
                let mensajeError = '';
                
                todasLasFilas.forEach((fila, idx) => {
                    const tipoInput = fila.querySelector('.estudio-tipo');
                    const resultadoInput = fila.querySelector('.estudio-resultado');
                    const obsInput = fila.querySelector('.estudio-observaciones');
                    const fechaInput = fila.querySelector('.estudio-fecha');
                    
                    // Obtener valores - pueden ser input.value o nodo de texto
                    const tipo = (tipoInput?.value || tipoInput?.textContent || '').trim();
                    const resultado = (resultadoInput?.value || resultadoInput?.textContent || '').trim();
                    const obs = (obsInput?.value || obsInput?.textContent || '').trim();
                    const fecha = (fechaInput?.value || fechaInput?.textContent || '').trim();
                    
                    // Fila no vacía - validar TODOS los campos
                    if (tipo || resultado || obs || fecha) {
                        // VALIDACIÓN 1: TODOS los campos requeridos (NO opcionales)
                        if (!tipo || !resultado || !obs || !fecha) {
                            tieneErrorEstudios = true;
                            mensajeError = `⚠️ Fila ${idx + 1}: Todos los campos son OBLIGATORIOS (Tipo, Resultado, Observaciones, Fecha)`;
                            return; // Salir de esta iteración del forEach
                        }
                        
                        // VALIDACIÓN 2: Fecha válida
                        const fechaObj = new Date(fecha);
                        if (isNaN(fechaObj.getTime())) {
                            tieneErrorEstudios = true;
                            mensajeError = `⚠️ Fila ${idx + 1}: FECHA inválida`;
                            return; // Salir de esta iteración del forEach
                        }
                        
                        // VALIDACIÓN 3: No duplicados
                        const duplicateKey = `${tipo}|${resultado}|${obs}`;
                        if (estudiosVistosSet.has(duplicateKey)) {
                            tieneErrorEstudios = true;
                            mensajeError = `⚠️ Fila ${idx + 1}: Este estudio ya existe (duplicado)`;
                            return; // Salir de esta iteración del forEach
                        }
                        
                        estudiosVistosSet.add(duplicateKey);
                        estudiosActualizados.push({
                            tipo_estudio: tipo,
                            resultado: resultado,
                            observaciones: obs,
                            fecha_estudio: fecha
                        });
                    }
                });
                
                // Si hay error en estudios, detener
                if (tieneErrorEstudios) {
                    alert(mensajeError);
                    const loadingOverlay = document.getElementById('loadingOverlay');
                    if (loadingOverlay) {
                        loadingOverlay.classList.remove('active');
                    }
                    return;
                }
                
                console.log('✅ Estudios validados:', estudiosActualizados.length);

            const datos = {
                consulta_id: consulta_id,
                motivo_consulta: document.getElementById('motivoConsulta')?.value || '',
                anamnesis: document.getElementById('anamnesis')?.value || '',
                antecedentes: document.getElementById('antecedentes')?.value || '',
                resumen: document.getElementById('impresion')?.value || '',
                presion_sistolica: parseInt(document.getElementById('presionSistolica')?.value) || null,
                presion_diastolica: parseInt(document.getElementById('presionDiastolica')?.value) || null,
                frecuencia_cardiaca: parseInt(document.getElementById('frecuenciaCardiaca')?.value) || null,
                temperatura: parseFloat(document.getElementById('temperatura')?.value) || null,
                peso: parseFloat(document.getElementById('peso')?.value) || null,
                talla: parseFloat(document.getElementById('talla')?.value) || null,
                diagnosticos: diagnosticosSeleccionados,
                estudios: estudiosActualizados,
                adjuntos: adjuntosSubidos
            };

                console.log('📤 PASO 2: Guardando consulta #' + consultaActualIdx);
                console.log('   - Datos a guardar:', datos);
                const response = await fetch(`/api/historia/${historiaId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',  // Enviar cookies con autenticación
                    body: JSON.stringify(datos)
                });

                const result = await response.json();
                
                if (result.success) {
                    console.log('✅ Consulta guardada correctamente');
                    alert('Consulta médica guardada exitosamente');
                    
                    // Ocultar loading overlay
                    const loadingOverlay = document.getElementById('loadingOverlay');
                    if (loadingOverlay) {
                        loadingOverlay.classList.remove('active');
                    }
                    
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                    
                    // Ocultar loading overlay en caso de error
                    const loadingOverlay = document.getElementById('loadingOverlay');
                    if (loadingOverlay) {
                        loadingOverlay.classList.remove('active');
                    }
                }
            } catch (error) {
                console.error('❌ Error al guardar:', error);
                alert('Error al guardar la consulta médica: ' + error.message);
                
                // Ocultar loading overlay en caso de error
                const loadingOverlay = document.getElementById('loadingOverlay');
                if (loadingOverlay) {
                    loadingOverlay.classList.remove('active');
                }
            }
        }

        let diagnosticosSeleccionados = [];
        let debounceTimer = null;

        function agregarDiagnostico() {
            const cie10Input = document.getElementById('cie10Input');
            const codigo = cie10Input.dataset.codigo;
            const descripcion = cie10Input.dataset.descripcion;
            const capitulo = cie10Input.dataset.capitulo;
            
            if (!codigo || !descripcion) {
                alert('Por favor selecciona un diagnóstico de la lista');
                return;
            }

            // Verificar si ya existe
            if (diagnosticosSeleccionados.some(d => d.codigo === codigo)) {
                alert('Este diagnóstico ya está agregado');
                return;
            }

            // Agregar a lista
            diagnosticosSeleccionados.push({ codigo, descripcion, capitulo });

            // Actualizar UI - agregar card
            const container = document.getElementById('diagnosticosContainer');
            const div = document.createElement('div');
            div.className = 'diagnostic-card';
            div.dataset.codigo = codigo;
            div.innerHTML = `
                <div>
                    <strong>${codigo}</strong>
                    <p>${descripcion}</p>
                </div>
                <button class="btn-remove" onclick="removeDiagnostico('${codigo}')" style="display: inline-block;">
                    <i class="bi bi-trash"></i>
                </button>
            `;
            container.appendChild(div);

            // Limpiar input
            cie10Input.value = '';
            cie10Input.dataset.codigo = '';
            cie10Input.dataset.descripcion = '';
            cie10Input.dataset.capitulo = '';
            document.getElementById('cie10Dropdown').innerHTML = '';
            document.getElementById('cie10Dropdown').style.display = 'none';
            document.getElementById('btnAgregarDiag').style.display = 'none';
            
            // Actualizar contador
            document.getElementById('diagnosticosCount').textContent = diagnosticosSeleccionados.length;
        }

        function removeDiagnostico(codigo) {
            diagnosticosSeleccionados = diagnosticosSeleccionados.filter(d => d.codigo !== codigo);
            document.querySelector(`[data-codigo="${codigo}"]`)?.remove();
            document.getElementById('diagnosticosCount').textContent = diagnosticosSeleccionados.length;
        }

        // Búsqueda CIE-10 CON DEBOUNCE
        const cie10Input = document.getElementById('cie10Input');
        const cie10Dropdown = document.getElementById('cie10Dropdown');
        const btnAgregarDiag = document.getElementById('btnAgregarDiag');
        
        if (cie10Input) {
            cie10Input.addEventListener('input', async function(e) {
                const query = e.target.value.trim();
                
                // Limpiar timer anterior
                clearTimeout(debounceTimer);
                
                if (query.length < 1) {
                    cie10Dropdown.style.display = 'none';
                    btnAgregarDiag.style.display = 'none';
                    return;
                }

                // Debounce de 300ms
                debounceTimer = setTimeout(async () => {
                    try {
                        console.log(`🔍 Buscando CIE-10: "${query}"`);
                        const response = await fetch(`/api/cie10/search?q=${encodeURIComponent(query)}`);
                        
                        if (!response.ok) {
                            console.error('Error en respuesta:', response.status);
                            cie10Dropdown.innerHTML = '<div style="padding: 10px; text-align: center; color: #dc3545;">Error en la búsqueda</div>';
                            cie10Dropdown.style.display = 'block';
                            return;
                        }
                        
                        const resultados = await response.json();
                        console.log(`✅ Resultados recibidos: ${resultados.length}`);
                        
                        cie10Dropdown.innerHTML = '';
                        
                        if (resultados.length > 0) {
                            resultados.forEach(resultado => {
                                const div = document.createElement('div');
                                div.className = 'cie10-item';
                                div.style.cssText = `
                                    padding: 12px 10px;
                                    border-bottom: 1px solid #f0f0f0;
                                    cursor: pointer;
                                    transition: background 0.2s;
                                `;
                                div.innerHTML = `
                                    <div style="font-weight: 700; color: #0066cc; font-size: 13px; margin-bottom: 4px;">
                                        ${resultado.codigo}
                                    </div>
                                    <div style="font-size: 12px; color: #666; margin-bottom: 4px;">
                                        ${resultado.descripcion.substring(0, 60)}${resultado.descripcion.length > 60 ? '...' : ''}
                                    </div>
                                    <div style="font-size: 11px; color: #999;">
                                        📁 ${resultado.capitulo || 'Sin categoría'}
                                    </div>
                                `;
                                
                                div.onmouseover = () => {
                                    div.style.background = '#f9f9f9';
                                };
                                div.onmouseout = () => {
                                    div.style.background = 'white';
                                };
                                
                                div.onclick = () => {
                                    // Guardar datos en el input
                                    cie10Input.dataset.codigo = resultado.codigo;
                                    cie10Input.dataset.descripcion = resultado.descripcion;
                                    cie10Input.dataset.capitulo = resultado.capitulo;
                                    cie10Input.value = resultado.codigo + ' - ' + resultado.descripcion.substring(0, 40);
                                    
                                    // Mostrar botón Agregar
                                    btnAgregarDiag.style.display = 'inline-block';
                                    
                                    // Cerrar dropdown
                                    cie10Dropdown.style.display = 'none';
                                    console.log(`✅ Seleccionado: ${resultado.codigo}`);
                                };
                                
                                cie10Dropdown.appendChild(div);
                            });
                            cie10Dropdown.style.display = 'block';
                        } else {
                            cie10Dropdown.innerHTML = '<div style="padding: 10px; text-align: center; color: #999;">Sin resultados</div>';
                            cie10Dropdown.style.display = 'block';
                            btnAgregarDiag.style.display = 'none';
                        }
                    } catch (error) {
                        console.error('❌ Error buscando CIE-10:', error);
                        cie10Dropdown.innerHTML = '<div style="padding: 10px; text-align: center; color: #dc3545;">Error en la búsqueda: ' + error.message + '</div>';
                        cie10Dropdown.style.display = 'block';
                    }
                }, 300); // Debounce de 300ms
            });

            // Cerrar dropdown al hacer click fuera
            document.addEventListener('click', function(e) {
                if (!cie10Input.contains(e.target) && !cie10Dropdown.contains(e.target)) {
                    cie10Dropdown.style.display = 'none';
                }
            });
        }

