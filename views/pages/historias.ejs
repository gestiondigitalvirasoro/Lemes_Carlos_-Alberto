<div class="page-title">
    <div class="d-flex justify-content-between align-items-center">
        <h1>
            <i class="bi bi-file-earmark-medical"></i>
            Historias Clínicas
        </h1>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Buscar Paciente</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" class="form-control" id="filtro-paciente" placeholder="Nombre, DNI o email..." oninput="filtrarTabla()">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">&nbsp;</label>
                <button class="btn btn-outline-primary w-100" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise"></i>
                    Refrescar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de Pacientes -->
<div class="card">
    <div class="card-header">
        <i class="bi bi-list-ul"></i>
        Pacientes con Historia Clínica
    </div>
    <div class="card-body">
        <% if (!historias || historias.length === 0) { %>
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i>
                No hay pacientes con historia clínica registrada
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover" id="tabla-historias">
                    <thead class="table-light">
                        <tr>
                            <th>Paciente</th>
                            <th>DNI</th>
                            <th>Edad</th>
                            <th>Teléfono</th>
                            <th>Obra Social</th>
                            <th>Médico</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% historias.forEach(function(h) { %>
                            <tr class="historia-row" data-search="<%= (h.nombre_paciente || '').toLowerCase() %> <%= (h.dni || '').toLowerCase() %>">
                                <td><strong><%= h.nombre_paciente %></strong></td>
                                <td><%= h.dni %></td>
                                <td><%= h.edad || '-' %></td>
                                <td><%= h.telefono || '-' %></td>
                                <td><%= h.obra_social || '-' %></td>
                                <td><%= h.medico %></td>
                                <td>
                                    <a href="/historia/<%= h.paciente_id %>" class="btn btn-sm btn-outline-primary" title="Ver Historia Clínica">
                                        <i class="bi bi-eye"></i> Ver Historia
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<script>
function filtrarTabla() {
    var filtro = document.getElementById('filtro-paciente').value.toLowerCase();
    var filas = document.querySelectorAll('#tabla-historias .historia-row');
    
    filas.forEach(function(fila) {
        var texto = fila.getAttribute('data-search');
        if (filtro === '' || texto.includes(filtro)) {
            fila.style.display = '';
        } else {
            fila.style.display = 'none';
        }
    });
}
</script>
