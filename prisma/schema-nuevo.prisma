// Prisma Schema - Sistema Médico Normalizado a 3FN
// Diseño profesional para auditoría, escalabilidad y seguimiento clínico

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// 1️⃣ PERSONA - Base para todos los actores del sistema
// ============================================================================
model Persona {
  id                    BigInt      @id @default(autoincrement())
  nombre                String      @db.VarChar(100)
  apellido              String      @db.VarChar(100)
  dni                   Int         @unique
  fecha_nacimiento      DateTime?   @db.Date
  sexo                  Sexo?
  telefono              String?     @db.VarChar(20)
  email                 String?     @db.VarChar(100)
  direccion             String?
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones 1:1
  usuario               Usuario?
  medico                Medico?
  paciente              Paciente?
  
  @@index([dni], map: "idx_persona_dni")
  @@index([email], map: "idx_persona_email")
  @@map("personas")
}

// ============================================================================
// 2️⃣ USUARIO - Autenticación y control de acceso
// ============================================================================
model Usuario {
  id                    BigInt      @id @default(autoincrement())
  persona_id            BigInt      @unique
  email                 String      @unique @db.VarChar(255)
  password_hash         String      @db.VarChar(255)
  rol                   Rol         @default(ROLE_SECRETARIA)
  activo                Boolean     @default(true)
  ultimo_login          DateTime?   @db.Timestamptz(6)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  persona               Persona     @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_usuario_persona")
  consultas_realizadas  ConsultaMedica[]  @relation("MedicoConsulta")
  turnos_creados        Turno[]           @relation("SecretariaCreaTurno")
  historias_creadas     HistoriaClinica[] @relation("MedicoCreaSesion")
  documentos_subidos    DocumentoAdjunto[] @relation("MedicoSubeDocumento")
  
  @@index([rol], map: "idx_usuario_rol")
  @@index([activo], map: "idx_usuario_activo")
  @@map("usuarios")
}

// ============================================================================
// 3️⃣ MEDICO - Extensión de Persona para médicos
// ============================================================================
model Medico {
  id                    BigInt      @id @default(autoincrement())
  persona_id            BigInt      @unique
  matricula             String      @unique @db.VarChar(50)
  especialidad          String      @db.VarChar(100)
  activo                Boolean     @default(true)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  persona               Persona     @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_medico_persona")
  consultas             ConsultaMedica[]
  turnos                Turno[]
  estudios              EstudioComplementario[]
  
  @@index([matricula], map: "idx_medico_matricula")
  @@index([especialidad], map: "idx_medico_especialidad")
  @@map("medicos")
}

// ============================================================================
// 4️⃣ PACIENTE - Extensión de Persona para pacientes
// ============================================================================
model Paciente {
  id                    BigInt      @id @default(autoincrement())
  persona_id            BigInt      @unique
  obra_social           String?     @db.VarChar(100)
  numero_afiliado       String?     @db.VarChar(50)
  observaciones_generales String?
  activo                Boolean     @default(true)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  persona               Persona     @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_paciente_persona")
  historias_clinicas    HistoriaClinica[]
  turnos                Turno[]
  
  @@index([obra_social], map: "idx_paciente_obra_social")
  @@map("pacientes")
}

// ============================================================================
// 5️⃣ HISTORIA CLINICA - Registro médico único por paciente
// ============================================================================
model HistoriaClinica {
  id                    BigInt      @id @default(autoincrement())
  paciente_id           BigInt
  creada_por_medico_id  BigInt
  fecha_apertura        DateTime    @default(now()) @db.Date
  activa                Boolean     @default(true)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  paciente              Paciente    @relation(fields: [paciente_id], references: [id], onDelete: Cascade, map: "fk_historia_paciente")
  medico_apertura       Usuario     @relation("MedicoCreaSesion", fields: [creada_por_medico_id], references: [id], map: "fk_historia_medico")
  consultas             ConsultaMedica[]
  antecedentes          Antecedente[]
  documentos            DocumentoAdjunto[]
  
  @@unique([paciente_id])
  @@index([paciente_id], map: "idx_historia_paciente_id")
  @@index([activa], map: "idx_historia_activa")
  @@map("historias_clinicas")
}

// ============================================================================
// 6️⃣ CONSULTA MEDICA - Cada visita/consulta del paciente
// ============================================================================
model ConsultaMedica {
  id                    BigInt      @id @default(autoincrement())
  historia_clinica_id   BigInt
  medico_id             BigInt
  turno_id              BigInt?     @unique
  fecha                 DateTime    @db.Timestamptz(6)
  motivo_consulta       String
  resumen               String?
  estado                EstadoConsulta @default(ATENDIDA)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  historia              HistoriaClinica @relation(fields: [historia_clinica_id], references: [id], onDelete: Cascade, map: "fk_consulta_historia")
  medico                Usuario         @relation("MedicoConsulta", fields: [medico_id], references: [id], map: "fk_consulta_medico")
  turno                 Turno?          @relation(fields: [turno_id], references: [id], map: "fk_consulta_turno")
  signos_vitales        SignoVital[]
  anamnesis             Anamnesis?
  diagnosticos          Diagnostico[]
  tratamientos          Tratamiento[]
  estudios              EstudioComplementario[]
  documentos            DocumentoAdjunto[]
  
  @@index([historia_clinica_id], map: "idx_consulta_historia_id")
  @@index([medico_id], map: "idx_consulta_medico_id")
  @@index([fecha], map: "idx_consulta_fecha")
  @@index([estado], map: "idx_consulta_estado")
  @@map("consultas_medicas")
}

// ============================================================================
// 7️⃣ SIGNOS VITALES - Mediciones de salud (tabla independiente)
// ============================================================================
model SignoVital {
  id                    BigInt      @id @default(autoincrement())
  consulta_id           BigInt
  peso_kg               Decimal?    @db.Decimal(5,2)
  talla_cm              Decimal?    @db.Decimal(5,2)
  imc                   Decimal?    @db.Decimal(5,2)
  presion_sistolica     Int?
  presion_diastolica    Int?
  frecuencia_cardiaca   Int?
  temperatura_c         Decimal?    @db.Decimal(4,1)
  glucemia_mg_dl        Int?
  circunferencia_abd_cm Decimal?    @db.Decimal(5,1)
  fecha_registro        DateTime    @default(now()) @db.Timestamptz(6)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  
  // Relaciones
  consulta              ConsultaMedica @relation(fields: [consulta_id], references: [id], onDelete: Cascade, map: "fk_signo_consulta")
  
  @@index([consulta_id], map: "idx_signo_consulta_id")
  @@index([fecha_registro], map: "idx_signo_fecha")
  @@map("signos_vitales")
}

// ============================================================================
// 8️⃣ ANAMNESIS - Historial de enfermedad actual
// ============================================================================
model Anamnesis {
  id                    BigInt      @id @default(autoincrement())
  consulta_id           BigInt      @unique
  enfermedad_actual     String
  sintomas_asociados    String?
  evolucion             String?
  fecha_registro        DateTime    @default(now()) @db.Timestamptz(6)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  consulta              ConsultaMedica @relation(fields: [consulta_id], references: [id], onDelete: Cascade, map: "fk_anamnesis_consulta")
  
  @@index([consulta_id], map: "idx_anamnesis_consulta_id")
  @@map("anamnesis")
}

// ============================================================================
// 9️⃣ ANTECEDENTES - Historial médico del paciente
// ============================================================================
model Antecedente {
  id                    BigInt      @id @default(autoincrement())
  historia_clinica_id   BigInt
  tipo                  TipoAntecedente
  descripcion           String
  fecha_registro        DateTime    @default(now()) @db.Timestamptz(6)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  historia              HistoriaClinica @relation(fields: [historia_clinica_id], references: [id], onDelete: Cascade, map: "fk_antecedente_historia")
  
  @@index([historia_clinica_id], map: "idx_antecedente_historia_id")
  @@index([tipo], map: "idx_antecedente_tipo")
  @@map("antecedentes")
}

// ============================================================================
// 🔟 DIAGNOSTICOS - Diagnósticos de cada consulta
// ============================================================================
model Diagnostico {
  id                    BigInt      @id @default(autoincrement())
  consulta_id           BigInt
  codigo_cie10          String?     @db.VarChar(10)
  descripcion           String
  principal             Boolean     @default(false)
  fecha_registro        DateTime    @default(now()) @db.Timestamptz(6)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  
  // Relaciones
  consulta              ConsultaMedica @relation(fields: [consulta_id], references: [id], onDelete: Cascade, map: "fk_diagnostico_consulta")
  
  @@index([consulta_id], map: "idx_diagnostico_consulta_id")
  @@index([codigo_cie10], map: "idx_diagnostico_cie10")
  @@index([principal], map: "idx_diagnostico_principal")
  @@map("diagnosticos")
}

// ============================================================================
// 1️⃣1️⃣ TRATAMIENTOS - Prescripciones y medicamentos
// ============================================================================
model Tratamiento {
  id                    BigInt      @id @default(autoincrement())
  consulta_id           BigInt
  medicamento           String      @db.VarChar(255)
  dosis                 String      @db.VarChar(100)
  frecuencia            String      @db.VarChar(100)
  duracion_dias         Int?
  indicaciones          String?
  fecha_inicio          DateTime    @db.Date
  fecha_fin             DateTime?   @db.Date
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  consulta              ConsultaMedica @relation(fields: [consulta_id], references: [id], onDelete: Cascade, map: "fk_tratamiento_consulta")
  
  @@index([consulta_id], map: "idx_tratamiento_consulta_id")
  @@index([fecha_inicio], map: "idx_tratamiento_fecha_inicio")
  @@map("tratamientos")
}

// ============================================================================
// 1️⃣2️⃣ ESTUDIOS COMPLEMENTARIOS - Análisis, radiografías, etc.
// ============================================================================
model EstudioComplementario {
  id                    BigInt      @id @default(autoincrement())
  consulta_id           BigInt
  tipo_estudio          String      @db.VarChar(100)
  resultado             String?
  observaciones         String?
  medico_id             BigInt
  fecha_estudio         DateTime    @db.Timestamptz(6)
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  consulta              ConsultaMedica @relation(fields: [consulta_id], references: [id], onDelete: Cascade, map: "fk_estudio_consulta")
  medico                Medico         @relation(fields: [medico_id], references: [id], map: "fk_estudio_medico")
  documentos            DocumentoAdjunto[]
  
  @@index([consulta_id], map: "idx_estudio_consulta_id")
  @@index([tipo_estudio], map: "idx_estudio_tipo")
  @@index([fecha_estudio], map: "idx_estudio_fecha")
  @@map("estudios_complementarios")
}

// ============================================================================
// 1️⃣3️⃣ DOCUMENTOS ADJUNTOS - Archivos médicos (soft delete)
// ============================================================================
model DocumentoAdjunto {
  id                    BigInt      @id @default(autoincrement())
  historia_clinica_id   BigInt
  consulta_id           BigInt?
  estudio_id            BigInt?
  nombre_archivo        String      @db.VarChar(255)
  tipo_mime             String      @db.VarChar(100)
  tamaño_bytes          BigInt
  url_storage           String      @db.VarChar(500)
  subido_por_medico_id  BigInt
  eliminado             Boolean     @default(false)
  fecha_subida          DateTime    @default(now()) @db.Timestamptz(6)
  fecha_eliminacion     DateTime?   @db.Timestamptz(6)
  
  // Relaciones
  historia              HistoriaClinica @relation(fields: [historia_clinica_id], references: [id], onDelete: Cascade, map: "fk_doc_historia")
  consulta              ConsultaMedica? @relation(fields: [consulta_id], references: [id], onDelete: SetNull, map: "fk_doc_consulta")
  estudio               EstudioComplementario? @relation(fields: [estudio_id], references: [id], onDelete: SetNull, map: "fk_doc_estudio")
  medico_subida         Usuario        @relation("MedicoSubeDocumento", fields: [subido_por_medico_id], references: [id], map: "fk_doc_medico")
  
  @@index([historia_clinica_id], map: "idx_doc_historia_id")
  @@index([eliminado], map: "idx_doc_eliminado")
  @@index([fecha_subida], map: "idx_doc_fecha_subida")
  @@map("documentos_adjuntos")
}

// ============================================================================
// 1️⃣4️⃣ TURNOS - Citas médicas
// ============================================================================
model Turno {
  id                    BigInt      @id @default(autoincrement())
  paciente_id           BigInt
  medico_id             BigInt
  fecha                 DateTime    @db.Timestamptz(6)
  hora                  String      @db.VarChar(5) // HH:mm
  estado                EstadoTurno @default(PENDIENTE)
  creado_por_secretaria_id BigInt
  observaciones         String?
  creado_en             DateTime    @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime    @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  paciente              Paciente    @relation(fields: [paciente_id], references: [id], onDelete: Cascade, map: "fk_turno_paciente")
  medico                Medico      @relation(fields: [medico_id], references: [id], map: "fk_turno_medico")
  secretaria            Usuario     @relation("SecretariaCreaTurno", fields: [creado_por_secretaria_id], references: [id], map: "fk_turno_secretaria")
  consulta              ConsultaMedica?
  
  @@index([paciente_id], map: "idx_turno_paciente_id")
  @@index([medico_id], map: "idx_turno_medico_id")
  @@index([fecha], map: "idx_turno_fecha")
  @@index([estado], map: "idx_turno_estado")
  @@map("turnos")
}

// ============================================================================
// ENUMS - Tipos de datos
// ============================================================================

enum Sexo {
  M
  F
  OTRO
  
  @@map("sexo_enum")
}

enum Rol {
  ROLE_ADMIN
  ROLE_DOCTOR
  ROLE_SECRETARIA
  
  @@map("rol_enum")
}

enum TipoAntecedente {
  PERSONAL
  FAMILIAR
  QUIRURGICO
  ALERGICO
  
  @@map("tipo_antecedente_enum")
}

enum EstadoConsulta {
  PROGRAMADA
  ATENDIDA
  CANCELADA
  NO_PRESENTADO
  
  @@map("estado_consulta_enum")
}

enum EstadoTurno {
  PENDIENTE
  CONFIRMADO
  EN_CONSULTA
  ATENDIDO
  AUSENTE
  CANCELADO
  
  @@map("estado_turno_enum")
}
