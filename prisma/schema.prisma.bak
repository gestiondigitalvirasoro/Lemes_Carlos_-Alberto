generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                    BigInt            @id @default(autoincrement())
  email                 String            @unique @db.VarChar(255)
  password_hash         String            @db.VarChar(255)
  nombre                String            @db.VarChar(100)
  apellido              String            @db.VarChar(100)
  role                  user_role         @default(secretaria)
  telefono              String?           @db.VarChar(20)
  direccion             String?
  activo                Boolean?          @default(true)
  ultimo_login          DateTime?         @db.Timestamptz(6)
  created_at            DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?         @default(now()) @updatedAt @db.Timestamptz(6)
  especialidad          String?           @db.VarChar(100)
  subespecialidad       String?           @db.VarChar(100)
  historias_como_doctor HistoriaClinica[] @relation("DoctorHistoria")
  pacientes             Paciente[]
  sesiones              Sesion[]
  turnos_como_doctor    Turno[]           @relation("TurnoDoctor")

  @@index([activo], map: "idx_usuarios_activo")
  @@index([email], map: "idx_usuarios_email")
  @@index([role], map: "idx_usuarios_role")
  @@map("usuarios")
}

model Paciente {
  id                      BigInt            @id @default(autoincrement())
  usuario_id              BigInt?
  persona_id              BigInt
  dni                     Int
  fecha_nacimiento        DateTime?         @db.Date
  genero                  gender_type?
  numero_historia_clinica String?           @unique @db.VarChar(20)
  numero_emergencia       String?           @db.VarChar(20)
  contacto_emergencia     String?           @db.VarChar(255)
  alergias                String?
  patologias_cronicas     String?
  activo                  Boolean?          @default(true)
  created_at              DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?         @default(now()) @updatedAt @db.Timestamptz(6)
  documentos              Documento[]
  historias_clinicas      HistoriaClinica[]
  usuario                 Usuario?          @relation(fields: [usuario_id], references: [id], map: "fk_pacientes_usuario")
  persona                 Persona           @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_pacientes_persona")
  turnos                  Turno[]

  @@index([numero_historia_clinica], map: "idx_pacientes_numero_historia")
  @@index([usuario_id], map: "idx_pacientes_usuario_id")
  @@index([persona_id], map: "idx_pacientes_persona_id")
  @@index([dni], map: "idx_pacientes_dni")
  @@map("pacientes")
}

model Turno {
  id               BigInt              @id @default(autoincrement())
  paciente_id      BigInt
  persona_id       BigInt
  doctor_id        BigInt
  fecha_hora       DateTime            @db.Timestamptz(6)
  duracion_minutos Int?                @default(30)
  estado           appointment_status? @default(pendiente)
  motivo           String?
  notas            String?
  sala_atencion    String?             @db.VarChar(50)
  precio_consulta  Decimal?            @db.Decimal(10, 2)
  pagado           Boolean?            @default(false)
  created_at       DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?           @default(now()) @updatedAt @db.Timestamptz(6)
  historia_clinica HistoriaClinica[]
  doctor           Usuario             @relation("TurnoDoctor", fields: [doctor_id], references: [id], map: "fk_turnos_doctor")
  paciente         Paciente            @relation(fields: [paciente_id], references: [id], onDelete: Cascade, map: "fk_turnos_paciente")
  persona          Persona             @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_turnos_persona")

  @@index([doctor_id], map: "idx_turnos_doctor_id")
  @@index([estado], map: "idx_turnos_estado")
  @@index([doctor_id, fecha_hora], map: "idx_turnos_fecha_doctor")
  @@index([fecha_hora], map: "idx_turnos_fecha_hora")
  @@index([paciente_id], map: "idx_turnos_paciente_id")
  @@index([persona_id], map: "idx_turnos_persona_id")
  @@map("turnos")
}

model HistoriaClinica {
  id                                    BigInt                @id @default(autoincrement())
  paciente_id                           BigInt
  doctor_id                             BigInt
  turno_id                              BigInt?
  signo_vital_principal_id              BigInt?             // ID de la sección de signos vitales principal
  documentacion_principal_id            BigInt?             // ID de la sección de documentación principal
  fecha                                 DateTime?            @default(dbgenerated("CURRENT_DATE")) @db.Date
  motivo_consulta                       String?
  anamnesis                             String?
  antecedentes_patologicos_personales   String?
  antecedentes_patologicos_familiares   String?
  antecedentes_quirurgicos              String?
  habitos                               String?
  examen_fisico                         String?
  diagnostico_principal                 String?
  diagnosticos_secundarios              String? // JSON array
  impresion_clinica                     String?
  tratamiento                           String? // JSON array de medicamentos
  observaciones                         String?
  created_at                            DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?            @default(now()) @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  doctor                                Usuario               @relation("DoctorHistoria", fields: [doctor_id], references: [id], map: "fk_historias_doctor")
  paciente                              Paciente              @relation(fields: [paciente_id], references: [id], onDelete: Cascade, map: "fk_historias_paciente")
  turno                                 Turno?                @relation(fields: [turno_id], references: [id], map: "fk_historias_turno")
  signo_vital_principal                 SignoVital?           @relation("HistoriaSignoPrincipal", fields: [signo_vital_principal_id], references: [id], onDelete: SetNull, map: "fk_historias_signo_principal")
  documentacion_principal               DocumentacionClinica? @relation("HistoriaDocuPrincipal", fields: [documentacion_principal_id], references: [id], onDelete: SetNull, map: "fk_historias_docu_principal")
  estudios_adjuntos                     EstudioAdjunto[]
  signos_vitales                        SignoVital[]          @relation("HistoriaSignos")
  documentaciones                       DocumentacionClinica[]

  @@index([doctor_id], map: "idx_historias_doctor_id")
  @@index([fecha], map: "idx_historias_fecha")
  @@index([paciente_id], map: "idx_historias_paciente_id")
  @@index([turno_id], map: "idx_historias_turno_id")
  @@index([signo_vital_principal_id], map: "idx_historias_signo_principal_id")
  @@index([documentacion_principal_id], map: "idx_historias_docu_principal_id")
  @@map("historias_clinicas")
}

model SignoVital {
  id                  BigInt           @id @default(autoincrement())
  historia_clinica_id BigInt
  peso_kg             Decimal?         @db.Decimal(5, 2)
  talla_cm            Decimal?         @db.Decimal(5, 2)
  imc                 Decimal?         @db.Decimal(5, 2)
  presion_sistolica   Int?
  presion_diastolica  Int?
  frecuencia_cardiaca Int?
  temperatura_c       Decimal?         @db.Decimal(4, 1)
  glucemia_mg_dl      Int?
  circunferencia_abd  Decimal?         @db.Decimal(5, 1)
  observaciones       String?
  created_at          DateTime?        @default(now()) @db.Timestamptz(6)
  
  // Relaciones
  historia_clinica    HistoriaClinica  @relation("HistoriaSignos", fields: [historia_clinica_id], references: [id], onDelete: Cascade, map: "fk_signos_vitales_historia")
  historia_principal  HistoriaClinica? @relation("HistoriaSignoPrincipal")

  @@index([historia_clinica_id], map: "idx_signos_vitales_historia_id")
  @@map("signos_vitales")
}

model EstudioAdjunto {
  id                  BigInt          @id @default(autoincrement())
  historia_clinica_id BigInt
  tipo_estudio        String          @db.VarChar(100)
  descripcion         String?
  archivo_url         String?         @db.VarChar(500)
  nombre_archivo      String?         @db.VarChar(255)
  archivo_mime_type   String?         @db.VarChar(100)
  tama_o_bytes        BigInt?         @map("tamaño_bytes")
  resultado           String?
  observaciones       String?
  created_at          DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?       @default(now()) @updatedAt @db.Timestamptz(6)
  historia_clinica    HistoriaClinica @relation(fields: [historia_clinica_id], references: [id], onDelete: Cascade, map: "fk_estudios_historia")

  @@index([historia_clinica_id], map: "idx_estudios_historia_id")
  @@index([tipo_estudio], map: "idx_estudios_tipo")
  @@map("estudios_adjuntos")
}

model DocumentacionClinica {
  id                  BigInt             @id @default(autoincrement())
  historia_clinica_id BigInt
  titulo              String?            @db.VarChar(255)
  contenido           String?
  tipo_documento      String?            @db.VarChar(50)  // ej: "informe", "nota", "prescripcion"
  archivo_url         String?            @db.VarChar(500)
  nombre_archivo      String?            @db.VarChar(255)
  archivo_mime_type   String?            @db.VarChar(100)
  tamaño_bytes        BigInt?
  observaciones       String?
  created_at          DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?          @default(now()) @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  historia_clinica    HistoriaClinica    @relation(fields: [historia_clinica_id], references: [id], onDelete: Cascade, map: "fk_documentacion_historia")
  historia_principal  HistoriaClinica?   @relation("HistoriaDocuPrincipal")

  @@index([historia_clinica_id], map: "idx_documentacion_historia_id")
  @@index([tipo_documento], map: "idx_documentacion_tipo")
  @@map("documentacion_clinica")
}

model Documento {
  id                BigInt        @id @default(autoincrement())
  paciente_id       BigInt
  tipo_documento    document_type
  numero_documento  Int?
  descripcion       String?
  archivo_url       String?       @db.VarChar(500)
  nombre_archivo    String?       @db.VarChar(255)
  archivo_mime_type String?       @db.VarChar(100)
  tama_o_bytes      BigInt?       @map("tamaño_bytes")
  fecha_vencimiento DateTime?     @db.Date
  activo            Boolean?      @default(true)
  created_at        DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?     @default(now()) @updatedAt @db.Timestamptz(6)
  paciente          Paciente      @relation(fields: [paciente_id], references: [id], onDelete: Cascade, map: "fk_documentos_paciente")

  @@index([numero_documento], map: "idx_documentos_numero")
  @@index([paciente_id], map: "idx_documentos_paciente_id")
  @@index([tipo_documento], map: "idx_documentos_tipo")
  @@map("documentos")
}

model Sesion {
  id            BigInt    @id @default(autoincrement())
  usuario_id    BigInt
  token_refresh String?   @db.VarChar(500)
  ip_address    String?   @db.Inet
  user_agent    String?
  fecha_inicio  DateTime? @default(now()) @db.Timestamptz(6)
  fecha_fin     DateTime? @db.Timestamptz(6)
  activa        Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  usuario       Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, map: "fk_sesiones_usuario")

  @@index([activa], map: "idx_sesiones_activa")
  @@index([fecha_inicio], map: "idx_sesiones_fecha_inicio")
  @@index([usuario_id], map: "idx_sesiones_usuario_id")
  @@map("sesiones")
}

enum appointment_status {
  pendiente
  confirmado
  en_consulta
  atendido
  ausente
  cancelado
}

enum document_type {
  cedula_identidad
  pasaporte
  licencia_conducir
  otro
}

enum gender_type {
  masculino
  femenino
  otro
}

enum user_role {
  admin
  doctor
  secretaria
}

model Persona {
  id                              BigInt                    @id @default(autoincrement())
  dni                             Int                       @unique
  telefono                        String?                   @db.VarChar(20)
  direccion                       String?
  email                           String?                   @db.VarChar(100)
  obra_social                     String?                   @db.VarChar(100)
  activo                          Boolean?                  @default(true)
  created_at                      DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?                 @default(now()) @updatedAt @db.Timestamptz(6)
  
  // Relaciones
  pacientes                       Paciente[]
  turnos                          Turno[]
  contactos                       ContactoPaciente[]
  obras_sociales                  ObraSocialPaciente[]
  datos_clinicos                  DatosClinicosPaciente[]

  @@index([dni], map: "idx_personas_dni")
  @@index([email], map: "idx_personas_email")
  @@index([activo], map: "idx_personas_activo")
  @@map("personas")
}

model ContactoPaciente {
  id                              BigInt                    @id @default(autoincrement())
  persona_id                      BigInt
  telefono_principal              String?                   @db.VarChar(20)
  telefono_secundario             String?                   @db.VarChar(20)
  email_principal                 String?                   @db.VarChar(100)
  email_secundario                String?                   @db.VarChar(100)
  direccion_principal             String?
  direccion_secundaria            String?
  created_at                      DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?                 @default(now()) @updatedAt @db.Timestamptz(6)
  
  persona                         Persona                   @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_contacto_persona")

  @@index([persona_id], map: "idx_contacto_persona_id")
  @@map("contacto_paciente")
}

model ObraSocialPaciente {
  id                              BigInt                    @id @default(autoincrement())
  persona_id                      BigInt
  nombre_obra_social              String?                   @db.VarChar(100)
  numero_afiliado                 String?                   @db.VarChar(50)
  plan                            String?                   @db.VarChar(100)
  vigencia_desde                  DateTime?                 @db.Date
  vigencia_hasta                  DateTime?                 @db.Date
  cobertura_porcentaje            Decimal?                  @db.Decimal(5, 2)
  activo                          Boolean?                  @default(true)
  created_at                      DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?                 @default(now()) @updatedAt @db.Timestamptz(6)
  
  persona                         Persona                   @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_obra_social_persona")

  @@index([persona_id], map: "idx_obra_social_persona_id")
  @@map("obra_social_paciente")
}

model DatosClinicosPaciente {
  id                              BigInt                    @id @default(autoincrement())
  persona_id                      BigInt
  alergias                        String?
  patologias_cronicas             String?
  antecedentes_quirurgicos        String?
  medicamentos_habituales         String?
  nota_importante                 String?
  created_at                      DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?                 @default(now()) @updatedAt @db.Timestamptz(6)
  
  persona                         Persona                   @relation(fields: [persona_id], references: [id], onDelete: Cascade, map: "fk_datos_clinicos_persona")

  @@index([persona_id], map: "idx_datos_clinicos_persona_id")
  @@map("datos_clinicos_paciente")
}
